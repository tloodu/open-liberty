<server description="Used for InMemoryIdentityStore enablement tests allowing the use of the store">

    <featureManager>
        <feature>servlet-6.1</feature>
        <feature>appSecurity-6.0</feature>
        <feature>timedexit-1.0</feature>
        <feature>componentTest-2.0</feature>
        <feature>restfulWS-4.0</feature>
    </featureManager>

   <!-- set allowInMemoryIdentityStores to false, or remove all together to disable -->
    <webAppSecurity allowInMemoryIdentityStores="true"/>
    
    <include location="../fatTestPorts.xml" />
</server>
