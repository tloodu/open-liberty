-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0

src: \
	fat/src, \
	test-applications/ConfigTestsEJB.jar/src, \
	test-applications/ConfigTestsWeb.war/src

fat.project: true

tested.features: \
	appSecurity-2.0,\
	appSecurity-3.0,\
	appSecurity-4.0,\
	appSecurity-5.0,\
	appSecurity-6.0,\
	ejbLite-3.2,\
	ejbHome-3.2,\
	ejbRemote-3.2,\
	enterpriseBeansLite-4.0,\
	enterpriseBeansHome-4.0,\
	enterpriseBeansRemote-4.0,\
	servlet-4.0,\
	servlet-5.0,\
	servlet-6.0,\
	servlet-6.1

-buildpath: \
	io.openliberty.yoko.spec.corba;version=latest,\
	io.openliberty.yoko.rmi.spec;version=latest,\
	com.ibm.websphere.javaee.annotation.1.1;version=latest,\
	com.ibm.websphere.javaee.ejb.3.1;version=latest,\
	com.ibm.websphere.javaee.servlet.3.1;version=latest

# Copy in FIPS keys
ltpa.fips.enabled: true
