-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0

src: \
  fat/src,\
  test-applications/jaxrs-interop/src,\
  test-applications/jaxws-peopleservice/src

fat.project: true

tested.features: \
  servlet-4.0, \
  jsonp-1.1, \
  jaxrsclient-2.1, \
  jaxrs-2.1, \
  restfulwsclient-3.0, \
  expressionlanguage-4.0, \
  servlet-5.0, \
  concurrent-2.0, \
  jndi-1.0, \
  xmlws-3.0, \
  restfulws-3.0, \
  xmlbinding-3.0, \
  jsonp-2.0, \
  cdi-3.0, \
  pages-3.0, \
  expressionlanguage-5.0, \
  restfulwsclient-3.1, \
  xmlws-4.0, \
  jsonp-2.1, \
  restfulws-3.1, \
  xmlbinding-4.0, \
  pages-3.1, \
  cdi-4.0, \
  servlet-6.0, \
  expressionlanguage-6.0, \
  restfulwsclient-4.0, \
  restfulws-4.0, \
  cdi-4.1, \
  pages-4.0, \
  servlet-6.1

-buildpath: \
  io.openliberty.com.fasterxml.jackson,\
  com.ibm.websphere.javaee.servlet.3.1,\
  com.ibm.websphere.javaee.jaxb.2.2;version=latest,\
  com.ibm.websphere.javaee.jaxws.2.2;version=latest,\
  com.ibm.websphere.javaee.jaxrs.2.0,\
  com.ibm.websphere.javaee.jws.1.0;version=latest

