<infinispan>
  <jgroups>
    <stack name="jgroups-tcp" extends="tcp">
      <TCPPING
        initial_hosts="${jgroups.tcpping.initial_hosts:127.0.0.1[7800]}"
        port_range="0"
        num_discovery_runs="3"
        stack.combine="REPLACE"
        stack.position="MPING"
      />
    </stack>

  </jgroups>
  
  <cache-container>
    <transport cluster="${infinispan.cluster.name}" stack="jgroups-tcp"/>
    <replicated-cache-configuration name="com.ibm.ws.MyCache.attr"/>
    <invalidation-cache-configuration name="*.session.*.inval"/>
  </cache-container>
</infinispan>
