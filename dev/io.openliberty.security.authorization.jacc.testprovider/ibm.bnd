Bundle-Name: Liberty Jakarta Authorization Provider 3.0
Bundle-SymbolicName: io.openliberty.security.authorization.jacc.testprovider
Bundle-Description: Liberty Jakarta Authorization Provider, version=${bVersion}

Export-Package: \
  com.ibm.ws.security.authorization.jacc.provider;provide:=true, \
  com.ibm.ws.security.authorization.jacc.service;provide:=true

Private-Package: com.ibm.ws.security.authorization.jacc.role

Include-Resource: \
  @\${repo;com.ibm.ws.security.authorization.jacc.testprovider.jakarta}!/(OSGI-INF/l10n/*|OSGI-INF/metatype/*)

-dsannotations: \
  com.ibm.ws.security.authorization.jacc.service.ProviderServiceImpl
