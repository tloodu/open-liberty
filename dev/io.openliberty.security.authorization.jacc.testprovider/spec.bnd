Bundle-Name: Jakarta Authorization Provider 3.0
Bundle-SymbolicName: io.openliberty.security.authorization.jacc.testprovider.spec
Bundle-Description: Jakarta Authorization Provider, version=${bVersion}

Web-ContextPath: authz

Import-Package: \
  com.ibm.websphere.ras, \
  com.ibm.websphere.security.auth, \
  com.ibm.websphere.security.cred, \
  com.ibm.wsspi.security.authorization.jacc, \
  com.ibm.ws.ffdc, \
  javax.security.auth, \
  javax.security.auth.login, \
  jakarta.security.jacc, \
  org.osgi.framework.*, \
  org.osgi.service.component.*

Private-Package: \
  com.ibm.ws.security.authorization.jacc.provider, \
  com.ibm.ws.security.authorization.jacc.role, \
  io.openliberty.security.authorization.spec

Include-Resource: \
  @\${repo;com.ibm.ws.security.authorization.jacc.testprovider.jakarta}!/(OSGI-INF/l10n/*|OSGI-INF/metatype/*), \
  WEB-INF=resources/WEB-INF

-dsannotations: \
  io.openliberty.security.authorization.spec.UserFeatureService
