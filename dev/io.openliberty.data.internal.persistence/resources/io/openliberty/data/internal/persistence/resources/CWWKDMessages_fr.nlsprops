#CMVCPATHNAME io.openliberty.data.internal/resources/io/openliberty/data/internal/persistence/resources/CWWKDMessages.nlsprops
#ISMESSAGEFILE TRUE
#NLS_ENCODING=UNICODE
#
#COMPONENTPREFIX CWWKD
#COMPONENTNAMEFOR CWWKD Jakarta Data
#
# NLS_MESSAGEFORMAT_VAR
#
#   Strings in this file which contain replacement variables are processed by the MessageFormat 
#   class (single quote must be coded as 2 consecutive single quotes ''). Strings in this file 
#   which do NOT contain replacement variables are NOT processed by the MessageFormat class 
#   (single quote must be coded as one single quote '). 

# All messages must use the range CWWKD1000 to CWWKD1399

CWWKD1000.repo.general.err=CWWKD1000E: La m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} a rencontr\u00e9 une erreur. L''erreur peut indiquer que la m\u00e9thode de d\u00e9p\u00f4t n''est pas valide. Erreur : {2}.
CWWKD1000.repo.general.err.explanation=Une erreur a \u00e9t\u00e9 trouv\u00e9e avec la m\u00e9thode de d\u00e9p\u00f4t sp\u00e9cifi\u00e9e.
CWWKD1000.repo.general.err.useraction=Localiser l'interface et la m\u00e9thode du r\u00e9f\u00e9rentiel et d\u00e9terminer si des corrections sont n\u00e9cessaires.

CWWKD1001.no.primary.entity=CWWKD1001E: La m\u00e9thode de d\u00e9p\u00f4t {0} n\u00e9cessite une classe d''entit\u00e9 mais l''interface de d\u00e9p\u00f4t {1} ne sp\u00e9cifie pas de classe d''entit\u00e9 primaire. Pour corriger cette erreur, l''interface de d\u00e9p\u00f4t peut \u00e9tendre l''un des sous-types de d\u00e9p\u00f4t int\u00e9gr\u00e9s, tels que {2}, et fournir la classe d''entit\u00e9 comme premier param\u00e8tre de type.
CWWKD1001.no.primary.entity.explanation=Les m\u00e9thodes du r\u00e9f\u00e9rentiel qui n'ont pas de classe d'entit\u00e9 propre exigent que le r\u00e9f\u00e9rentiel d\u00e9finisse une classe d'entit\u00e9 primaire.
CWWKD1001.no.primary.entity.useraction=D\u00e9finir une classe d'entit\u00e9 primaire pour le r\u00e9f\u00e9rentiel.

CWWKD1002.method.annos.err=CWWKD1002E: La m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} est annot\u00e9e avec une combinaison d''annotations qui n''est pas valide : {2}.
CWWKD1002.method.annos.err.explanation=Cette combinaison d'annotations n'est pas valable pour une seule m\u00e9thode de d\u00e9p\u00f4t.
CWWKD1002.method.annos.err.useraction=Localisez l'interface et la m\u00e9thode du r\u00e9f\u00e9rentiel et d\u00e9terminez la bonne combinaison d'annotations de m\u00e9thode.

CWWKD1003.rtrn.err=CWWKD1003E: Le type de retour {0} de la m\u00e9thode {1} de l''interface {2} du r\u00e9f\u00e9rentiel n''est pas un type de retour valide pour une m\u00e9thode {3} du r\u00e9f\u00e9rentiel. Les types de retour valides sont les suivants : {4}.
CWWKD1003.rtrn.err.explanation=Le type de retour de la m\u00e9thode ne fait pas partie des types de retour pris en charge pour le type d\u00e9clar\u00e9 de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1003.rtrn.err.useraction=Reportez-vous aux informations de la Javadoc de Jakarta Data pour les annotations Insert, Update et Save et \u00e0 la documentation Query by Method name pour les types de retour valides.

CWWKD1004.general.rtrn.err=CWWKD1004E: Le type de retour {0} de la m\u00e9thode {1} de l''interface de r\u00e9f\u00e9rentiel {2} n''est pas un type de retour valide pour une m\u00e9thode de r\u00e9f\u00e9rentiel.
CWWKD1004.general.rtrn.err.explanation=Le type de retour de la m\u00e9thode ne fait pas partie des types de retour pris en charge pour le type de m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1004.general.rtrn.err.useraction=Reportez-vous aux informations Javadoc de Jakarta Data pour obtenir une liste des types de retour valides pour le type de m\u00e9thode de r\u00e9f\u00e9rentiel.

CWWKD1005.find.rtrn.err=CWWKD1005E: La m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} n''est pas valide. La m\u00e9thode sp\u00e9cifie un type de retour {2} qui n''est pas convertible \u00e0 partir du type d''entit\u00e9 {3}. Le type de r\u00e9sultat d''une op\u00e9ration de recherche doit \u00eatre le type d''entit\u00e9, un type d''attribut d''entit\u00e9, un enregistrement Java compos\u00e9 d''attributs d''entit\u00e9 ou un type construit par la requ\u00eate qui est fournie \u00e0 l''annotation Query. Le type de retour de la m\u00e9thode de recherche du r\u00e9f\u00e9rentiel peut \u00eatre le type de r\u00e9sultat, un tableau du type de r\u00e9sultat ou l''un des types suivants param\u00e9tr\u00e9s avec le type de r\u00e9sultat : {4}.
CWWKD1005.find.rtrn.err.explanation=Le type de retour de la m\u00e9thode ne fait pas partie des types de retour pris en charge pour les m\u00e9thodes de recherche de r\u00e9f\u00e9rentiel.
CWWKD1005.find.rtrn.err.useraction=Reportez-vous aux informations Javadoc de Jakarta Data pour obtenir une liste des types de retour valides pour les m\u00e9thodes de recherche de r\u00e9f\u00e9rentiel.

CWWKD1006.delete.rtrn.err=CWWKD1006E: Le type de retour de la m\u00e9thode {1} de l''interface de r\u00e9f\u00e9rentiel {2} n''est pas un type de retour valide pour une op\u00e9ration de suppression. Le type de retour doit \u00eatre soit void, long, int, boolean, array, List ou Optional. Un type de retour de type void ne renvoie aucune valeur. Un type de retour de type long ou int renvoie un nombre de suppressions. Un type de retour bool\u00e9en indique si des entit\u00e9s ont \u00e9t\u00e9 supprim\u00e9es. Un type de retour de type tableau, liste ou optionnel, param\u00e9tr\u00e9 avec une classe d''entit\u00e9 {3} ou une classe d''identifiant unique {4} renvoie les entit\u00e9s supprim\u00e9es ou les identifiants d''entit\u00e9.
CWWKD1006.delete.rtrn.err.explanation=Le type de retour de la m\u00e9thode ne fait pas partie des types de retour pris en charge pour une op\u00e9ration de suppression.
CWWKD1006.delete.rtrn.err.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour utiliser l'un des types de retour pris en charge.

CWWKD1007.updel.rtrn.err=CWWKD1007E: Le type de retour de la m\u00e9thode {1} de l''interface de r\u00e9f\u00e9rentiel {2} n''est pas un type de retour valide pour une op\u00e9ration de r\u00e9f\u00e9rentiel {3}. Le type de retour doit \u00eatre soit void, long, int ou boolean. Un type de retour de type void ne renvoie aucune valeur. Un type de retour long ou int renvoie un nombre d''entit\u00e9s correspondantes. Un type de retour de type bool\u00e9en renvoie un indicateur indiquant si des entit\u00e9s correspondent.
CWWKD1007.updel.rtrn.err.explanation=Le type de retour de la m\u00e9thode ne fait pas partie des types de retour pris en charge pour une op\u00e9ration de mise \u00e0 jour ou de suppression.
CWWKD1007.updel.rtrn.err.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour utiliser l'un des types de retour pris en charge.

CWWKD1008.ambig.rtrn.err=CWWKD1008E: Le type de retour {0} de la m\u00e9thode {1} de l''interface du r\u00e9f\u00e9rentiel {2} est ambigu en tant que type de retour car il correspond \u00e0 plusieurs attributs d''entit\u00e9 : {3}. La m\u00e9thode du r\u00e9f\u00e9rentiel doit passer \u00e0 l''annotation Query et utiliser une requ\u00eate avec une clause SELECT qui sp\u00e9cifie l''attribut de l''entit\u00e9 \u00e0 renvoyer.
CWWKD1008.ambig.rtrn.err.explanation=Le type de retour de la m\u00e9thode ne fait pas partie des types de retour pris en charge pour une m\u00e9thode de suppression.
CWWKD1008.ambig.rtrn.err.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel afin d'utiliser l'annotation Query pour s\u00e9lectionner l'attribut de l'entit\u00e9.

CWWKD1009.lifecycle.param.err=CWWKD1009E: La m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} ne peut pas avoir de param\u00e8tres {2} parce que la m\u00e9thode est annot\u00e9e avec l''annotation {3} de cycle de vie. Les m\u00e9thodes du r\u00e9f\u00e9rentiel qui sont annot\u00e9es avec une annotation de cycle de vie doivent avoir exactement 1 param\u00e8tre, qui doit \u00eatre l''entit\u00e9 ou un tableau ou une liste de l''entit\u00e9.
CWWKD1009.lifecycle.param.err.explanation=Les m\u00e9thodes de cycle de vie doivent avoir un seul param\u00e8tre d'entit\u00e9.
CWWKD1009.lifecycle.param.err.useraction=Mise \u00e0 jour de la m\u00e9thode de d\u00e9p\u00f4t pour avoir un seul param\u00e8tre qui est une entit\u00e9, un tableau de l'entit\u00e9, ou une liste de l'entit\u00e9.

CWWKD1010.unknown.entity.attr=CWWKD1010E: Un attribut d''entit\u00e9 nomm\u00e9 {0} n''est pas trouv\u00e9 sur la classe d''entit\u00e9 {1} pour la m\u00e9thode {2} de l''interface de r\u00e9f\u00e9rentiel {3}. Les noms d''attributs valables pour l''entit\u00e9 sont les suivants {4}.
CWWKD1010.unknown.entity.attr.explanation=La m\u00e9thode du r\u00e9f\u00e9rentiel tente d'utiliser un attribut d'entit\u00e9 qui n'existe pas.
CWWKD1010.unknown.entity.attr.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour qu'elle corresponde \u00e0 un attribut valide d\u00e9fini par l'entit\u00e9.

CWWKD1011.unknown.method.pattern=CWWKD1011E: La m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} ne correspond \u00e0 aucun des mod\u00e8les d\u00e9finis par Jakarta Data. Une m\u00e9thode de r\u00e9f\u00e9rentiel doit soit utiliser des annotations, soit \u00eatre une m\u00e9thode d''acc\u00e8s aux ressources, soit \u00eatre nomm\u00e9e selon le mod\u00e8le "Query by Method Name". Des annotations telles que {2} sont utilis\u00e9es pour d\u00e9finir les op\u00e9rations. Une m\u00e9thode d''acc\u00e8s \u00e0 une ressource ne doit contenir aucun param\u00e8tre et aucun des types de retour {3}. Le mod\u00e8le d''interrogation par nom de m\u00e9thode doit commencer par l''un des mots-cl\u00e9s {4}, suivi de 0 ou plusieurs caract\u00e8res. Les noms de m\u00e9thodes peuvent \u00e9galement inclure le mot-cl\u00e9 By et une ou plusieurs conditions d\u00e9limit\u00e9es. Voici des exemples de noms de m\u00e9thodes de r\u00e9f\u00e9rentiel valides : {5}.
CWWKD1011.unknown.method.pattern.explanation=Les m\u00e9thodes de d\u00e9p\u00f4t doivent suivre les mod\u00e8les d\u00e9finis par Jakarta Data.
CWWKD1011.unknown.method.pattern.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour qu'elle soit conforme \u00e0 l'un des mod\u00e8les de Jakarta Data.

CWWKD1012.fd.missing.param.anno=CWWKD1012E: Le param\u00e8tre {0} de la m\u00e9thode {1} de l''interface {2} repository ne correspond pas \u00e0 un attribut d''entit\u00e9. Les param\u00e8tres qui ne correspondent pas \u00e0 un attribut d''entit\u00e9 doivent \u00eatre annot\u00e9s avec l''annotation By ou avoir l''un des types de param\u00e8tres sp\u00e9ciaux : {3}. Pour d\u00e9finir une condition de restriction des r\u00e9sultats de la requ\u00eate, le param\u00e8tre doit \u00eatre annot\u00e9 avec l''annotation By et la valeur de l''annotation By doit \u00eatre assign\u00e9e au nom de l''attribut de l''entit\u00e9. Vous pouvez \u00e9galement activer l''option de compilation -parameters et donner au param\u00e8tre le m\u00eame nom que l''attribut de l''entit\u00e9.
CWWKD1012.fd.missing.param.anno.explanation=Les param\u00e8tres des m\u00e9thodes de recherche et de suppression du r\u00e9f\u00e9rentiel doivent correspondre aux attributs de l'entit\u00e9 ou \u00eatre des types de param\u00e8tres sp\u00e9ciaux d\u00e9finis par Jakarta Data.
CWWKD1012.fd.missing.param.anno.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel de sorte que tous les param\u00e8tres correspondent aux attributs de l'entit\u00e9 ou aient l'un des types de param\u00e8tres sp\u00e9ciaux de Jakarta Data.

CWWKD1013.cde.missing.param.anno=CWWKD1013E: Le param\u00e8tre {0} de la m\u00e9thode {1} de l''interface {2} repository ne correspond pas \u00e0 un attribut d''entit\u00e9. Les param\u00e8tres qui ne correspondent pas \u00e0 un attribut d''entit\u00e9 doivent \u00eatre annot\u00e9s avec l''annotation By et la valeur de l''annotation By doit \u00eatre assign\u00e9e au nom de l''attribut d''entit\u00e9. Vous pouvez \u00e9galement activer l''option de compilation -parameters et donner au param\u00e8tre le m\u00eame nom que l''attribut de l''entit\u00e9.
CWWKD1013.cde.missing.param.anno.explanation=Les param\u00e8tres des m\u00e9thodes "count", "delete" et "exists" du r\u00e9f\u00e9rentiel doivent correspondre aux attributs de l'entit\u00e9.
CWWKD1013.cde.missing.param.anno.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel de mani\u00e8re \u00e0 ce que tous les param\u00e8tres correspondent aux attributs de l'entit\u00e9.

CWWKD1014.upd.missing.param.anno=CWWKD1014E: La m\u00e9thode {0} du r\u00e9f\u00e9rentiel {1} n''est pas une m\u00e9thode valide de mise \u00e0 jour du cycle de vie car la m\u00e9thode a des param\u00e8tres {2}. Les m\u00e9thodes du r\u00e9f\u00e9rentiel qui sont annot\u00e9es avec une annotation de cycle de vie doivent avoir exactement 1 param\u00e8tre, qui doit \u00eatre l''entit\u00e9, un tableau de l''entit\u00e9, ou une liste de l''entit\u00e9. La m\u00e9thode {0} n''est pas non plus une op\u00e9ration de mise \u00e0 jour bas\u00e9e sur un param\u00e8tre valide car le param\u00e8tre de m\u00e9thode {3} n''a pas d''annotation ( {4} ) qui indique le nom de l''attribut de l''entit\u00e9. Vous pouvez \u00e9galement activer l''option de compilation -parameters et donner au param\u00e8tre le m\u00eame nom que l''attribut de l''entit\u00e9.
CWWKD1014.upd.missing.param.anno.explanation=Les param\u00e8tres des m\u00e9thodes de mise \u00e0 jour du r\u00e9f\u00e9rentiel doivent correspondre aux attributs de l'entit\u00e9. Par ailleurs, les m\u00e9thodes de cycle de vie doivent avoir un seul param\u00e8tre d'entit\u00e9.
CWWKD1014.upd.missing.param.anno.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel de mani\u00e8re \u00e0 ce que tous les param\u00e8tres correspondent aux attributs de l'entit\u00e9. Une autre solution consiste \u00e0 mettre \u00e0 jour la m\u00e9thode de d\u00e9p\u00f4t pour qu'elle ait un seul param\u00e8tre qui soit une entit\u00e9, un tableau de l'entit\u00e9 ou une liste de l'entit\u00e9.

CWWKD1015.null.entity.param=CWWKD1015E: La m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} ne peut pas accepter une entit\u00e9 nulle.
CWWKD1015.null.entity.param.explanation=Les m\u00e9thodes de cycle de vie n\u00e9cessitent une instance d'entit\u00e9 non nulle.
CWWKD1015.null.entity.param.useraction=Mise \u00e0 jour du code de l'application pour \u00e9viter de fournir une valeur d'entit\u00e9 nulle \u00e0 la m\u00e9thode de d\u00e9p\u00f4t.

CWWKD1016.incompat.entity.param=CWWKD1016E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} requiert une entit\u00e9 {2}, mais une valeur {3} a \u00e9t\u00e9 fournie.
CWWKD1016.incompat.entity.param.explanation=La m\u00e9thode de cycle de vie n'accepte que les valeurs d'entit\u00e9 du type d\u00e9clar\u00e9.
CWWKD1016.incompat.entity.param.useraction=Mettre \u00e0 jour le code de l'application pour fournir une valeur d'entit\u00e9 du m\u00eame type que celui d\u00e9clar\u00e9 par la m\u00e9thode du r\u00e9f\u00e9rentiel.

CWWKD1017.dup.special.param=CWWKD1017E: La m\u00e9thode {0} du r\u00e9f\u00e9rentiel {1} ne peut pas avoir plusieurs param\u00e8tres {2}.
CWWKD1017.dup.special.param.explanation=Certains param\u00e8tres sp\u00e9ciaux de Jakarta Data, notamment Limit et PageRequest, ne peuvent pas appara\u00eetre plusieurs fois dans la signature d'une m\u00e9thode de r\u00e9f\u00e9rentiel.
CWWKD1017.dup.special.param.useraction=Mettre \u00e0 jour la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel pour qu'elle contienne au plus une occurrence du type de param\u00e8tre sp\u00e9cial Jakarta Data.

CWWKD1018.confl.special.param=CWWKD1018E: La m\u00e9thode {0} du r\u00e9f\u00e9rentiel {1} ne peut pas avoir un param\u00e8tre {2} et un param\u00e8tre {3}.
CWWKD1018.confl.special.param.explanation=Certains param\u00e8tres sp\u00e9ciaux de Jakarta Data, tels que Limit et PageRequest, ne peuvent pas \u00eatre combin\u00e9s dans une m\u00eame signature de m\u00e9thode de r\u00e9f\u00e9rentiel.
CWWKD1018.confl.special.param.useraction=Mise \u00e0 jour du r\u00e9f\u00e9rentiel pour ne pas utiliser les deux types de param\u00e8tres sp\u00e9ciaux de Jakarta Data dans la m\u00eame signature de m\u00e9thode.

CWWKD1019.mixed.positional.named=CWWKD1019E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} ne peut pas avoir une requ\u00eate qui m\u00e9lange des param\u00e8tres positionnels et des param\u00e8tres nomm\u00e9s. L''interface d\u00e9finit une combinaison de {2} param\u00e8tres positionnels et {3} param\u00e8tres nomm\u00e9s {4} pour la valeur d''annotation Query : {5}. Une requ\u00eate avec des param\u00e8tres positionnels doit r\u00e9f\u00e9rencer chaque param\u00e8tre par sa valeur ordinale, en commen\u00e7ant par?1, et les param\u00e8tres de la m\u00e9thode ne doivent pas avoir l''annotation Param. Dans une requ\u00eate avec des param\u00e8tres nomm\u00e9s, chaque param\u00e8tre doit \u00eatre r\u00e9f\u00e9renc\u00e9 par son nom, comme {6}, et les param\u00e8tres de la m\u00e9thode doivent avoir l''annotation Param, comme {7}. Par ailleurs, l''activation de l''option de compilation -parameters permet aux param\u00e8tres des m\u00e9thodes d''indiquer le param\u00e8tre nomm\u00e9\
    \ en faisant correspondre son nom, par exemple, {8}.
CWWKD1019.mixed.positional.named.explanation=Les requ\u00eates avec param\u00e8tres doivent utiliser tous les param\u00e8tres nomm\u00e9s ou tous les param\u00e8tres positionnels, et non une combinaison.
CWWKD1019.mixed.positional.named.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour n'utiliser que des param\u00e8tres nomm\u00e9s ou des param\u00e8tres positionnels.

CWWKD1020.invalid.param.type=CWWKD1020E: Les param\u00e8tres de la m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} ne doivent pas \u00eatre du type {2} car la m\u00e9thode de d\u00e9p\u00f4t est une op\u00e9ration {3}.
CWWKD1020.invalid.param.type.explanation=Le type de param\u00e8tre n'est pas autoris\u00e9 pour ce type de m\u00e9thode.
CWWKD1020.invalid.param.type.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour d\u00e9finir un param\u00e8tre de m\u00e9thode pour chaque valeur requise par une comparaison.

CWWKD1021.insufficient.params=CWWKD1021E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} a {2} param\u00e8tres, mais les conditions d''interrogation d\u00e9finies par la m\u00e9thode n\u00e9cessitent {3} param\u00e8tres. La requ\u00eate pour la m\u00e9thode est : {4}.
CWWKD1021.insufficient.params.explanation=Les conditions d'interrogation qui d\u00e9finissent des comparaisons de valeurs requi\u00e8rent un nombre correspondant de param\u00e8tres de m\u00e9thode du r\u00e9f\u00e9rentiel pour fournir les valeurs.
CWWKD1021.insufficient.params.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour d\u00e9finir un param\u00e8tre de m\u00e9thode pour chaque valeur requise par une comparaison.

CWWKD1022.too.many.params=CWWKD1022E: Les conditions d''interrogation de la m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} n\u00e9cessitent {2} param\u00e8tres, mais la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel a {3} param\u00e8tres. La requ\u00eate pour la m\u00e9thode est : {4}.
CWWKD1022.too.many.params.explanation=Les conditions d'interrogation qui d\u00e9finissent des comparaisons de valeurs requi\u00e8rent un nombre correspondant de param\u00e8tres de m\u00e9thode du r\u00e9f\u00e9rentiel pour fournir les valeurs. Les param\u00e8tres suppl\u00e9mentaires ne sont pas autoris\u00e9s.
CWWKD1022.too.many.params.useraction=Mettre \u00e0 jour la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel pour supprimer les param\u00e8tres suppl\u00e9mentaires qui ne correspondent pas aux conditions d\u00e9clar\u00e9es.

CWWKD1023.extra.param=CWWKD1023E: Les conditions d''interrogation de la m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} requi\u00e8rent {2} param\u00e8tres, mais la m\u00e9thode du r\u00e9f\u00e9rentiel dispose d''un param\u00e8tre suppl\u00e9mentaire {3}. La requ\u00eate pour la m\u00e9thode est : {4}.
CWWKD1023.extra.param.explanation=Les conditions d'interrogation qui d\u00e9finissent des comparaisons de valeurs requi\u00e8rent un nombre correspondant de param\u00e8tres de m\u00e9thode du r\u00e9f\u00e9rentiel pour fournir les valeurs. Les param\u00e8tres suppl\u00e9mentaires ne sont pas autoris\u00e9s.
CWWKD1023.extra.param.useraction=Mettre \u00e0 jour la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel pour supprimer les param\u00e8tres suppl\u00e9mentaires qui ne correspondent pas aux conditions d\u00e9clar\u00e9es.

CWWKD1024.missing.entity.attr=CWWKD1024E: Il manque un nom d''attribut d''entit\u00e9 \u00e0 la m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} ou le param\u00e8tre fourni n''a pas de nom d''attribut d''entit\u00e9. Les noms d''attributs valables pour la classe d''entit\u00e9 {2} sont les suivants : {3}.
CWWKD1024.missing.entity.attr.explanation=Les conditions d'interrogation et les crit\u00e8res de tri d'une m\u00e9thode de d\u00e9p\u00f4t doivent inclure un nom d'attribut d'entit\u00e9.
CWWKD1024.missing.entity.attr.useraction=Inspectez la d\u00e9claration et l'utilisation de la m\u00e9thode du r\u00e9f\u00e9rentiel pour vous assurer qu'un nom d'attribut d'entit\u00e9 est fourni pour chaque condition de requ\u00eate et crit\u00e8re de tri.

CWWKD1025.missing.id.attr=CWWKD1025E: La classe d''entit\u00e9 {0} utilis\u00e9e par la m\u00e9thode {1} de l''interface de r\u00e9f\u00e9rentiel {2} n''a pas d''attribut ID.
CWWKD1025.missing.id.attr.explanation=Les m\u00e9thodes du r\u00e9f\u00e9rentiel qui suppriment et renvoient une entit\u00e9 doivent avoir un attribut ID.
CWWKD1025.missing.id.attr.useraction=Si l'entit\u00e9 n'a pas d'attribut unique pour l'identifiant, d\u00e9finissez des m\u00e9thodes de r\u00e9f\u00e9rentiel distinctes qui recherchent l'entit\u00e9 et la suppriment.

CWWKD1026.ignore.case.not.text=CWWKD1026E: L''attribut {0} de l''entit\u00e9 {1} n''est pas un caract\u00e8re ou une s\u00e9quence de caract\u00e8res ; par cons\u00e9quent, les crit\u00e8res de tri {2} ne doivent pas sp\u00e9cifier d''ignorer la casse. Le type de l''attribut est {3}, et il a \u00e9t\u00e9 fourni \u00e0 la m\u00e9thode {4} de l''interface du r\u00e9f\u00e9rentiel {5}.
CWWKD1026.ignore.case.not.text.explanation=Le tri sans tenir compte de la casse n'est possible qu'avec les attributs d'entit\u00e9 qui repr\u00e9sentent du texte.
CWWKD1026.ignore.case.not.text.useraction=S'assurer que les crit\u00e8res de tri sont appliqu\u00e9s \u00e0 l'attribut d'entit\u00e9 correct et supprimer l'instruction d'ignorer la casse si l'attribut d'entit\u00e9 ne repr\u00e9sente pas du texte.

CWWKD1027.datastore.lacks.java.comp=CWWKD1027E: Une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {0} ) de l''artefact d''application {1} sp\u00e9cifient une valeur {2} dataStore qui ne correspond pas \u00e0 une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou \u00e0 une r\u00e9f\u00e9rence d''unit\u00e9 de persistance parce qu''il manque un pr\u00e9fixe d''espace de noms java:comp/env/. Envisagez de modifier l''annotation Repository pour sp\u00e9cifier {3}.
CWWKD1027.datastore.lacks.java.comp.explanation=Les noms JNDI des r\u00e9f\u00e9rences de ressources de sources de donn\u00e9es et des r\u00e9f\u00e9rences d'unit\u00e9s de persistance doivent inclure un pr\u00e9fixe d'espace de noms java :.
CWWKD1027.datastore.lacks.java.comp.useraction=Veiller \u00e0 ce que la valeur du magasin de donn\u00e9es de l'annotation Repository comprenne un pr\u00e9fixe d'espace de noms java : lorsque la valeur indique le nom JNDI d'une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou d'une r\u00e9f\u00e9rence d'unit\u00e9 de persistance.

CWWKD1028.first.exceeds.max=CWWKD1028E: La m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} demande les premiers r\u00e9sultats {2}, ce qui d\u00e9passe le nombre maximum de r\u00e9sultats autoris\u00e9 : {3}.
CWWKD1028.first.exceeds.max.explanation=Le nombre maximum de r\u00e9sultats de la requ\u00eate est limit\u00e9 par les contraintes du syst\u00e8me et la valeur sp\u00e9cifi\u00e9e.
CWWKD1028.first.exceeds.max.useraction=R\u00e9duire le nombre maximal de r\u00e9sultats de la requ\u00eate \u00e0 une valeur inf\u00e9rieure.

CWWKD1029.first.neg.or.zero=CWWKD1029E: La m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} demande les premiers {2} r\u00e9sultats. Le nombre maximum de r\u00e9sultats \u00e0 renvoyer doit \u00eatre un nombre positif.
CWWKD1029.first.neg.or.zero.explanation=Le nombre maximum de r\u00e9sultats de la requ\u00eate doit \u00eatre un nombre positif.
CWWKD1029.first.neg.or.zero.useraction=Mise \u00e0 jour de la m\u00e9thode de d\u00e9p\u00f4t pour sp\u00e9cifier un nombre maximum positif de r\u00e9sultats.

CWWKD1030.ql.lacks.entity=CWWKD1030E: Le nom de l''entit\u00e9 est absent de la requ\u00eate {0} sp\u00e9cifi\u00e9e pour la m\u00e9thode {1} du r\u00e9f\u00e9rentiel {2}. Pour les requ\u00eates {3}, utilisez la forme : {4}.
CWWKD1030.ql.lacks.entity.explanation=La requ\u00eate contient une clause qui demande le nom de l'entit\u00e9.
CWWKD1030.ql.lacks.entity.useraction=Mise \u00e0 jour de la requ\u00eate pour la m\u00e9thode du r\u00e9f\u00e9rentiel afin d'inclure le nom de l'entit\u00e9.

CWWKD1031.ql.similar.entity=CWWKD1031E: La m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} sp\u00e9cifie une requ\u00eate qui n\u00e9cessite un nom d''entit\u00e9 {2} qui n''a pas \u00e9t\u00e9 trouv\u00e9 mais qui est proche du nom d''entit\u00e9 {3}. La requ\u00eate est la suivante : {4}.
CWWKD1031.ql.similar.entity.explanation=La requ\u00eate peut contenir une erreur typographique dans sa r\u00e9f\u00e9rence au nom de l'entit\u00e9.
CWWKD1031.ql.similar.entity.useraction=Examinez la requ\u00eate pour vous assurer que le nom de l'entit\u00e9 utilis\u00e9 est correct.

CWWKD1032.ql.unknown.entity=CWWKD1032E: La m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} sp\u00e9cifie une requ\u00eate qui requiert un nom d''entit\u00e9 {2} introuvable. Assurez-vous que {2} est le nom d''une entit\u00e9 valide. Pour permettre la recherche de l''entit\u00e9, donnez au r\u00e9f\u00e9rentiel une m\u00e9thode de cycle de vie qui est annot\u00e9e avec l''une des annotations {3} et fournissez l''entit\u00e9 en tant que param\u00e8tre. Le r\u00e9f\u00e9rentiel peut \u00e9galement \u00e9tendre l''interface DataRepository ou une autre interface de r\u00e9f\u00e9rentiel int\u00e9gr\u00e9e, avec la classe d''entit\u00e9 comme premi\u00e8re variable de type. La requ\u00eate est la suivante : {4}.
CWWKD1032.ql.unknown.entity.explanation=La requ\u00eate peut contenir une erreur typographique dans sa r\u00e9f\u00e9rence au nom de l'entit\u00e9, ou le r\u00e9f\u00e9rentiel ne sp\u00e9cifie pas sa classe d'entit\u00e9 primaire.
CWWKD1032.ql.unknown.entity.useraction=Examinez la requ\u00eate pour vous assurer que le nom de l'entit\u00e9 utilis\u00e9 est correct. Examinez la d\u00e9finition du r\u00e9f\u00e9rentiel pour vous assurer que la classe d'entit\u00e9 primaire correcte est sp\u00e9cifi\u00e9e.

CWWKD1033.ql.orderby.disallowed=CWWKD1033E: La m\u00e9thode {0} de l''interface de r\u00e9f\u00e9rentiel {1} ne peut pas sp\u00e9cifier une requ\u00eate qui inclut une clause ORDER BY car la m\u00e9thode renvoie {2}. Supprimez la clause ORDER BY et utilisez plut\u00f4t l''annotation {3} pour sp\u00e9cifier des crit\u00e8res de tri statiques. La requ\u00eate est la suivante : {4}.
CWWKD1033.ql.orderby.disallowed.explanation=La clause ORDER BY est incompatible avec la pagination bas\u00e9e sur le curseur.
CWWKD1033.ql.orderby.disallowed.useraction=Remplacer la clause ORDER BY par des annotations sp\u00e9cifiant les crit\u00e8res de tri.

CWWKD1034.ql.req.end.in.where=CWWKD1034E: La requ\u00eate sp\u00e9cifi\u00e9e par la m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} doit se terminer par une clause WHERE car la m\u00e9thode renvoie {2}. La clause WHERE se termine \u00e0 la position {3}, mais la longueur de la requ\u00eate est {4}. La requ\u00eate est la suivante : {5}.
CWWKD1034.ql.req.end.in.where.explanation=Une clause WHERE est n\u00e9cessaire lors de l'utilisation de la pagination bas\u00e9e sur le curseur.
CWWKD1034.ql.req.end.in.where.useraction=Ajoutez une clause WHERE \u00e0 la requ\u00eate.

CWWKD1035.incompat.page.mode=CWWKD1035E: Une demande de page avec le mode de pagination {0} ne doit pas \u00eatre fournie \u00e0 la m\u00e9thode {1} de l''interface du r\u00e9f\u00e9rentiel {2} car la m\u00e9thode renvoie {3} au lieu de {4}.
CWWKD1035.incompat.page.mode.explanation=Le mode de pagination demand\u00e9 n'est pas compatible avec le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1035.incompat.page.mode.useraction=Utilisez un type de retour Page pour le mode de pagination OFFSET et un type de retour CursoredPage pour les modes de pagination CURSOR_NEXT et CURSOR_PREVIOUS.

CWWKD1036.cursor.size.mismatch=CWWKD1036E: Un curseur de {0} \u00e9l\u00e9ments fourni \u00e0 la m\u00e9thode {1} de l''interface du r\u00e9f\u00e9rentiel {2} ne peut pas \u00eatre utilis\u00e9 avec des crit\u00e8res de tri de taille {3} car le nombre et l''ordre des \u00e9l\u00e9ments du curseur doivent correspondre aux crit\u00e8res de tri. Le curseur est compos\u00e9 de : {4}. Les crit\u00e8res de tri sont : {5}.
CWWKD1036.cursor.size.mismatch.explanation=Le nombre d'\u00e9l\u00e9ments du curseur doit correspondre \u00e0 la taille des crit\u00e8res de tri combin\u00e9s de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1036.cursor.size.mismatch.useraction=Corrigez les \u00e9l\u00e9ments du curseur ou les crit\u00e8res de tri pour qu'ils aient tous deux la m\u00eame taille.

CWWKD1037.cursor.rtrn.mismatch=CWWKD1037E: Impossible d''obtenir un curseur \u00e0 partir du r\u00e9sultat {0} de la m\u00e9thode {1} de l''interface de d\u00e9p\u00f4t {2}. Les requ\u00eates qui utilisent la pagination bas\u00e9e sur le curseur doivent renvoyer des r\u00e9sultats du m\u00eame type que le type d''entit\u00e9, qui est {3}. Le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel est {4}.
CWWKD1037.cursor.rtrn.mismatch.explanation=La pagination par curseur n'est possible que lorsque la m\u00e9thode du r\u00e9f\u00e9rentiel renvoie le type d'entit\u00e9.
CWWKD1037.cursor.rtrn.mismatch.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour qu'elle renvoie le type d'entit\u00e9.

CWWKD1038.no.prev.offset.page=CWWKD1038E: Un num\u00e9ro de page ant\u00e9rieur \u00e0 {0} ne peut \u00eatre demand\u00e9 pour la m\u00e9thode {1} de l''interface de d\u00e9p\u00f4t {2} car la m\u00e9thode Page.hasPrevious renvoie un message faux, indiquant qu''il n''y a pas de page pr\u00e9c\u00e9dente.
CWWKD1038.no.prev.offset.page.explanation=La pagination offset n'autorise pas les num\u00e9ros de page inf\u00e9rieurs \u00e0 1.
CWWKD1038.no.prev.offset.page.useraction=Assurez-vous que le num\u00e9ro de page demand\u00e9 est un nombre positif et utilisez la m\u00e9thode Page.hasPrevious pour vous assurer qu'il est valide de demander la page pr\u00e9c\u00e9dente.

CWWKD1039.no.prev.cursor.page=CWWKD1039E: Une page pr\u00e9c\u00e9dente ne peut pas \u00eatre demand\u00e9e pour la m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} car la m\u00e9thode Page.hasPrevious renvoie un message faux, indiquant qu''il n''y a pas de page pr\u00e9c\u00e9dente.
CWWKD1039.no.prev.cursor.page.explanation=La pagination bas\u00e9e sur le curseur ne permet pas de demander une page pr\u00e9c\u00e9dente lorsque l'on sait que la page actuelle contient les r\u00e9sultats du d\u00e9but de l'ensemble de donn\u00e9es.
CWWKD1039.no.prev.cursor.page.useraction=Utilisez la m\u00e9thode Page.hasPrevious pour vous assurer qu'il est possible de demander la page pr\u00e9c\u00e9dente.

CWWKD1040.no.next.page=CWWKD1040E: Une page suivante ne peut pas \u00eatre demand\u00e9e pour la m\u00e9thode {0} de l''interface de d\u00e9p\u00f4t {1} car {2} renvoie un message faux, indiquant qu''il n''y a pas de page suivante.
CWWKD1040.no.next.page.explanation=Il n'est pas possible de demander une page suivante lorsque l'on sait que la page actuelle contient la fin de l'ensemble de donn\u00e9es.
CWWKD1040.no.next.page.useraction=Utilisez la m\u00e9thode hasNext pour vous assurer qu'il est possible de demander la page suivante.

CWWKD1041.rtrn.mismatch.pagereq=CWWKD1041E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} a un type de retour {2} mais il manque un param\u00e8tre de type PageRequest \u00e0 la suite des param\u00e8tres des conditions de la requ\u00eate.
CWWKD1041.rtrn.mismatch.pagereq.explanation=Les m\u00e9thodes du r\u00e9f\u00e9rentiel avec les types de retour Page et CursoredPage doivent avoir un param\u00e8tre PageRequest.
CWWKD1041.rtrn.mismatch.pagereq.useraction=Ajouter un param\u00e8tre PageRequest \u00e0 la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel.

CWWKD1042.no.totals=CWWKD1042E: Les pages r\u00e9cup\u00e9r\u00e9es par la m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} n''incluent pas le nombre total d''\u00e9l\u00e9ments et de pages parce que la demande de page {2} sp\u00e9cifie la valeur false pour requestTotal. Pour demander une page avec le d\u00e9compte total, utilisez la m\u00e9thode PageRequest.withTotal au lieu de la m\u00e9thode PageRequest.withoutTotal.
CWWKD1042.no.totals.explanation=La m\u00e9thode PageRequest.withoutTotal sp\u00e9cifie que les pages demand\u00e9es n'incluent pas le nombre total d'\u00e9l\u00e9ments et de pages.
CWWKD1042.no.totals.useraction=Utilisez la m\u00e9thode PageRequest.withTotal pour demander le nombre total d'\u00e9l\u00e9ments et de pages.

CWWKD1043.offset.exceeds.max=CWWKD1043E: Le d\u00e9calage {0} n\u00e9cessaire pour la demande de page {1} fournie \u00e0 la m\u00e9thode {2} de l''interface du r\u00e9f\u00e9rentiel {3} d\u00e9passe la valeur maximale autoris\u00e9e de {4}.
CWWKD1043.offset.exceeds.max.explanation=La combinaison du num\u00e9ro de page et de la taille maximale de la page est trop importante.
CWWKD1043.offset.exceeds.max.useraction=Ajouter des restrictions \u00e0 la requ\u00eate pour r\u00e9duire le nombre de r\u00e9sultats correspondants.

CWWKD1044.invalid.resource.type=CWWKD1044E: La m\u00e9thode d''acc\u00e8s \u00e0 la ressource {0} du r\u00e9f\u00e9rentiel {1} ne peut pas renvoyer une ressource {2}. Les types de retour pris en charge pour les m\u00e9thodes d''acc\u00e8s aux ressources sont les suivants : {3}.
CWWKD1044.invalid.resource.type.explanation=Le type de retour de la m\u00e9thode d'acc\u00e8s \u00e0 la ressource ne fait pas partie des types pris en charge par Jakarta Data.
CWWKD1044.invalid.resource.type.useraction=Supprimez la m\u00e9thode ou mettez-la \u00e0 jour pour qu'elle renvoie l'un des types pris en charge.

CWWKD1045.unknown.entity.anno=CWWKD1045E: Le fournisseur int\u00e9gr\u00e9 de Jakarta Data ne peut pas fournir une impl\u00e9mentation de l''interface de d\u00e9p\u00f4t {0} parce que la classe d''entit\u00e9 {1} utilis\u00e9e par le d\u00e9p\u00f4t comprend une annotation d''entit\u00e9 non reconnue. Les annotations d''entit\u00e9 suivantes se trouvent sur la classe d''entit\u00e9 : {2}. Les annotations d''entit\u00e9 prises en charge sont les suivantes : {3}.
CWWKD1045.unknown.entity.anno.explanation=Le fournisseur de donn\u00e9es Jakarta int\u00e9gr\u00e9 ne prend pas en charge l'une des annotations d'entit\u00e9.
CWWKD1045.unknown.entity.anno.useraction=Supprimez l'annotation d'entit\u00e9 non reconnue ou utilisez l'attribut provider de l'annotation Repository pour s\u00e9lectionner un fournisseur Jakarta Data qui reconna\u00eet l'annotation d'entit\u00e9.

CWWKD1046.result.convert.err=CWWKD1046E: Le r\u00e9sultat {0} de la m\u00e9thode {1} de l''interface {2} du r\u00e9f\u00e9rentiel ne peut pas \u00eatre converti dans le type de retour {3} de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1046.result.convert.err.explanation=La valeur du r\u00e9sultat n'est pas compatible avec le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1046.result.convert.err.useraction=Assurez-vous que le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel est coh\u00e9rent avec le type de r\u00e9sultat renvoy\u00e9 par la requ\u00eate.

CWWKD1047.result.out.of.range=CWWKD1047E: Le r\u00e9sultat {0} de la m\u00e9thode {1} de l''interface {2} du r\u00e9f\u00e9rentiel ne peut pas \u00eatre converti dans le type de retour {3} de la m\u00e9thode du r\u00e9f\u00e9rentiel car le r\u00e9sultat n''est pas compris entre {4} et {5}.
CWWKD1047.result.out.of.range.explanation=La valeur du r\u00e9sultat n'est pas compatible avec le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel car elle se situe en dehors de la plage de valeurs pouvant \u00eatre converties.
CWWKD1047.result.out.of.range.useraction=Ajustez le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel pour permettre le retour de la valeur.

CWWKD1048.result.exceeds.max=CWWKD1048E: Le r\u00e9sultat {0} de la m\u00e9thode {1} de l''interface {2} du r\u00e9f\u00e9rentiel ne peut pas \u00eatre converti dans le type de retour {3} de la m\u00e9thode du r\u00e9f\u00e9rentiel car la valeur du r\u00e9sultat d\u00e9passe la valeur maximale de {4}.
CWWKD1048.result.exceeds.max.explanation=La valeur du r\u00e9sultat n'est pas compatible avec le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel car elle d\u00e9passe la valeur maximale qui peut \u00eatre convertie dans ce type.
CWWKD1048.result.exceeds.max.useraction=Ajustez le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel pour permettre le retour de la valeur.

CWWKD1049.count.convert.err=CWWKD1049E: La valeur de comptage {0} de la m\u00e9thode {1} de l''interface {2} du r\u00e9f\u00e9rentiel ne peut pas \u00eatre convertie dans le type de retour {3} de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1049.count.convert.err.explanation=La valeur de comptage n'est pas compatible avec le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1049.count.convert.err.useraction=Ajustez le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel pour permettre le retour de la valeur.

CWWKD1050.opt.lock.exc=CWWKD1050E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} n''a pas trouv\u00e9 d''entit\u00e9 {2} correspondant aux attributs de l''entit\u00e9 : {3}. V\u00e9rifier que l''instance d''entit\u00e9 fournie \u00e0 la m\u00e9thode {0} est bas\u00e9e sur la version la plus r\u00e9cente de l''entit\u00e9. La version la plus r\u00e9cente de l''entit\u00e9 peut \u00eatre obtenue \u00e0 partir d''une m\u00e9thode de recherche ou de la valeur de r\u00e9sultat de l''une des m\u00e9thodes de cycle de vie suivantes : {4}.
CWWKD1050.opt.lock.exc.explanation=Aucune entit\u00e9 correspondante n'a \u00e9t\u00e9 trouv\u00e9e.
CWWKD1050.opt.lock.exc.useraction=Si l'on s'attend \u00e0 ce que l'entit\u00e9 ne soit pas trouv\u00e9e dans la base de donn\u00e9es, aucune action n'est n\u00e9cessaire. Dans le cas contraire, il faut s'assurer que la version la plus r\u00e9cente de l'entit\u00e9 est utilis\u00e9e.

CWWKD1051.single.opt.lock.exc=CWWKD1051E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} n''a pas trouv\u00e9 d''entit\u00e9 {2} correspondante dans la base de donn\u00e9es. V\u00e9rifier que l''instance d''entit\u00e9 fournie \u00e0 la m\u00e9thode {0} est bas\u00e9e sur la version la plus r\u00e9cente de l''entit\u00e9. La version la plus r\u00e9cente de l''entit\u00e9 peut \u00eatre obtenue \u00e0 partir d''une m\u00e9thode de recherche ou de la valeur de r\u00e9sultat de l''une des m\u00e9thodes de cycle de vie suivantes : {3}.
CWWKD1051.single.opt.lock.exc.explanation=Aucune entit\u00e9 correspondante n'a \u00e9t\u00e9 trouv\u00e9e.
CWWKD1051.single.opt.lock.exc.useraction=Si l'on s'attend \u00e0 ce que l'entit\u00e9 ne soit pas trouv\u00e9e dans la base de donn\u00e9es, aucune action n'est n\u00e9cessaire. Dans le cas contraire, il faut s'assurer que la version la plus r\u00e9cente de l'entit\u00e9 est utilis\u00e9e.

CWWKD1052.multi.opt.lock.exc=CWWKD1052E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} n''a pas trouv\u00e9 {2} des entit\u00e9s {3} {4} dans la base de donn\u00e9es. V\u00e9rifier que les instances d''entit\u00e9s fournies \u00e0 la m\u00e9thode {0} sont bas\u00e9es sur la version la plus r\u00e9cente de chaque entit\u00e9. La version la plus r\u00e9cente d''une entit\u00e9 peut \u00eatre obtenue \u00e0 partir d''une m\u00e9thode de recherche ou de la valeur de r\u00e9sultat de l''une des m\u00e9thodes de cycle de vie suivantes : {5}.
CWWKD1052.multi.opt.lock.exc.explanation=Une ou plusieurs entit\u00e9s n'ont pas \u00e9t\u00e9 trouv\u00e9es dans la base de donn\u00e9es.
CWWKD1052.multi.opt.lock.exc.useraction=Si l'on s'attend \u00e0 ce qu'une entit\u00e9 ne soit pas trouv\u00e9e dans la base de donn\u00e9es, aucune action n'est n\u00e9cessaire. Dans le cas contraire, il convient de s'assurer que la version la plus r\u00e9cente de chaque entit\u00e9 est utilis\u00e9e.

CWWKD1053.empty.result=CWWKD1053E: Le type de retour {0} de la m\u00e9thode {1} de l''interface du r\u00e9f\u00e9rentiel {2} ne peut pas renvoyer un r\u00e9sultat vide. Si un r\u00e9sultat vide est attendu, la m\u00e9thode de d\u00e9p\u00f4t doit renvoyer un tableau ou l''un des types de retour suivants : {3}.
CWWKD1053.empty.result.explanation=Le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel ne lui permet pas de renvoyer un r\u00e9sultat vide.
CWWKD1053.empty.result.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour utiliser l'un des types de retour pouvant repr\u00e9senter un r\u00e9sultat vide.

CWWKD1054.non.unique.result=CWWKD1054E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} a le type de retour {2}, qui n''est pas capable de renvoyer des r\u00e9sultats {3}. Pour se limiter \u00e0 un seul r\u00e9sultat, utilisez l''un des mod\u00e8les de donn\u00e9es Jakarta suivants : {4}.
CWWKD1054.non.unique.result.explanation=Le type de retour de la m\u00e9thode du r\u00e9f\u00e9rentiel ne permet pas de renvoyer plusieurs r\u00e9sultats.
CWWKD1054.non.unique.result.useraction=Mettez \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour utiliser un type de retour prenant en charge plusieurs r\u00e9sultats ou mettez \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour qu'elle ne renvoie qu'un seul r\u00e9sultat.

CWWKD1055.unsupported.entity.attr=CWWKD1055E: L''attribut {0} de l''entit\u00e9 {1} a un type non pris en charge : {2}. Jakarta Data prend en charge les types d''\u00e9num\u00e9ration Java, les types temporels {3} et les types de base suivants : {4}. Le fournisseur de donn\u00e9es Jakarta int\u00e9gr\u00e9 prend \u00e9galement en charge certains types de persistance Jakarta, tels que les donn\u00e9es int\u00e9grables. Par ailleurs, si vous utilisez une entit\u00e9 Jakarta Persistence, vous pouvez ajouter l''annotation {5} \u00e0 l''attribut {0} pour fournir une impl\u00e9mentation AttributeConverter qui convertit un type non pris en charge en un type pris en charge.
CWWKD1055.unsupported.entity.attr.explanation=Jakarta Data ne prend pas en charge le type utilis\u00e9 par l'attribut de l'entit\u00e9.
CWWKD1055.unsupported.entity.attr.useraction=Mettre \u00e0 jour l'attribut de l'entit\u00e9 pour utiliser l'un des types pris en charge.

CWWKD1056.unsupported.keyword=CWWKD1056E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} a un nom qui inclut un mot-cl\u00e9 {2}, qui n''est pas un mot-cl\u00e9 pris en charge par le mod\u00e8le Jakarta Data Query by Method Name.
CWWKD1056.unsupported.keyword.explanation=Le nom de la m\u00e9thode comprend un mot-cl\u00e9 qui n'est pas reconnu comme faisant partie du mod\u00e8le de requ\u00eate Jakarta Data Query by Method Name pris en charge.
CWWKD1056.unsupported.keyword.useraction=Renommer la m\u00e9thode du r\u00e9f\u00e9rentiel pour supprimer le mot-cl\u00e9 non pris en charge.

CWWKD1057.no.args.constr.inacc=CWWKD1057E: Le type de retour {0} de la m\u00e9thode {1} de l''interface de r\u00e9f\u00e9rentiel {2} n''est pas valide pour une m\u00e9thode de r\u00e9f\u00e9rentiel car la classe {3} ne dispose pas d''un constructeur public sans param\u00e8tres.
CWWKD1057.no.args.constr.inacc.explanation=Un constructeur public sans param\u00e8tres est n\u00e9cessaire pour convertir le r\u00e9sultat dans la classe sp\u00e9cifi\u00e9e.
CWWKD1057.no.args.constr.inacc.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour qu'elle ait un type de retour support\u00e9 par Jakarta Data ou pour qu'elle soit une sous-classe de Iterable avec un constructeur public qui n'a pas de param\u00e8tres.

CWWKD1058.no.args.constr.err=CWWKD1058E: Le type de retour {0} de la m\u00e9thode {1} de l''interface de d\u00e9p\u00f4t {2} n''est pas valide pour une m\u00e9thode de d\u00e9p\u00f4t parce que le constructeur de la classe {3} a soulev\u00e9 une erreur : {4}.
CWWKD1058.no.args.constr.err.explanation=Le constructeur public sans param\u00e8tres a \u00e9chou\u00e9 en raison d'une erreur.
CWWKD1058.no.args.constr.err.useraction=Corrigez l'erreur dans le constructeur ou mettez \u00e0 jour la m\u00e9thode de d\u00e9p\u00f4t pour utiliser un type de retour diff\u00e9rent.

CWWKD1059.attr.cast.err=CWWKD1059E: La m\u00e9thode {0} de l''interface de r\u00e9f\u00e9rentiel {1} ne peut pas acc\u00e9der \u00e0 l''attribut {2} de l''entit\u00e9 {3} car le champ ou la m\u00e9thode {4} de la classe {5} est incompatible avec une valeur {6}.
CWWKD1059.attr.cast.err.explanation=Un attribut de l'entit\u00e9 ou un attribut connexe de sa hi\u00e9rarchie n'est pas compatible avec le type attendu.
CWWKD1059.attr.cast.err.useraction=Examinez le mod\u00e8le d'entit\u00e9 et v\u00e9rifiez que les types corrects sont utilis\u00e9s pour chaque attribut.

CWWKD1060.name.out.of.scope=CWWKD1060E: L''interface de r\u00e9f\u00e9rentiel {0} dans l''application {1} configure une valeur {2} pour l''attribut {3}, mais les noms {3} ne sont pas accessibles \u00e0 l''artefact qui fournit l''interface de r\u00e9f\u00e9rentiel. Utilisez plut\u00f4t un nom {4}.
CWWKD1060.name.out.of.scope.explanation=L'espace de noms sp\u00e9cifi\u00e9 n'est pas accessible \u00e0 partir de l'artefact o\u00f9 l'interface du r\u00e9f\u00e9rentiel est d\u00e9finie.
CWWKD1060.name.out.of.scope.useraction=Mettre \u00e0 jour l'annotation Repository pour sp\u00e9cifier un nom de magasin de donn\u00e9es visible par le module ou la biblioth\u00e8que fournissant l'interface du r\u00e9f\u00e9rentiel.

CWWKD1061.comp.name.in.ejb=CWWKD1061E: Une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {0} ) d\u00e9finies dans le module de haricot d''entreprise {1} de l''application {2} configurent une valeur {3} pour l''attribut {4}. Cependant, les noms {5} ne sont pas accessibles aux modules de haricots d''entreprise. Utilisez un nom appartenant \u00e0 l''un des espaces de noms suivants : {6}.
CWWKD1061.comp.name.in.ejb.explanation=L'espace de noms sp\u00e9cifi\u00e9 n'est pas accessible au module de l'enterprise bean dans lequel l'interface du r\u00e9f\u00e9rentiel est d\u00e9finie.
CWWKD1061.comp.name.in.ejb.useraction=Mettre \u00e0 jour l'annotation Repository pour sp\u00e9cifier un nom de magasin de donn\u00e9es visible par le module de l'enterprise bean qui fournit l'interface du repository.

CWWKD1062.resource.not.found=CWWKD1062E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} ne parvient pas \u00e0 localiser la ressource {2} avec le filtre {3}.
CWWKD1062.resource.not.found.explanation=La ressource est introuvable.
CWWKD1062.resource.not.found.useraction=Assurez-vous que la ressource sp\u00e9cifi\u00e9e et toutes les autres ressources dont elle d\u00e9pend existent et sont correctement configur\u00e9es.

CWWKD1063.unsupported.resource=CWWKD1063E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} ne peut pas obtenir une ressource {2} car le fournisseur de Jakarta Persistence ne prend pas en charge l''op\u00e9ration de d\u00e9ballage renvoyant une instance {3}.
CWWKD1063.unsupported.resource.explanation=Le fournisseur Jakarta Persistence ne prend pas en charge l'op\u00e9ration de d\u00e9ballage renvoyant le type de ressource sp\u00e9cifi\u00e9.
CWWKD1063.unsupported.resource.useraction=Supprime la m\u00e9thode d'acc\u00e8s aux ressources non prise en charge de l'interface du r\u00e9f\u00e9rentiel.

CWWKD1064.datastore.error=CWWKD1064E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} ne peut pas obtenir le magasin de donn\u00e9es {2} pour le r\u00e9f\u00e9rentiel en raison de l''erreur suivante : {3}.
CWWKD1064.datastore.error.explanation=Une erreur s'est produite lors de la tentative d'obtention du magasin de donn\u00e9es.
CWWKD1064.datastore.error.useraction=Assurez-vous que le magasin de donn\u00e9es sp\u00e9cifi\u00e9 et toutes les autres ressources dont il d\u00e9pend existent et sont correctement configur\u00e9s.

CWWKD1065.ddlgen.timeout=CWWKD1065E: La g\u00e9n\u00e9ration DDL pour une ou plusieurs interfaces de r\u00e9f\u00e9rentiel{0}) a \u00e9chou\u00e9 parce que le magasin de donn\u00e9es {1} n''a pas termin\u00e9 la g\u00e9n\u00e9ration DDL dans un d\u00e9lai de {2} secondes pour les entit\u00e9s suivantes : {3}.
CWWKD1065.ddlgen.timeout.explanation=La tentative de g\u00e9n\u00e9ration de DDL a d\u00e9pass\u00e9 le temps imparti et n'a pas abouti.
CWWKD1065.ddlgen.timeout.useraction=R\u00e9essayer la g\u00e9n\u00e9ration DDL lorsque le syst\u00e8me et la base de donn\u00e9es ne sont pas sollicit\u00e9s.

CWWKD1066.ddlgen.failed=CWWKD1066E: La g\u00e9n\u00e9ration DDL pour une ou plusieurs interfaces de r\u00e9f\u00e9rentiel{0}) qui utilisent le magasin de donn\u00e9es {1} a rencontr\u00e9 une erreur lors de la g\u00e9n\u00e9ration DDL pour les entit\u00e9s suivantes : {2}. L''erreur est la suivante : {3}.
CWWKD1066.ddlgen.failed.explanation=La tentative de g\u00e9n\u00e9ration de DDL a \u00e9chou\u00e9 et ne s'est pas termin\u00e9e.
CWWKD1066.ddlgen.failed.useraction=Examinez l'erreur et apportez des corrections \u00e0 l'interface du r\u00e9f\u00e9rentiel, aux entit\u00e9s, \u00e0 la configuration du magasin de donn\u00e9es ou \u00e0 la base de donn\u00e9es.

CWWKD1067.ddlgen.emf.timeout=CWWKD1067E: La g\u00e9n\u00e9ration DDL pour une ou plusieurs interfaces de r\u00e9f\u00e9rentiel{0}) a \u00e9chou\u00e9 parce que le magasin de donn\u00e9es {1} n''\u00e9tait pas disponible ou n''\u00e9tait pas en mesure de rendre les entit\u00e9s suivantes disponibles dans un d\u00e9lai de {2} secondes : {3}.
CWWKD1067.ddlgen.emf.timeout.explanation=L'acquisition des ressources n\u00e9cessaires \u00e0 la g\u00e9n\u00e9ration des DDL a pris du retard et n'a pas abouti.
CWWKD1067.ddlgen.emf.timeout.useraction=R\u00e9essayer la g\u00e9n\u00e9ration DDL lorsque le syst\u00e8me et la base de donn\u00e9es ne sont pas sollicit\u00e9s.

CWWKD1068.entity.name.conflict=CWWKD1068E: L''interface du r\u00e9f\u00e9rentiel {0} comporte plusieurs entit\u00e9s nomm\u00e9es {1} qui sont fournies par diff\u00e9rentes classes : {2}. Utilisez les annotations d''entit\u00e9 Jakarta Persistence suivantes pour attribuer un nom d''entit\u00e9 et un nom de table uniques \u00e0 chaque classe d''entit\u00e9 : {3}.
CWWKD1068.entity.name.conflict.explanation=Les noms des entit\u00e9s et des tables sont d\u00e9duits du nom de la classe non qualifi\u00e9e ou attribu\u00e9s par les annotations Jakarta Persistence.
CWWKD1068.entity.name.conflict.useraction=Renommez les entit\u00e9s ou ajoutez des annotations Jakarta Persistence pour r\u00e9soudre explicitement le conflit de noms.

CWWKD1069.record.entity.name.conflict=CWWKD1069E: L''interface du r\u00e9f\u00e9rentiel {0} comporte plusieurs entit\u00e9s nomm\u00e9es {1} qui sont fournies par diff\u00e9rentes classes : {2}. Lorsque des enregistrements Java sont utilis\u00e9s comme entit\u00e9s, il doit \u00e9galement \u00eatre possible d''ajouter un suffixe "Entit\u00e9" au nom de l''entit\u00e9 sans qu''il en r\u00e9sulte un conflit de nom. Par exemple : {2}.
CWWKD1069.record.entity.name.conflict.explanation=Les noms des entit\u00e9s et des tables sont d\u00e9duits du nom de la classe non qualifi\u00e9e ou attribu\u00e9s par les annotations Jakarta Persistence.
CWWKD1069.record.entity.name.conflict.useraction=Renommez les entit\u00e9s ou passez aux entit\u00e9s Jakarta Persistence pour r\u00e9soudre le conflit de noms.

CWWKD1070.record.convert.err=CWWKD1070E: L''enregistrement {0} fourni \u00e0 la m\u00e9thode {1} de l''interface du r\u00e9f\u00e9rentiel {2} ne peut pas \u00eatre utilis\u00e9 comme entit\u00e9 en raison de l''erreur suivante : {3}.
CWWKD1070.record.convert.err.explanation=Il n'est pas possible d'utiliser l'enregistrement Java comme une entit\u00e9.
CWWKD1070.record.convert.err.useraction=D\u00e9finir l'entit\u00e9 comme une entit\u00e9 Jakarta Persistence au lieu d'utiliser une entit\u00e9 Java record.

CWWKD1071.record.with.type.var=CWWKD1071E: L''enregistrement {0} est utilis\u00e9 comme une entit\u00e9 par une ou plusieurs interfaces du r\u00e9f\u00e9rentiel{1}) dans l''artefact d''application {2}, mais l''enregistrement ne peut pas \u00eatre une entit\u00e9 parce qu''il a une ou plusieurs variables de type : {3}.
CWWKD1071.record.with.type.var.explanation=Les classes d'entit\u00e9s ne peuvent pas avoir de variables de type g\u00e9n\u00e9rique.
CWWKD1071.record.with.type.var.useraction=Supprimer les variables de type de l'enregistrement.

CWWKD1072.record.comp.conflict=CWWKD1072E: L''enregistrement {0} est utilis\u00e9 en tant qu''entit\u00e9 par une ou plusieurs interfaces du r\u00e9f\u00e9rentiel ( {1} ) dans l''artefact d''application {2}, mais l''enregistrement ne peut pas \u00eatre une entit\u00e9 parce que ses composants {3} et {4} r\u00e9solvent tous deux le m\u00eame nom d''attribut d''entit\u00e9.
CWWKD1072.record.comp.conflict.explanation=Les noms d'attributs d'entit\u00e9s doivent \u00eatre uniques, sans tenir compte de la casse.
CWWKD1072.record.comp.conflict.useraction=Renommez l'un des composants de l'enregistrement pour \u00e9viter le conflit.

CWWKD1073.offset.exceeds.max=CWWKD1073E: Le point de d\u00e9part {0} de la limite {1} fournie \u00e0 la m\u00e9thode {2} de l''interface du r\u00e9f\u00e9rentiel {3} d\u00e9passe la valeur maximale autoris\u00e9e de {4}.
CWWKD1073.offset.exceeds.max.explanation=Le point de d\u00e9part de la limite est trop \u00e9lev\u00e9.
CWWKD1073.offset.exceeds.max.useraction=Ajouter des restrictions \u00e0 la requ\u00eate pour r\u00e9duire le nombre de r\u00e9sultats correspondants.

CWWKD1074.qbmn.incompat.keywords=CWWKD1074E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} ne doit pas combiner le mot-cl\u00e9 {2} avec le mot-cl\u00e9 {3} dans la m\u00eame condition d''interrogation par nom de m\u00e9thode.
CWWKD1074.qbmn.incompat.keywords.explanation=Les mots-cl\u00e9s Requ\u00eate par nom de m\u00e9thode sp\u00e9cifi\u00e9s ne sont pas compatibles entre eux.
CWWKD1074.qbmn.incompat.keywords.useraction=Renommer la m\u00e9thode pour ne pas combiner les mots-cl\u00e9s sur la m\u00eame condition.

CWWKD1075.entity.attr.conflict=CWWKD1075E: L''entit\u00e9 {0} ne peut pas avoir un attribut nomm\u00e9 {1} et un attribut nomm\u00e9 {2} car la sp\u00e9cification de Jakarta Data consid\u00e8re que ces noms sont des alias pour le m\u00eame attribut d''entit\u00e9.
CWWKD1075.entity.attr.conflict.explanation=Il y a une collision entre les noms de deux attributs d'entit\u00e9 en raison du caract\u00e8re de soulignement.
CWWKD1075.entity.attr.conflict.useraction=Ne pas utiliser le caract\u00e8re de soulignement dans les noms d'attributs d'entit\u00e9s.

CWWKD1076.repo.disposed=CWWKD1076E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} ne peut pas \u00eatre invoqu\u00e9e car l''application qui d\u00e9finit le r\u00e9f\u00e9rentiel s''est arr\u00eat\u00e9e. L''instance du r\u00e9f\u00e9rentiel est {2}.
CWWKD1076.repo.disposed.explanation=Les m\u00e9thodes du r\u00e9f\u00e9rentiel ne doivent pas \u00eatre utilis\u00e9es en dehors du cycle de vie de l'application qui d\u00e9finit le r\u00e9f\u00e9rentiel.
CWWKD1076.repo.disposed.useraction=Veiller \u00e0 ce que la m\u00e9thode du r\u00e9f\u00e9rentiel ne soit pas utilis\u00e9e en dehors du champ d'application de l'application qui d\u00e9finit le r\u00e9f\u00e9rentiel.

CWWKD1077.defaultds.not.found=CWWKD1077E: L''artefact d''application {0} poss\u00e8de une ou plusieurs interfaces de r\u00e9f\u00e9rentiel{1}) qui utilisent ou utilisent par d\u00e9faut le magasin de donn\u00e9es {2}. Ce magasin de donn\u00e9es doit \u00eatre configur\u00e9 dans la configuration du serveur en d\u00e9finissant un \u00e9l\u00e9ment dataSource dont l''identifiant est DefaultDataSource. Par exemple, {3} Il est \u00e9galement possible d''attribuer \u00e0 la valeur dataStore de l''annotation Repository l''identifiant d''un \u00e9l\u00e9ment databaseStore ou le nom JNDI d''une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou d''une r\u00e9f\u00e9rence d''unit\u00e9 de persistance accessible \u00e0 l''artefact d''application. Un \u00e9l\u00e9ment databaseStore peut \u00eatre d\u00e9fini dans la configuration du serveur. Par exemple, {4} Un composant d''application peut utiliser l''annotation Resource pour d\u00e9finir une r\u00e9f\u00e9rence de ressource de source de donn\u00e9\
    es. Par exemple, {5}, qui exige que la configuration du serveur ait un \u00e9l\u00e9ment de configuration dataSource avec un attribut {6}. Un composant d''application peut utiliser l''annotation PersistenceUnit pour d\u00e9finir une r\u00e9f\u00e9rence d''unit\u00e9 de persistance. Par exemple, {7}, qui exige que le fichier persistence.xml contienne un \u00e9l\u00e9ment persistence-unit avec un attribut name correspondant. Par exemple, {8}
CWWKD1077.defaultds.not.found.explanation=Les r\u00e9f\u00e9rentiels Jakarta Data utilisent par d\u00e9faut la source de donn\u00e9es par d\u00e9faut de Jakarta EE, qui doit \u00eatre configur\u00e9e dans la configuration du serveur.
CWWKD1077.defaultds.not.found.useraction=Configurez la source de donn\u00e9es par d\u00e9faut de Jakarta EE ou sp\u00e9cifiez un magasin de donn\u00e9es diff\u00e9rent pour le r\u00e9f\u00e9rentiel.

CWWKD1078.datastore.not.found=CWWKD1078E: Une ou plusieurs interfaces de r\u00e9f\u00e9rentiel{0}) de l''artefact d''application {1} sp\u00e9cifient un magasin de donn\u00e9es {2} qui ne correspond pas \u00e0 l''ID d''un \u00e9l\u00e9ment dataSource ou d''un \u00e9l\u00e9ment databaseStore dans la configuration du serveur, ou qui ne correspond pas au nom JNDI d''une source de donn\u00e9es, d''une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou d''une r\u00e9f\u00e9rence d''unit\u00e9 de persistance qui est accessible \u00e0 l''artefact d''application, ou l''une des ressources connexes n''est pas configur\u00e9e correctement. Un \u00e9l\u00e9ment dataSource peut \u00eatre d\u00e9fini dans la configuration du serveur. Par exemple, {3} Un \u00e9l\u00e9ment databaseStore peut \u00eatre d\u00e9fini dans la configuration du serveur. Par exemple, {4} Un composant d''application peut utiliser l''annotation Resource pour d\u00e9finir une r\u00e9f\u00e9rence de ressource de source de donn\u00e9\
    es. Par exemple, {5}, qui exige que la configuration du serveur ait un \u00e9l\u00e9ment de configuration dataSource avec un attribut {6}. Un composant d''application peut utiliser l''annotation PersistenceUnit pour d\u00e9finir une r\u00e9f\u00e9rence d''unit\u00e9 de persistance. Par exemple, {7}, qui exige que le fichier persistence.xml contienne un \u00e9l\u00e9ment persistence-unit avec un attribut name correspondant. Par exemple, {8}
CWWKD1078.datastore.not.found.explanation=Le magasin de donn\u00e9es d'un r\u00e9f\u00e9rentiel Jakarta Data peut \u00eatre l'ID d'un \u00e9l\u00e9ment dataSource ou d'un \u00e9l\u00e9ment databaseStore dans la configuration du serveur, ou il peut s'agir d'un nom JNDI d'une source de donn\u00e9es, d'une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou d'une r\u00e9f\u00e9rence d'unit\u00e9 de persistance.
CWWKD1078.datastore.not.found.useraction=Assurez-vous que la ressource est correctement configur\u00e9e. Si vous utilisez un nom JNDI, assurez-vous que la port\u00e9e du nom JNDI rend la ressource accessible \u00e0 l'artefact d'application qui fournit le r\u00e9f\u00e9rentiel.

CWWKD1079.jndi.not.found=CWWKD1079E: Une ou plusieurs interfaces de r\u00e9f\u00e9rentiel{0}) de l''artefact d''application {1} sp\u00e9cifient un magasin de donn\u00e9es avec le nom JNDI {2} JNDI, mais une source de donn\u00e9es, une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou une r\u00e9f\u00e9rence d''unit\u00e9 de persistance avec ce nom JNDI n''est pas accessible \u00e0 l''artefact d''application, ou l''une des ressources associ\u00e9es n''est pas configur\u00e9e correctement. Un composant d''application peut utiliser l''annotation Resource pour d\u00e9finir une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es. Par exemple, {3}, qui pointe vers un \u00e9l\u00e9ment de configuration du serveur dataSource avec un attribut {4}. Un composant d''application peut utiliser l''annotation PersistenceUnit pour d\u00e9finir une r\u00e9f\u00e9rence d''unit\u00e9 de persistance. Par exemple, {5}, qui exige que le fichier persistence.xml contienne un \u00e9l\u00e9ment persisten\
    ce-unit avec un attribut name correspondant. Par exemple, {6} Un composant d''application peut utiliser l''annotation DataSourceDefinition pour d\u00e9finir une source de donn\u00e9es. Un \u00e9l\u00e9ment dataSource peut \u00e9galement d\u00e9finir une source de donn\u00e9es dans la configuration du serveur. Par exemple, {7}
CWWKD1079.jndi.not.found.explanation=Lorsque le magasin de donn\u00e9es d'un r\u00e9f\u00e9rentiel Jakarta Data est d\u00e9fini sur le nom JNDI d'une source de donn\u00e9es, une r\u00e9f\u00e9rence de ressource de source de donn\u00e9es ou une r\u00e9f\u00e9rence d'unit\u00e9 de persistance, le nom JNDI doit \u00eatre accessible \u00e0 l'artefact d'application qui fournit le r\u00e9f\u00e9rentiel, et la source de donn\u00e9es ou l'unit\u00e9 de persistance doit \u00eatre configur\u00e9e correctement.
CWWKD1079.jndi.not.found.useraction=Assurez-vous que la ressource est correctement configur\u00e9e et que la port\u00e9e du nom JNDI rend la ressource accessible \u00e0 l'artefact d'application qui fournit le r\u00e9f\u00e9rentiel.

CWWKD1080.datastore.general.err=CWWKD1080E: Une ou plusieurs interfaces de r\u00e9f\u00e9rentiel{0}) de l''artefact d''application {1} ne sont pas disponibles en raison d''une erreur. L''erreur peut \u00eatre due \u00e0 un probl\u00e8me de configuration, ou le magasin de donn\u00e9es {2} pour le r\u00e9f\u00e9rentiel peut ne pas \u00eatre disponible. L''erreur est la suivante : {3}.
CWWKD1080.datastore.general.err.explanation=Une erreur emp\u00eache l'utilisation des d\u00e9p\u00f4ts sp\u00e9cifi\u00e9s.
CWWKD1080.datastore.general.err.useraction=Localisez les interfaces du r\u00e9f\u00e9rentiel et la configuration du magasin de donn\u00e9es et apportez les corrections n\u00e9cessaires.

CWWKD1081.entity.general.err=CWWKD1081E: En raison d''une erreur, l''entit\u00e9 {0} n''est pas disponible pour une ou plusieurs interfaces de r\u00e9f\u00e9rentiel{1}) qui utilisent le magasin de donn\u00e9es {2}. Erreur : {3}.
CWWKD1081.entity.general.err.explanation=Une erreur emp\u00eache l'utilisation de l'entit\u00e9 sp\u00e9cifi\u00e9e.
CWWKD1081.entity.general.err.useraction=Localiser l'entit\u00e9 et apporter les corrections n\u00e9cessaires.

CWWKD1082.entity.classes.missing=CWWKD1082E: L''unit\u00e9 de persistance du magasin de donn\u00e9es {0} ne d\u00e9finit pas une ou plusieurs classes d''entit\u00e9s{1}) dont une ou plusieurs interfaces de r\u00e9f\u00e9rentiel{2}), qui utilisent le magasin de donn\u00e9es, ont besoin.
CWWKD1082.entity.classes.missing.explanation=Les r\u00e9f\u00e9rentiels utilisent des classes d'entit\u00e9s qui doivent \u00eatre d\u00e9finies dans l'unit\u00e9 de persistance.
CWWKD1082.entity.classes.missing.useraction=Inclure toutes les classes d'entit\u00e9s dans l'unit\u00e9 de persistance.

CWWKD1083.dup.method.param=CWWKD1083E: Les param\u00e8tres multiples de la m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} correspondent au param\u00e8tre nomm\u00e9 : {2}. Vous pouvez annoter un param\u00e8tre de m\u00e9thode avec {3} pour sp\u00e9cifier le langage d''interrogation nomm\u00e9 param\u00e8tre. Vous pouvez \u00e9galement activer l''option de compilation -parameters et d\u00e9finir un param\u00e8tre de m\u00e9thode sous la forme {4}, qui ne n\u00e9cessite pas l''annotation Param.
CWWKD1083.dup.method.param.explanation=Chaque param\u00e8tre de m\u00e9thode doit correspondre \u00e0 un param\u00e8tre de requ\u00eate.
CWWKD1083.dup.method.param.useraction=V\u00e9rifier que chacun des param\u00e8tres de la m\u00e9thode sp\u00e9cifie le bon param\u00e8tre nomm\u00e9. Supprimer les param\u00e8tres de m\u00e9thode en double. 
CWWKD1084.missing.named.params=CWWKD1084E: Les param\u00e8tres de la m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} ne d\u00e9finissent pas les param\u00e8tres nomm\u00e9s{2}) qui sont requis par la valeur d''annotation Query : {3}. Vous pouvez d\u00e9finir un param\u00e8tre nomm\u00e9 pour la requ\u00eate en pla\u00e7ant l''annotation Param sur un param\u00e8tre de m\u00e9thode correspondant. Par exemple, {4}. Par ailleurs, si vous activez l''option de compilation -parameters, vous pouvez omettre l''annotation Param si le param\u00e8tre de la m\u00e9thode porte le m\u00eame nom que le param\u00e8tre nomm\u00e9. Par exemple, si String est le type de param\u00e8tre nomm\u00e9, le param\u00e8tre de la m\u00e9thode peut \u00eatre {5}, ce qui ne n\u00e9cessite pas l''annotation Param.
CWWKD1084.missing.named.params.explanation=La valeur de l'annotation Query n\u00e9cessite un ou plusieurs param\u00e8tres nomm\u00e9s qui ne sont pas fournis par la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1084.missing.named.params.useraction=Ajouter des param\u00e8tres \u00e0 la m\u00e9thode de d\u00e9p\u00f4t pour sp\u00e9cifier les param\u00e8tres nomm\u00e9s manquants.

CWWKD1085.extra.method.params=CWWKD1085E: Les param\u00e8tres de la m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} d\u00e9finissent des param\u00e8tres de requ\u00eate{2}) qui ne correspondent \u00e0 aucun des param\u00e8tres nomm\u00e9s{3}) utilis\u00e9s par la valeur d''annotation Query : {4}.
CWWKD1085.extra.method.params.explanation=Tous les param\u00e8tres de la m\u00e9thode doivent \u00eatre utilis\u00e9s par la requ\u00eate ou \u00eatre des types de param\u00e8tres d\u00e9finis par Jakarta Data.
CWWKD1085.extra.method.params.useraction=Supprimer les param\u00e8tres suppl\u00e9mentaires de la m\u00e9thode.

CWWKD1086.named.params.unused=CWWKD1086E: Les param\u00e8tres de la m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} d\u00e9finissent des param\u00e8tres nomm\u00e9s{2}), qui ne sont pas utilis\u00e9s dans la valeur d''annotation Query : {3}. Vous pouvez faire r\u00e9f\u00e9rence \u00e0 des param\u00e8tres nomm\u00e9s dans une requ\u00eate en utilisant le caract\u00e8re : suivi du nom du param\u00e8tre. Par exemple, {4}. Les param\u00e8tres positionn\u00e9s dans une requ\u00eate peuvent \u00eatre r\u00e9f\u00e9renc\u00e9s en utilisant la balise ? suivi d''une valeur ordinale, commen\u00e7ant par ?1. \u00c9vitez d''annoter les param\u00e8tres des m\u00e9thodes avec l''annotation Param lorsque la requ\u00eate utilise des param\u00e8tres positionnels ou n''a pas de param\u00e8tres.
CWWKD1086.named.params.unused.explanation=L'annotation Param ne peut \u00eatre utilis\u00e9e que lorsque la requ\u00eate a des param\u00e8tres nomm\u00e9s.
CWWKD1086.named.params.unused.useraction=Supprimez l'annotation Param ou modifiez la requ\u00eate pour utiliser des param\u00e8tres nomm\u00e9s.

CWWKD1087.null.param=CWWKD1087E: Le param\u00e8tre {0} de la m\u00e9thode {1} de l''interface du r\u00e9f\u00e9rentiel {2} est une valeur nulle. Sp\u00e9cifier une valeur non nulle.
CWWKD1087.null.param.explanation=La valeur du param\u00e8tre ne doit pas \u00eatre nulle.
CWWKD1087.null.param.useraction=Sp\u00e9cifier une valeur non nulle pour le param\u00e8tre.

CWWKD1088.empty.sorts=CWWKD1088E: Les crit\u00e8res de tri sp\u00e9cifi\u00e9s par le param\u00e8tre {0} de la m\u00e9thode {1} de l''interface du r\u00e9f\u00e9rentiel {2} sont vides.
CWWKD1088.empty.sorts.explanation=Les crit\u00e8res de tri ne doivent pas \u00eatre vides.
CWWKD1088.empty.sorts.useraction=Sp\u00e9cifiez une valeur pour les crit\u00e8res de tri.

CWWKD1089.unordered.pagination=CWWKD1089E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} doit sp\u00e9cifier les crit\u00e8res de tri car la m\u00e9thode renvoie une valeur {2}. Les donn\u00e9es non ordonn\u00e9es ne peuvent pas \u00eatre divis\u00e9es en pages.
CWWKD1089.unordered.pagination.explanation=La pagination n\u00e9cessite des donn\u00e9es ordonn\u00e9es.
CWWKD1089.unordered.pagination.useraction=Utilisez l'annotation OrderBy pour d\u00e9finir les crit\u00e8res de tri de la m\u00e9thode de d\u00e9p\u00f4t.

CWWKD1090.orderby.conflict=CWWKD1090E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} ne peut pas combiner l''annotation OrderBy et le mot cl\u00e9 OrderBy.
CWWKD1090.orderby.conflict.explanation=L'annotation OrderBy n'est pas compatible avec le mot-cl\u00e9 OrderBy.
CWWKD1090.orderby.conflict.useraction=Utilisez uniquement l'annotation OrderBy ou le mot-cl\u00e9 OrderBy.

CWWKD1091.method.name.parse.err=CWWKD1091E: Un attribut d''entit\u00e9 nomm\u00e9 {0} n''est pas trouv\u00e9 sur la classe d''entit\u00e9 {1} pour la m\u00e9thode {2} de l''interface de r\u00e9f\u00e9rentiel {3}. Confirmez que la m\u00e9thode du r\u00e9f\u00e9rentiel a un nom conforme au mod\u00e8le Query by Method Name ou qu''elle est annot\u00e9e avec l''un des \u00e9l\u00e9ments suivants : {4}. Les noms d''attributs valables pour l''entit\u00e9 sont les suivants {5}.
CWWKD1091.method.name.parse.err.explanation=Le nom de la m\u00e9thode du r\u00e9f\u00e9rentiel a \u00e9t\u00e9 analys\u00e9 selon le mod\u00e8le "Query by Method Name" car la m\u00e9thode du r\u00e9f\u00e9rentiel n'a pas d'annotation Jakarta Data indiquant le type d'op\u00e9ration.
CWWKD1091.method.name.parse.err.useraction=Corrigez le nom de la m\u00e9thode du r\u00e9f\u00e9rentiel ou annotez la m\u00e9thode du r\u00e9f\u00e9rentiel pour indiquer une op\u00e9ration Jakarta Data telle que Query, Find ou Save.

CWWKD1092.lifecycle.arg.empty=CWWKD1092E: La m\u00e9thode {0} du r\u00e9f\u00e9rentiel {1} n''accepte pas de param\u00e8tre {2} vide. La valeur du param\u00e8tre doit contenir au moins une entit\u00e9.
CWWKD1092.lifecycle.arg.empty.explanation=M\u00e9thodes d'insertion, de mise \u00e0 jour, de sauvegarde et de suppression
 require au moins une entit\u00e9.
CWWKD1092.lifecycle.arg.empty.useraction=S'assurer que le tableau, la liste ou le flux fourni \u00e0 la m\u00e9thode contient au moins une entit\u00e9.

CWWKD1093.fn.not.applicable=CWWKD1093E: La fonction {0} ne peut pas \u00eatre \u00e9valu\u00e9e pour l''entit\u00e9 {1} utilis\u00e9e par la m\u00e9thode {2} de l''interface de r\u00e9f\u00e9rentiel {3}. L''entit\u00e9 n''a pas d''attribut annot\u00e9 par {4} ou dont {0} peut \u00eatre d\u00e9duit.
CWWKD1093.fn.not.applicable.explanation=La fonction ne peut pas \u00eatre utilis\u00e9e sur l'entit\u00e9 car l'entit\u00e9 n'a pas d'attribut d'identification ou de version.
CWWKD1093.fn.not.applicable.useraction=Ne pas utiliser la fonction dans le langage de requ\u00eate ou dans les param\u00e8tres de la m\u00e9thode de d\u00e9p\u00f4t.

CWWKD1094.return.mismatch=CWWKD1094E: La m\u00e9thode {0} de l''interface du r\u00e9f\u00e9rentiel {1} a le type de retour {2}, qui n''est pas capable de renvoyer le nombre d''entit\u00e9s, {3}, que la m\u00e9thode du r\u00e9f\u00e9rentiel accepte comme param\u00e8tre. Les types de retour valides pour une m\u00e9thode {4} qui accepte plusieurs entit\u00e9s sont les suivants : {5}.
CWWKD1094.return.mismatch.explanation=Une m\u00e9thode du cycle de vie du r\u00e9f\u00e9rentiel qui renvoie des entit\u00e9s doit pouvoir renvoyer le m\u00eame nombre d'entit\u00e9s que celui accept\u00e9 par la m\u00e9thode.
CWWKD1094.return.mismatch.useraction=Mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour utiliser un type de retour qui peut renvoyer plusieurs entit\u00e9s ou mettre \u00e0 jour la m\u00e9thode du r\u00e9f\u00e9rentiel pour n'accepter qu'une seule entit\u00e9.

CWWKD1095.repo.err=CWWKD1095E: Une erreur a emp\u00each\u00e9 la mise en \u0153uvre de l''interface du r\u00e9f\u00e9rentiel {0}. L''annotation du r\u00e9f\u00e9rentiel est {1}. La classe d''entit\u00e9 primaire est {2}. L''erreur est la suivante : {3}
CWWKD1095.repo.err.explanation=Le fournisseur int\u00e9gr\u00e9 de Jakarta Data n'est pas en mesure de fournir une instance du r\u00e9f\u00e9rentiel en raison d'une erreur.
CWWKD1095.repo.err.useraction=Recherchez l'erreur et corrigez l'interface du r\u00e9f\u00e9rentiel, les entit\u00e9s, la configuration du magasin de donn\u00e9es ou la base de donn\u00e9es.

CWWKD1096.orderby.incompat=CWWKD1096E: La m\u00e9thode {0} du r\u00e9f\u00e9rentiel {1} a une annotation OrderBy, mais la m\u00e9thode {0} n''est pas une op\u00e9ration de recherche ou de suppression qui renvoie des entit\u00e9s.
CWWKD1096.orderby.incompat.explanation=L'annotation OrderBy n'est pas compatible avec le type d'op\u00e9ration du r\u00e9f\u00e9rentiel.
CWWKD1096.orderby.incompat.useraction=Supprime l'annotation OrderBy.

CWWKD1097.param.incompat=CWWKD1097E: La m\u00e9thode {0} du r\u00e9f\u00e9rentiel {1} a un param\u00e8tre {2}, mais la m\u00e9thode {0} n''est pas une op\u00e9ration de recherche ou de suppression qui renvoie des entit\u00e9s.
CWWKD1097.param.incompat.explanation=Les param\u00e8tres Order, Sort et Limit ne sont pas compatibles avec le type d'op\u00e9ration du r\u00e9f\u00e9rentiel.
CWWKD1097.param.incompat.useraction=Supprimer le param\u00e8tre Ordre, Tri ou Limite.

CWWKD1098.spec.param.position.err=CWWKD1098E: La m\u00e9thode {0} du r\u00e9f\u00e9rentiel {1} comporte un param\u00e8tre {2} plac\u00e9 avant les param\u00e8tres de la requ\u00eate. Les types de param\u00e8tres qui ont une signification particuli\u00e8re dans Jakarta Data {3} ) doivent \u00eatre plac\u00e9s apr\u00e8s les autres param\u00e8tres dans la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1098.spec.param.position.err.explanation=Lorsque des types de param\u00e8tres sp\u00e9ciaux d\u00e9finis par Jakarta Data sont inclus dans la signature d'une m\u00e9thode de r\u00e9f\u00e9rentiel, ils doivent \u00eatre plac\u00e9s apr\u00e8s tous les param\u00e8tres de la requ\u00eate.
CWWKD1098.spec.param.position.err.useraction=D\u00e9placer les types de param\u00e8tres sp\u00e9ciaux d\u00e9finis par Jakarta Data \u00e0 la fin de la signature de la m\u00e9thode du r\u00e9f\u00e9rentiel.

CWWKD1099.first.keyword.incompat=CWWKD1099E: La m\u00e9thode {0} du r\u00e9f\u00e9rentiel {1} a un nom qui inclut le mot cl\u00e9 First, ce qui est incompatible avec le param\u00e8tre {2} de la m\u00e9thode.
CWWKD1099.first.keyword.incompat.explanation=Une m\u00e9thode Query by Method Name qui inclut un param\u00e8tre Limit ou PageRequest ne peut pas utiliser le mot-cl\u00e9 First.
CWWKD1099.first.keyword.incompat.useraction=Supprimer le mot-cl\u00e9 First du nom de la m\u00e9thode.

CWWKD1100.cursor.requires.sort=CWWKD1100E: La m\u00e9thode {0} du r\u00e9f\u00e9rentiel {1} renvoie {2} mais n''a pas d''annotation OrderBy ni aucun des param\u00e8tres suivants pour sp\u00e9cifier les crit\u00e8res de tri : {3}. Les crit\u00e8res de tri sont n\u00e9cessaires pour la pagination bas\u00e9e sur le curseur et ne peuvent pas \u00eatre sp\u00e9cifi\u00e9s dans une clause ORDER BY d''une valeur d''annotation de requ\u00eate.
CWWKD1100.cursor.requires.sort.explanation=La pagination par curseur n\u00e9cessite des crit\u00e8res de tri.
CWWKD1100.cursor.requires.sort.useraction=Supprime la clause ORDER BY de la valeur d'annotation de la requ\u00eate si elle existe. Ajoutez une annotation OrderBy ou un param\u00e8tre de m\u00e9thode du r\u00e9f\u00e9rentiel pour sp\u00e9cifier les crit\u00e8res de tri.

CWWKD1101.attr.subset.mismatch=CWWKD1101E: {0} Le type de retour de la m\u00e9thode {1} du r\u00e9f\u00e9rentiel {2} utilise le type d''enregistrement Java {3} pour d\u00e9finir les r\u00e9sultats comme un sous-ensemble des attributs de l''entit\u00e9 : {4}. Cependant, au moins un des noms d''attributs demand\u00e9s n''est pas pr\u00e9sent dans l''entit\u00e9 {5}. Pour renvoyer un sous-ensemble d''attributs d''entit\u00e9 sous la forme d''un enregistrement Java, assurez-vous que les noms des composants de l''enregistrement font partie de l''ensemble suivant de noms d''attributs valides pour l''entit\u00e9 {5} : {6}. Il est \u00e9galement possible d''utiliser l''annotation Select pour attribuer des noms d''attributs d''entit\u00e9s valides. Pour renvoyer un seul attribut d''entit\u00e9 ayant un type d''enregistrement Java, annotez la m\u00e9thode {1} avec l''annotation Select et attribuez la valeur de son membre au nom de l''attribut d''entit\u00e9.
CWWKD1101.attr.subset.mismatch.explanation=Lorsque des enregistrements Java sont utilis\u00e9s pour r\u00e9cup\u00e9rer un sous-ensemble d'attributs d'entit\u00e9, tous les composants de l'enregistrement doivent correspondre \u00e0 des attributs d'entit\u00e9 valides.
CWWKD1101.attr.subset.mismatch.useraction=Renommez les composants de l'enregistrement pour qu'ils correspondent \u00e0 des noms d'attributs d'entit\u00e9 valides, ou utilisez l'annotation Select pour demander explicitement des attributs d'entit\u00e9 par leur nom.

CWWKD1102.incompat.query.result=CWWKD1102E: La m\u00e9thode {0} du r\u00e9f\u00e9rentiel {1} a le type de retour {2}, mais le fournisseur Jakarta Persistence a effectu\u00e9 une requ\u00eate avec des r\u00e9sultats de type {3}. V\u00e9rifier si le fournisseur Jakarta Persistence permet d''interroger les types d''attributs d''entit\u00e9 que la m\u00e9thode {0} s\u00e9lectionne. V\u00e9rifier les autres causes d''incompatibilit\u00e9 si le fournisseur Jakarta permet d''interroger les types d''attributs d''entit\u00e9 que la m\u00e9thode {0} s\u00e9lectionne.
CWWKD1102.incompat.query.result.explanation=Les fournisseurs de services de persistance Jakarta ne permettent pas de renvoyer tous les types d'attributs d'entit\u00e9. Si le fournisseur Jakarta renvoie bien le type d'attributs d'entit\u00e9 que la m\u00e9thode a s\u00e9lectionn\u00e9, il existe une autre cause d'incompatibilit\u00e9. Par exemple, le fournisseur Jakarta Persistence peut pr\u00e9senter un bogue ou la signature de la m\u00e9thode de d\u00e9p\u00f4t peut comporter une erreur.
CWWKD1102.incompat.query.result.useraction=Si le type d'attributs d'entit\u00e9 s\u00e9lectionn\u00e9 par la m\u00e9thode n'est pas autoris\u00e9, modifiez la requ\u00eate pour r\u00e9cup\u00e9rer l'entit\u00e9 enti\u00e8re ou un ensemble diff\u00e9rent d'attributs d'entit\u00e9 autoris\u00e9s par le fournisseur de Jakarta Persistence. Si le type d'attributs d'entit\u00e9 s\u00e9lectionn\u00e9 par la m\u00e9thode est autoris\u00e9, v\u00e9rifiez les autres causes d'incompatibilit\u00e9.

CWWKD1103.incompat.query.result=CWWKD1103E: La m\u00e9thode {0} du r\u00e9f\u00e9rentiel {1} a le type de retour {2}, mais le fournisseur Jakarta Persistence a effectu\u00e9 une requ\u00eate {3} avec des r\u00e9sultats de type {4}. V\u00e9rifier si le fournisseur Jakarta Persistence permet d''interroger les types d''attributs d''entit\u00e9 que la m\u00e9thode {0} s\u00e9lectionne. V\u00e9rifier les autres causes d''incompatibilit\u00e9 si le fournisseur Jakarta permet d''interroger les types d''attributs d''entit\u00e9 que la m\u00e9thode {0} s\u00e9lectionne.
CWWKD1103.incompat.query.result.explanation=Les fournisseurs de services de persistance Jakarta ne permettent pas de renvoyer tous les types d'attributs d'entit\u00e9. Si le fournisseur Jakarta renvoie bien le type d'attributs d'entit\u00e9 que la m\u00e9thode a s\u00e9lectionn\u00e9, il existe une autre cause d'incompatibilit\u00e9. Par exemple, le fournisseur Jakarta Persistence peut pr\u00e9senter un bogue ou la signature de la m\u00e9thode de d\u00e9p\u00f4t peut comporter une erreur.
CWWKD1103.incompat.query.result.useraction=Si le type d'attributs d'entit\u00e9 s\u00e9lectionn\u00e9 par la m\u00e9thode n'est pas autoris\u00e9, modifiez la requ\u00eate pour r\u00e9cup\u00e9rer l'entit\u00e9 enti\u00e8re ou un ensemble diff\u00e9rent d'attributs d'entit\u00e9 autoris\u00e9s par le fournisseur de Jakarta Persistence. Si le type d'attributs d'entit\u00e9 s\u00e9lectionn\u00e9 par la m\u00e9thode est autoris\u00e9, v\u00e9rifiez les autres causes d'incompatibilit\u00e9.

CWWKD1104.empty.anno.value=CWWKD1104E: La valeur vide de la classe String n''est pas une valeur valide pour l''annotation {0} utilis\u00e9e sur la m\u00e9thode {1} du r\u00e9f\u00e9rentiel {2}.
CWWKD1104.empty.anno.value.explanation=La valeur vide pour la classe String n'est pas une valeur prise en charge. La valeur prise en charge d\u00e9pend du type d'annotation. Par exemple, si l'annotation est une annotation Param, les valeurs valides sont les noms des param\u00e8tres nomm\u00e9s qui sont utilis\u00e9s dans la valeur de l'annotation Query.
CWWKD1104.empty.anno.value.useraction=Si l'annotation n'est pas n\u00e9cessaire, supprimez-la de la m\u00e9thode de d\u00e9p\u00f4t. Sinon, sp\u00e9cifiez une valeur valide pour l'annotation.

CWWKD1105.keyword.in.orderby=CWWKD1105E: La clause OrderBy de la m\u00e9thode {0} du r\u00e9f\u00e9rentiel {1} ne peut pas \u00eatre analys\u00e9e car l''attribut {2} de l''entit\u00e9 {3} contient le mot-cl\u00e9 {4} du mod\u00e8le Jakarta Data Query by Method Name. Supprimer la clause OrderBy du nom de la m\u00e9thode {0} et utiliser l''annotation OrderBy \u00e0 la place.
CWWKD1105.keyword.in.orderby.explanation=Les noms d'attributs d'entit\u00e9s qui contiennent des mots-cl\u00e9s Jakarta Data ne peuvent pas \u00eatre utilis\u00e9s dans les noms des m\u00e9thodes du r\u00e9f\u00e9rentiel qui suivent le mod\u00e8le d'interrogation des donn\u00e9es Jakarta par nom de m\u00e9thode.
CWWKD1105.keyword.in.orderby.useraction=Renommez l'attribut de l'entit\u00e9 ou passez \u00e0 l'annotation OrderBy pour sp\u00e9cifier l'ordre.

CWWKD1106.init.timed.out=CWWKD1106E: Le r\u00e9f\u00e9rentiel {0} qui n\u00e9cessite le magasin de donn\u00e9es {1} et qui est fourni ou utilis\u00e9 par l''artefact d''application {2} n''est pas devenu disponible dans les {3} secondes. Confirmez que l''artefact d''application {2} d\u00e9marre et que la ressource de magasin de donn\u00e9es {1} sp\u00e9cifi\u00e9e comme valeur dataStore de l''annotation Repository est configur\u00e9e correctement et est accessible \u00e0 l''artefact d''application au moment o\u00f9 l''on acc\u00e8de pour la premi\u00e8re fois au r\u00e9f\u00e9rentiel {0}.
CWWKD1106.init.timed.out.explanation=Un d\u00e9p\u00f4t n'a pas \u00e9t\u00e9 disponible dans le d\u00e9lai imparti.
CWWKD1106.init.timed.out.useraction=V\u00e9rifier la configuration du site dataStore et confirmer qu'il est accessible aux artefacts d'application qui d\u00e9finissent et utilisent le r\u00e9f\u00e9rentiel. Confirmez \u00e9galement que l'application et tous ses modules d\u00e9marrent correctement.

CWWKD1107.init.timed.out.checkpoint=CWWKD1107E: L''artefact de l''application {0} a acc\u00e9d\u00e9 au r\u00e9f\u00e9rentiel {1} avant qu''un point de contr\u00f4le de l''application ne soit termin\u00e9. Mettre \u00e0 jour l''application {0} pour \u00e9viter d''utiliser le r\u00e9f\u00e9rentiel avant un point de contr\u00f4le.
CWWKD1107.init.timed.out.checkpoint.explanation=Les applications ne peuvent pas utiliser les r\u00e9f\u00e9rentiels avant l'ach\u00e8vement d'un point de contr\u00f4le.
CWWKD1107.init.timed.out.checkpoint.useraction=\u00c9vitez d'utiliser le r\u00e9f\u00e9rentiel jusqu'\u00e0 ce que le point de contr\u00f4le soit termin\u00e9.

CWWKD1108.missing.entity.anno=CWWKD1108E: La classe d''entit\u00e9s {0} n\u00e9cessite l''annotation {1} car l''annotation {2} est appliqu\u00e9e au membre {3} de la classe d''entit\u00e9s.
CWWKD1108.missing.entity.anno.explanation=Classes d'entit\u00e9s utilisant des annotations
 from le paquet jakarta.persistence doit \u00e9galement \u00eatre annot\u00e9 avec l'\u00e9l\u00e9ment Entity
 annotation de la sp\u00e9cification Jakarta Persistence.
CWWKD1108.missing.entity.anno.useraction=Appliquer l'annotation Entit\u00e9 \u00e0 l'\u00e9l\u00e9ment
 entity ou supprimer les annotations Jakarta Persistence de ses membres.

CWWKD1109.jpa.anno.on.record=CWWKD1109E: L''annotation {0} n''est pas autoris\u00e9e sur la m\u00e9thode {1} de la classe d''entit\u00e9 {2} car la classe d''entit\u00e9 {2} est un enregistrement Java.
CWWKD1109.jpa.anno.on.record.explanation=Les annotations Jakarta Persistence ne sont pas autoris\u00e9es sur les enregistrements Java.
CWWKD1109.jpa.anno.on.record.useraction=Passez \u00e0 une classe d'entit\u00e9 Jakarta Persistence ou supprimez l'annotation Jakarta Persistence de l'enregistrement Java.

CWWKD1110.incompat.with.collection=CWWKD1110E: La m\u00e9thode {0} de l''interface de r\u00e9f\u00e9rentiel {1} a un nom qui inclut le mot-cl\u00e9 {2}, ce qui est incompatible avec l''attribut {3} de l''entit\u00e9 {4} parce que l''attribut a un type de collection. Les mots-cl\u00e9s suivants de requ\u00eate par nom de m\u00e9thode peuvent \u00eatre utilis\u00e9s avec les attributs d''entit\u00e9 qui ont un type de collection : {5}.
CWWKD1110.incompat.with.collection.explanation=Certains mots-cl\u00e9s de l'interrogation par nom de m\u00e9thode ne sont pas compatibles avec les attributs d'entit\u00e9 qui ont un type de collection.
CWWKD1110.incompat.with.collection.useraction=Mettre \u00e0 jour la m\u00e9thode de d\u00e9p\u00f4t pour \u00e9viter d'utiliser le mot-cl\u00e9 qui n'est pas compatible avec le type de collection.

CWWKD1111.unsupported.convert=CWWKD1111E: L''impl\u00e9mentation de {0} AttributeConverter convertit les valeurs de {1} en type {2}, qui n''est pas pris en charge par la sp\u00e9cification Jakarta Data. La sp\u00e9cification Jakarta Data prend en charge les types d''\u00e9num\u00e9ration Java, les types temporels {3} et les types de base suivants : {4}. Le fournisseur de donn\u00e9es Jakarta int\u00e9gr\u00e9 prend \u00e9galement en charge certains types de persistance Jakarta.
CWWKD1111.unsupported.convert.explanation=L'impl\u00e9mentation AttributeConverter ne peut pas \u00eatre utilis\u00e9e avec le fournisseur de donn\u00e9es Jakarta int\u00e9gr\u00e9 car elle convertit les valeurs en un type non pris en charge.
CWWKD1111.unsupported.convert.useraction=Mise \u00e0 jour de l'impl\u00e9mentation de AttributeConverter pour convertir les valeurs en l'un des types pris en charge.

CWWKD1112.record.entity.verify.err=CWWKD1112W: Une classe d''entit\u00e9 pour l''enregistrement {0} est d\u00e9finie mais pourrait ne pas fonctionner. La v\u00e9rification des octets de la classe d''entit\u00e9 Jakarta Persistence, qui a \u00e9t\u00e9 g\u00e9n\u00e9r\u00e9e pour la classe d''entit\u00e9, a \u00e9chou\u00e9. La classe d''entit\u00e9 d\u00e9finie est utilis\u00e9e par une ou plusieurs interfaces de r\u00e9f\u00e9rentiel ( {1} ) dans l''artefact d''application {2}. L''erreur est la suivante : {3}.
CWWKD1112.record.entity.verify.err.explanation=Lorsqu'un r\u00e9f\u00e9rentiel utilise une entit\u00e9 record, une entit\u00e9 Jakarta Persistence est g\u00e9n\u00e9r\u00e9e pour repr\u00e9senter l'entit\u00e9 record. La v\u00e9rification des octets de la classe d'entit\u00e9 Jakarta Persistence g\u00e9n\u00e9r\u00e9e a \u00e9chou\u00e9.
CWWKD1112.record.entity.verify.err.useraction=V\u00e9rifier que la mise en \u0153uvre de l'entit\u00e9 d'archivage respecte les exigences et les conventions relatives \u00e0 une entit\u00e9 d'archivage.

CWWKD1113.server.stopping=CWWKD1113I: Un ou plusieurs d\u00e9p\u00f4ts ( {0} ) n''ont pas \u00e9t\u00e9 initialis\u00e9s car le serveur est en train de s''arr\u00eater.
CWWKD1113.server.stopping.explanation=Le serveur s'arr\u00eate et ne tentera pas d'initialiser les r\u00e9f\u00e9rentiels.
CWWKD1113.server.stopping.useraction=Aucune action n'est requise.

CWWKD1114.app.stopping=CWWKD1114I: Un ou plusieurs r\u00e9f\u00e9rentiels ( {0} ) n''ont pas \u00e9t\u00e9 initialis\u00e9s car l''application {1} est dans l''\u00e9tat {2}.
CWWKD1114.app.stopping.explanation=L'application s'arr\u00eate ou s'est arr\u00eat\u00e9e et n'essaiera pas d'initialiser les r\u00e9f\u00e9rentiels.
CWWKD1114.app.stopping.useraction=D\u00e9marrer l'application pour rendre les d\u00e9p\u00f4ts disponibles.

CWWKD1115.app.unavailable=CWWKD1115E: Un ou plusieurs d\u00e9p\u00f4ts ( {0} ) n''ont pas \u00e9t\u00e9 initialis\u00e9s car l''application {1} n''est pas disponible.
CWWKD1115.app.unavailable.explanation=L'application qui d\u00e9finit les r\u00e9f\u00e9rentiels n'est pas disponible. Les r\u00e9f\u00e9rentiels ne peuvent pas s'initialiser.
CWWKD1115.app.unavailable.useraction=D\u00e9marrer l'application pour rendre les d\u00e9p\u00f4ts disponibles.

CWWKD1116.resource.unavailable=CWWKD1116E: Un ou plusieurs r\u00e9f\u00e9rentiels ( {0} ) n''ont pas \u00e9t\u00e9 initialis\u00e9s parce que la ressource {1} n''a pas \u00e9t\u00e9 disponible dans les {2} secondes.
CWWKD1116.resource.unavailable.explanation=Une ressource dont les r\u00e9f\u00e9rentiels ont besoin n'est pas devenue disponible.
CWWKD1116.resource.unavailable.useraction=V\u00e9rifier la configuration des ressources utilis\u00e9es par les r\u00e9f\u00e9rentiels.

CWWKD1117.anno.constraint.conflict=CWWKD1117E: Le param\u00e8tre {0} de la m\u00e9thode {1} de l''interface du r\u00e9f\u00e9rentiel {2} ne peut pas \u00eatre annot\u00e9 avec les annotations : {3}. Une ou plusieurs annotations sont incompatibles avec le type {4} du param\u00e8tre de la m\u00e9thode du r\u00e9f\u00e9rentiel.
CWWKD1117.anno.constraint.conflict.explanation=La contrainte et ses sous-types ne peuvent pas \u00eatre combin\u00e9s avec des annotations de param\u00e8tres autres que l'annotation By.
CWWKD1117.anno.constraint.conflict.useraction=Supprimer l'annotation conflictuelle ou sp\u00e9cifier le type d'attribut de l'entit\u00e9 au lieu d'un type de contrainte.

CWWKD1118.param.anno.conflict=CWWKD1118E: Le param\u00e8tre {0} de la m\u00e9thode {1} de l''interface du r\u00e9f\u00e9rentiel {2} ne peut pas \u00eatre annot\u00e9 avec les annotations : {3}. Deux ou plusieurs annotations sont contradictoires.
CWWKD1118.param.anno.conflict.explanation=La combinaison d'annotations de param\u00e8tres n'est pas valide.
CWWKD1118.param.anno.conflict.useraction=Supprimer une ou plusieurs des annotations conflictuelles du param\u00e8tre de la m\u00e9thode du r\u00e9f\u00e9rentiel.
