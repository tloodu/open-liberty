<server>
    <featureManager>
        <feature>webProfile-8.0</feature>
        <feature>componenttest-1.0</feature>
    </featureManager>

    <include location="../fatTestPorts.xml"/>

    <webApplication location="testNativeLibrary.war">
        <classloader privateLibraryRef="testPrivateLib1,testPrivateLib3,testPrivateLib5" commonLibraryRef="testCommonLib2,testCommonLib4,testCommonLib6" />
    </webApplication>

    <library id="testPrivateLib1">
       <!-- test of relative path to jar -->
       <path name="lib1/testLib1.jar"/>
       <!-- native path is configured in test code -->
    </library>

    <library id="testCommonLib2">
       <!-- test of relative path to jar -->
       <path name="lib2/testLib2.jar"/>
       <!-- native path is configured in test code -->
    </library>

    <library id="testPrivateLib3">
       <!-- test of relative path to jar -->
       <file name="lib3/testLib3.jar"/>
       <!-- native path is configured in test code -->
    </library>

    <library id="testCommonLib4">
       <!-- test of relative path to jar -->
       <file name="lib4/testLib4.jar"/>
       <!-- native path is configured in test code -->
    </library>

    <library id="testPrivateLib5">
       <!-- test of relative path fileset -->
       <fileset dir="lib5"/>
    </library>

    <library id="testCommonLib6">
       <!-- test of relative path fileset -->
       <fileset dir="lib6"/>
    </library>

    <javaPermission codeBase="${server.config.dir}/apps/testNativeLibrary.war" className="java.lang.RuntimePermission" name="getClassLoader"/>
    <javaPermission codeBase="${server.config.dir}/apps/testNativeLibrary.war" className="java.lang.RuntimePermission" name="accessDeclaredMembers"/>
    <javaPermission codeBase="${server.config.dir}/apps/testNativeLibrary.war" className="java.lang.reflect.ReflectPermission" name="suppressAccessChecks"/>
</server>
