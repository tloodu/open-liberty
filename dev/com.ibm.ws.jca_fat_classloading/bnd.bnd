-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0

src:\
    fat/src,\
    test-applications/cdiweb/src,\
    test-applications/fvtweb/src,\
    test-libraries/cdilib/src,\
    test-libraries/testlib/src,\
    test-resourceadapters/fvtra/src

tested.features:\
    cdi-4.0,\
    connectors-2.1,\
    messaging-3.1,\
    servlet-6.0

fat.project: true

-buildpath:\
    com.ibm.ws.componenttest.2.0;version=latest,\
    io.openliberty.jakarta.annotation.2.0;version=latest,\
    io.openliberty.jakarta.cdi.3.0;version=latest,\
    io.openliberty.jakarta.connectors.2.0;version=latest,\
    io.openliberty.jakarta.messaging.3.0;version=latest,\
    io.openliberty.jakarta.servlet.5.0;version=latest

