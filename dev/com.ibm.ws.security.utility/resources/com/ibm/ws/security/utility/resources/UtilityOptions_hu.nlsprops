#CMVCPATHNAME com.ibm.ws.security.utility/resources/com/ibm/ws/security/utility/resources/UtilityOptions.nlsprops
#ISMESSAGEFILE FALSE
#NLS_ENCODING=UNICODE
#NLS_MESSAGEFORMAT_ALL

global.description=Le\u00edr\u00e1s:
global.actions=M\u0171veletek:
global.options=Param\u00e9terek:
global.usage=Haszn\u00e1lat:
global.required=K\u00f6telez\u0151:
global.options.statement=\tAz egyes m\u0171veletek r\u00e9szletes param\u00e9terinform\u00e1ci\u00f3it a help [m\u0171veletn\u00e9v] paranccsal k\u00e9rheti le.



# -------- GENERAL OPTIONS -----------------------------------------------#
# List of descriptive text for options. Use "\n\" for line continuations.
# The code provides no whitespace: begin keys with "\ \ \ \ " for leading
# whitespace, and begin descriptions with \t 
#------------------------------\n at 72 chars -------------------------\n\#
#------------------------------\n at 72 chars Leading "\ \ \ \ "-------\n\#
#------------------------------\n at 72 chars Leading "\t"-------------\n\#
#Note to translator, please make sure that the the length of the line should
# not exceed 80 characters. Therefore the \n (CRLF) needs to be placed at or
# before 72th characters if the line starts with \t.
# And this statement is applied after the sentences are translated.
# So please feel free to place \n character at or before 72th characters if
# the translated sentence is longer than the original sentence.

help.desc=\tS\u00fag\u00f3inform\u00e1ci\u00f3kat jelen\u00edt meg a megadott m\u0171veletr\u0151l.
#Note to translator the word "help" should not be translated
help.usage.options=\t{0} help [m\u0171veletn\u00e9v]

# -------- ENCODE OPTIONS ------------------------------------------------#
# List of descriptive text for options. Use "\n\" for line continuations.
# The code provides no whitespace: begin keys with "\ \ \ \ " for leading
# whitespace, and begin descriptions with \t 
#------------------------------\n at 72 chars -------------------------\n\#
#------------------------------\n at 72 chars Leading "\ \ \ \ "-------\n\#
#------------------------------\n at 72 chars Leading "\t"-------------\n\#
encode.desc=\tK\u00f3dolja a megadott sz\u00f6veget.\n\n\tHa jelszava speci\u00e1lis karaktereket tartalmaz, minden speci\u00e1lis karaktert meg kell sz\u00fcntetni, hogy biztos\u00edtsa a jelsz\u00f3 megfelel\u0151 k\u00f3dol\u00e1s\u00e1t.\n\tA speci\u00e1lis karakterek \u00e9s az escape karakterek az oper\u00e1ci\u00f3s rendszert\u0151l f\u00fcgg\u0151en v\u00e1ltozhatnak.\n\tP\u00e9ld\u00e1ul UNIX rendszereken pa$$W0rd \u00e9rt\u00e9ket pa\\$\\$W0rd n\u00e9ven kell megadni.\n\tTov\u00e1bbi inform\u00e1ci\u00f3k\u00e9rt tekintse meg az Open Liberty securityUtility k\u00f3dol\u00e1si dokument\u00e1ci\u00f3j\u00e1t.
#Note to translator the word "encode" should not be translated
encode.usage.options=\t{0} encode [param\u00e9terek]
encode.option-key.text=\ \ \ \ sz\u00f6vegK\u00f3dol\u00e1shoz
encode.option-desc.text=\tHa nincsenek megadva argumentumok, akkor az eszk\u00f6z interakt\u00edv   \n\tm\u00f3dban lesz; egy\u00e9b esetben a megadott sz\u00f6veg ker\u00fcl k\u00f3dol\u00e1sra.\n\tA sz\u00f3k\u00f6z\u00f6ket tartalmaz\u00f3 sz\u00f6veget id\u00e9z\u0151jelek k\u00f6z\u00e9 kell tenni, ha argumentumk\u00e9nt van megadva.
encode.option-key.encoding=\ \ \ \ --encoding=[xor|aes|hash{1}]
encode.option-desc.encoding=\tAdja meg, hogyan k\u00f3dolja a jelsz\u00f3t. T\u00e1mogatott k\u00f3dol\u00e1sok: xor, aes, aes-128, \u00e9s hash. Az alap\u00e9rtelmezett k\u00f3dol\u00e1s: xor. Az Aes titkos\u00edt\u00e1s egy aes-256 bites kulcs haszn\u00e1lat\u00e1val t\u00f6rt\u00e9nik.\n\taes-128 a 25.0.0.2 el\u0151tti szerverv\u00e1ltozatokkal val\u00f3 kompatibilit\u00e1s \u00e9rdek\u00e9ben haszn\u00e1lhat\u00f3. {2}
encode.option-key.key=\ \ \ \ --key=[kulcs]
encode.option-desc.key=\tMegad egy kulcsot az AES k\u00f3dol\u00e1shoz. Ez a karaktersorozat\n\tlesz kivonatolva titkos\u00edt\u00e1si kulcs el\u0151\u00e1ll\u00edt\u00e1s\u00e1hoz, amely a jelsz\u00f3 titkos\u00edt\u00e1s\u00e1ban\n\t\u00e9s visszafejt\u00e9s\u00e9ben ker\u00fcl felhaszn\u00e1l\u00e1sra. A kulcsot a kiszolg\u00e1l\u00f3 sz\u00e1m\u00e1ra a\n\twlp.password.encryption.key meghat\u00e1roz\u00e1s\u00e1val lehet megadni, amelynek \u00e9rt\u00e9ke\n\ta kulcs. Ha ez a param\u00e9ter nincs megadva, akkor alap\u00e9rtelmezett kulcs ker\u00fcl felhaszn\u00e1l\u00e1sra.
encode.option-key.notrim=\ \ \ \ --notrim
encode.option-desc.notrim=\tMegadja, hogy a sz\u00f3k\u00f6z karaktereket el kell-e t\u00e1vol\u00edtani a megadott\n\tsz\u00f6veg elej\u00e9r\u0151l \u00e9s v\u00e9g\u00e9r\u0151l. Ha ez a param\u00e9ter meg van adva, akkor a \n\tmegadott \u00fagy lesz k\u00f3dolva, ahogy van.\n\tHa a param\u00e9ter nincs megadva, akkor a sz\u00f3k\u00f6z karakterek el lesznek  \n\tt\u00e1vol\u00edtva a megadott sz\u00f6veg elej\u00e9r\u0151l \u00e9s v\u00e9g\u00e9r\u0151l. 
encode.option-key.listCustom=\ \ \ \ --listCustom
encode.option-desc.listCustom=\tMegjelen\u00edti az egy\u00e9ni jelsz\u00f3titkos\u00edt\u00e1si inform\u00e1ci\u00f3kat\n\tJavaScript Object Notation (JSON) form\u00e1tumban. \n\tAz inform\u00e1ci\u00f3 a k\u00f6vetkez\u0151ket tartalmazza: \n\tname : az egy\u00e9ni jelsz\u00f3titkos\u00edt\u00e1si algoritmus neve \n\tfeaturename : a szolg\u00e1ltat\u00e1s neve\n\tdescription : az egy\u00e9ni jelsz\u00f3titkos\u00edt\u00e1s le\u00edr\u00e1sa
encode.option-key.keyring=\ \ \ \ --keyring=[keyring]
encode.option-desc.keyring=\tAdja meg az SAF kulcscsom\u00f3t, ahol az AES titkos\u00edt\u00e1si kulcs tal\u00e1lhat\u00f3.
encode.option-key.keyringType=\ \ \ \ --keyringType=[keyringType]
encode.option-desc.keyringType=\tAdja meg annak a kulcscsom\u00f3nak az SAF kulcscsom\u00f3t\u00edpus\u00e1t, ahol az AES titkos\u00edt\u00e1s\n\ttal\u00e1lhat\u00f3.
encode.option-key.keyLabel=\ \ \ \ --keyLabel=[keyLabel]
encode.option-desc.keyLabel=\tAdja meg az AES titkos\u00edt\u00e1si kulcs SAF tan\u00fas\u00edtv\u00e1ny\u00e1nak azonos\u00edt\u00f3j\u00e1t.



# -------- CREATE SSL CERTIFICATE OPTIONS --------------------------------#
# List of descriptive text for options. Use "\n\" for line continuations.
# The code provides no whitespace: begin keys with "\ \ \ \ " for leading
# whitespace, and begin descriptions with \t 
#------------------------------\n at 72 chars -------------------------\n\#
#------------------------------\n at 72 chars Leading "\ \ \ \ "-------\n\#
#------------------------------\n at 72 chars Leading "\t"-------------\n\#
sslCert.desc=\tAlap\u00e9rtelmezett SSL tan\u00fas\u00edtv\u00e1nyt hoz l\u00e9tre a kiszolg\u00e1l\u00f3 vagy \n\t\u00fcgyf\u00e9l konfigur\u00e1ci\u00f3 sz\u00e1m\u00e1ra. 
#Note to translator the word "createSSLCertificate" should not be translated
sslCert.usage.options=\t{0} createSSLCertificate '{--server=servername |--client=clientname'}\n\t--password[=jelsz\u00f3] [param\u00e9terek]
sslCert.required-key.server=\ \ \ \ --server=n\u00e9v
sslCert.required-desc.server=\tA kiszolg\u00e1l\u00f3, mely sz\u00e1m\u00e1ra a tan\u00fas\u00edtv\u00e1ny l\u00e9trehoz\u00e1sra ker\u00fcl.  Ez az argumentum\n\tnem haszn\u00e1lhat\u00f3 a --client argumentum haszn\u00e1latakor.
sslCert.required-key.client=\ \ \ \ --client=n\u00e9v
sslCert.required-desc.client=\tAz \u00fcgyf\u00e9l, amely sz\u00e1m\u00e1ra l\u00e9tre kell hozni a tan\u00fas\u00edtv\u00e1nyt.  Ez az argumentum\n\tnem haszn\u00e1lhat\u00f3 a --server argumentum haszn\u00e1latakor.
sslCert.required-key.password=\ \ \ \ --password[=pwd]
sslCert.required-desc.password=\tKulcst\u00e1rol\u00f3 jelsz\u00f3, minim\u00e1lisan {1} karakter.\n\tHa nincs \u00e9rt\u00e9k megadva, akkor a rendszer r\u00e1k\u00e9rdez.
sslCert.option-key.validity=\ \ \ \ --validity=nap
sslCert.option-desc.validity=\tA napok sz\u00e1ma, ameddig a tan\u00fas\ufffd\ufffdtv\u00e1ny \u00e9rv\u00e9nyes. Az alap\u00e9rtelmezett \u00e9rv\u00e9nyess\u00e9gi id\u0151szak:  \n\t{2}. A minim\u00e1lis \u00e9rv\u00e9nyess\u00e9gi id\u0151szak: {3}.
sslCert.option-key.subject=\ \ \ \ --subject=DN
sslCert.option-desc.subject=\tDN a tan\u00fas\u00edtv\u00e1ny t\u00e1rgya \u00e9s kibocs\u00e1t\u00f3ja. Az alap\u00e9rtelmezett DN a    \n\thosztn\u00e9ven alapul.
sslCert.option.addon=A tan\u00fas\u00edtv\u00e1ny {4} \u00e1ln\u00e9vvel ker\u00fcl l\u00e9trehoz\u00e1sra.\nA kulcsalgoritmus: {5}; az al\u00e1\u00edr\u00e1si algoritmus: {6}.\nHa tov\u00e1bbi vez\u00e9rl\u00e9si lehet\u0151s\u00e9gekre van sz\u00fcks\u00e9ge a tan\u00fas\u00edtv\u00e1ny l\u00e9trehoz\u00e1sa eset\u00e9ben, haszn\u00e1lja k\u00f6zvetlen\u00fcl a kulcseszk\u00f6zt.
sslCert.option-key.password.encoding=\ \ \ \ --passwordEncoding=[xor|aes]
sslCert.option-desc.password.encoding=\tMegadja a kulcst\u00e1rol\u00f3 jelsz\u00f3 k\u00f3dol\u00e1s\u00e1nak m\u00f3dj\u00e1t. A t\u00e1mogatott k\u00f3dol\u00e1sok:\n\txor \u00e9s aes. Az alap\u00e9rtelmezett k\u00f3dol\u00e1s az xor. \n\tA securityUtility encode --listCustom parancs haszn\u00e1lat\u00e1val megn\u00e9zheti,\n\thogy vannak-e tov\u00e1bbi t\u00e1mogatott egy\u00e9ni titkos\u00edt\u00e1sok.
sslCert.option-key.password.key=\ \ \ \ --passwordKey=[kulcs]
sslCert.option-desc.password.key=\tMegad egy kulcsot a kulcst\u00e1rol\u00f3 jelsz\u00f3 AES\n\tk\u00f3dol\u00e1s\u00e1hoz. Ez a karaktersorozat lesz kivonatolva titkos\u00edt\u00e1si kulcs el\u0151\u00e1ll\u00edt\u00e1s\u00e1hoz,\n\tamely a jelsz\u00f3 titkos\u00edt\u00e1s\u00e1ban \u00e9s visszafejt\u00e9s\u00e9ben ker\u00fcl felhaszn\u00e1l\u00e1sra. A kulcsot a\n\tkiszolg\u00e1l\u00f3 sz\u00e1m\u00e1ra a wlp.password.encryption.key meghat\u00e1roz\u00e1s\u00e1val lehet megadni,\n\tamelynek \u00e9rt\u00e9ke a kulcs. Ha ez a param\u00e9ter nincs megadva, akkor\n\taz alap\u00e9rtelmezett kulcs ker\u00fcl felhaszn\u00e1l\u00e1sra.

sslCert.option-key.createConfigFile=\ \ \ \ --createConfigFile=f\u00e1jl
sslCert.option-desc.createConfigFile=\tNem k\u00f6telez\u0151. A k\u00f3dr\u00e9szlet a megadott f\u00e1jlba ker\u00fcl ki\u00edr\u00e1sra\n\ta konzolk\u00e9perny\u0151 helyett. A f\u00e1jlt ezut\u00e1n fel lehet venni a\n\tserver.xml konfigur\u00e1ci\u00f3ba a megadott k\u00f3dr\u00e9szlet seg\u00edts\u00e9g\u00e9vel.

sslCert.option-key.keySize=\ \ \ \ --keySize=m\u00e9ret
sslCert.option-desc.keySize=\tTan\u00fas\u00edtv\u00e1nykulcs m\u00e9rete.  Az alap\u00e9rtelmezett kulcsm\u00e9ret: {7}.

sslCert.option-key.sigAlg=\ \ \ \ --sigAlg=signature algorithm
sslCert.option-desc.sigAlg=\tA tan\u00fas\u00edtv\u00e1ny al\u00e1\u00edr\u00e1si algoritmusa.\n\tAz alap\u00e9rtelmezett al\u00e1\u00edr\u00e1si algoritmus a k\u00f6vetkez\u0151: {8}.

sslCert.option-key.keyType=\ \ \ \ --keyType
sslCert.option-desc.keyType=\tNem k\u00f6telez\u0151. Alap\u00e9rtelmez\u00e9sben PKCS12 kulcst\u00e1rol\u00f3 ker\u00fcl el\u0151\u00e1ll\u00edt\u00e1sra. JKS\n\tkulcst\u00e1rol\u00f3 el\u0151\u00e1ll\u00edt\u00e1s\u00e1hoz adja meg a --keyType param\u00e9tert JKS\n\t\u00e9rt\u00e9kkel. Nem kell a param\u00e9tert megadni, ha PKCS12 kulcst\u00e1rol\u00f3\n\taz elv\u00e1rt.\n\tA PKCS12 sz\u00e1mos el\u0151nnyel rendelkezik: kiterjeszthet\u0151bb; er\u0151sebb kriptogr\u00e1fiai\n\talgoritmusokat t\u00e1mogat; \u00e9s sz\u00e9les k\u00f6r\u0171en elfogadott. A PKCS12 gyakran\n\taz a form\u00e1tum, amelyet a tan\u00fas\u00edtv\u00e1nyhat\u00f3s\u00e1gok biztos\u00edtanak tan\u00fas\u00edtv\u00e1nyok\n\tkiad\u00e1sakor.

sslCert.option-key.ext=\ \ \ \ --extInfo=tan\u00fas\u00edtv\u00e1ny kiterjeszt\u00e9si inform\u00e1ci\u00f3k
sslCert.option-desc.ext=\tA tan\u00fas\u00edtv\u00e1nyhoz hozz\u00e1adand\u00f3 tan\u00fas\u00edtv\u00e1ny kiterjeszt\u00e9si inform\u00e1ci\u00f3k.\n\tAz alap\u00e9rtelmezett kiterjeszt\u00e9s egy T\u00e1rgy alternat\u00edv neve bejegyz\u00e9s, amely\n\ta hosztnevet haszn\u00e1lja. Ez a kapcsol\u00f3 a Jave Keytool parancs -ext kapcsol\u00f3j\u00e1nak\n\t szintaxis\u00e1t k\u00f6veti. A kapcsol\u00f3 t\u00f6bbsz\u00f6r is haszn\u00e1lhat\u00f3 a parancshoz\n 
#line.

# -------- CREATE LTPA KEYS OPTIONS --------------------------------------#
# List of descriptive text for options. Use "\n\" for line continuations.
# The code provides no whitespace: begin keys with "\ \ \ \ " for leading
# whitespace, and begin descriptions with \t 
#------------------------------\n at 72 chars -------------------------\n\#
#------------------------------\n at 72 chars Leading "\ \ \ \ "-------\n\#
#------------------------------\n at 72 chars Leading "\t"-------------\n\#
# Note to translator: the words 'LTPA' and 'ltpa.keys' should not be translated 
createLTPAKeys.desc=\tLTPA kulcsk\u00e9szlet l\u00e9trehoz\u00e1sa a kiszolg\u00e1l\u00f3 sz\u00e1m\u00e1ra, vagy \n\tmegoszthat\u00f3an t\u00f6bb kiszolg\u00e1l\u00f3 sz\u00e1m\u00e1ra. Ha nincs megadva kiszolg\u00e1l\u00f3 vagy f\u00e1jl, akkor az ltpa.keys\n\tf\u00e1jl az aktu\u00e1lis munkak\u00f6nyvt\u00e1rba ker\u00fcl l\u00e9trehoz\u00e1sra.
#Note to translator the word "createLTPAKeys" should not be translated
createLTPAKeys.usage.options=\t{0} createLTPAKeys --password[=jelsz\u00f3] [param\u00e9terek]
createLTPAKeys.required-key.password=\ \ \ \ --password[=jelsz\u00f3]
createLTPAKeys.required-desc.password=\tLTPA kulcs jelsz\u00f3. Ha nincs \u00e9rt\u00e9k megadva, akkor a rendszer r\u00e1k\u00e9rdez.
createLTPAKeys.option-key.server=\ \ \ \ --server=n\u00e9v
createLTPAKeys.option-desc.server=\tA kiszolg\u00e1l\u00f3, amely sz\u00e1m\u00e1ra az LTPA kulcsok l\u00e9trehoz\u00e1sra ker\u00fclnek.\n\tEz az argumentum nem haszn\u00e1lhat\u00f3  --file argumentum haszn\u00e1latakor.
createLTPAKeys.option-key.file=\ \ \ \ --file=n\u00e9v
createLTPAKeys.option-desc.file=\tAz LTPA kulcsok be\u00edr\u00e1s\u00e1ra szolg\u00e1l\u00f3 f\u00e1jl. \n\tEz az argumentum nem haszn\u00e1lhat\u00f3  --server argumentum haszn\u00e1latakor.
createLTPAKeys.option-key.password.encoding=\ \ \ \ --passwordEncoding=[xor|aes]
createLTPAKeys.option-desc.password.encoding=\tMegadja az LTPA kulcs jelsz\u00f3 k\u00f3dol\u00e1s\u00e1nak m\u00f3dj\u00e1t a server.xml f\u00e1jlban.\n\tA t\u00e1mogatott k\u00f3dol\u00e1sok: xor \u00e9s aes. Az alap\u00e9rtelmezett k\u00f3dol\u00e1s az xor. \n\tA securityUtility encode --listCustom parancs haszn\u00e1lat\u00e1val megn\u00e9zheti,\n\thogy vannak-e tov\u00e1bbi t\u00e1mogatott egy\u00e9ni titkos\u00edt\u00e1sok.
createLTPAKeys.option-key.password.key=\ \ \ \ --passwordKey=[kulcs]
createLTPAKeys.option-desc.password.key=\tMegad egy, az LTPA kulcs jelsz\u00f3 AES k\u00f3dol\u00e1sakor haszn\u00e1lt kulcsot.\n\tEz a karaktersorozat lesz kivonatolva titkos\u00edt\u00e1si kulcs el\u0151\u00e1ll\u00edt\u00e1s\u00e1hoz,\n\tamely a jelsz\u00f3 titkos\u00edt\u00e1s\u00e1ban \u00e9s visszafejt\u00e9s\u00e9ben ker\u00fcl felhaszn\u00e1l\u00e1sra. A kulcsot a\n\tkiszolg\u00e1l\u00f3 sz\u00e1m\u00e1ra a wlp.password.encryption.key meghat\u00e1roz\u00e1s\u00e1val lehet megadni,\n\tamelynek \u00e9rt\u00e9ke a kulcs. Ha ez a param\u00e9ter nincs megadva, akkor\n\taz alap\u00e9rtelmezett kulcs ker\u00fcl felhaszn\u00e1l\u00e1sra.

# -------- tlsProfiler OPTIONS ------------------------------------------------#
# List of descriptive text for options. Use "\n\" for line continuations.
# The code provides no whitespace: begin keys with "\ \ \ \ " for leading
# whitespace, and begin descriptions with \t 
#------------------------------\n at 72 chars -------------------------\n\#
#------------------------------\n at 72 chars Leading "\ \ \ \ "-------\n\#
#------------------------------\n at 72 chars Leading "\t"-------------\n\#
tlsProfiler.desc=\tTesztelje a c\u00e9lhoszt \u00e9s -portok kompatibilit\u00e1s\u00e1t az el\u00e9rhet\u0151 TLS protokollokkal \u00e9s rejtjelk\u00e9szletekkel.
tlsProfiler.usage.options=\t{0} tlsProfiler [param\u00e9terek]
tlsProfiler.required-key.port=\ \ \ \ --port
tlsProfiler.required-desc.port=\tAdja meg a portot.
tlsProfiler.required-key.host=\ \ \ \ --host
tlsProfiler.required-desc.host=\tAdja meg a hosztot.
tlsProfiler.option-key.file=\ \ \ \ --file
tlsProfiler.option-desc.file=\tNem k\u00f6telez\u0151. Az eredm\u00e9ny a megadott f\u00e1jlba ker\u00fcl ki\u00edr\u00e1sra \n\ta konzolk\u00e9perny\u0151 helyett.
tlsProfiler.option-key.verbose=\ \ \ \ --verbose
tlsProfiler.option-desc.verbose=\tA nem biztons\u00e1gos protokollokkal kapcsolatos tov\u00e1bbi inform\u00e1ci\u00f3k tartalmaz\u00e1sa.

# -------- CONFIGURE FIPS OPTIONS --------------------------------------#
# List of descriptive text for options. Use "\n\" for line continuations.
# The code provides no whitespace: begin keys with "\ \ \ \ " for leading
# whitespace, and begin descriptions with \t 
#------------------------------\n at 72 chars -------------------------\n\#
#------------------------------\n at 72 chars Leading "\ \ \ \ "-------\n\#
#------------------------------\n at 72 chars Leading "\t"-------------\n\# 
configureFIPS.desc=\tA FIPS 140-3 konfigur\u00e1l\u00e1sa a Java-telep\u00edt\u00e9s alapj\u00e1n, amelyet a JAVA_HOME, JRE_HOME vagy WLP_DEFAULT_JAVA_HOME k\u00f6rnyezeti v\u00e1ltoz\u00f3k \u00e1ltal meghat\u00e1rozott telep\u00edt\u00e9s, ebben a sorrendben. Ha nem volt be\u00e1ll\u00edtva, akkor a FIPS 140-3 van be\u00e1ll\u00edtva a securityUtility parancs futtat\u00e1s\u00e1hoz haszn\u00e1lt JVM alapj\u00e1n ker\u00fcl be\u00e1ll\u00edt\u00e1sra. A parancs be\u00e1ll\u00edtja a FIPS 140-3 szabv\u00e1nyt a IBM Semeru Runtimes vagy a IBM SDK sz\u00e1m\u00e1ra, vagy hiba\u00fczenetet ad vissza, ha egyiket sem siker\u00fclt meghat\u00e1rozni.\n\n\tA IBM Semeru Runtimes: L\u00e9trehoz egy f\u00e1jlt, amely a FIPS 140-3 egy\u00e9ni profilt tartalmazza a k\u00f6vetkez\u0151 eszk\u00f6z\u00f6k sz\u00e1m\u00e1ra az alkalmaz\u00e1s sz\u00e1m\u00e1ra, amely kib\u0151v\u00edti a Liberty FIPS140-3-Liberty profilt, amely kiterjeszti a IBM Semeru Runtimes-t FIPS140-3-Strongly-Enforced profil. \
    Tov\u00e1bb\u00e1 l\u00e9trehozza vagy friss\u00edti a default.env, server.env, vagy a client.env f\u00e1jlt a FIPS 140-3 enged\u00e9lyez\u00e9s\u00e9hez az al\u00e1bbi param\u00e9terek be\u00e1ll\u00edt\u00e1s\u00e1val ENABLE_FIPS140_3 k\u00f6rnyezeti v\u00e1ltoz\u00f3t az egy\u00e9ni profilf\u00e1jl el\u00e9r\u00e9si \u00fatvonal\u00e1ra.\n\n\tA IBM SDK eset\u00e9ben: L\u00e9trehozza vagy friss\u00edti a default.env, server.env, vagy client.env f\u00e1jlt a k\u00f6vetkez\u0151kre a FIPS 140-3 enged\u00e9lyez\u00e9se a ENABLE_FIPS140_3 k\u00f6rnyezet be\u00e1ll\u00edt\u00e1s\u00e1val v\u00e1ltoz\u00f3t true \u00e9rt\u00e9kre \u00e1ll\u00edtja.

configureFIPS.usage.options=\t{0} configureFIPS [opci\u00f3k]

configureFIPS.option-key.1.server=\ \ \ \ --server =n\u00e9v

configureFIPS.option-desc.1.server=\tKiszolg\u00e1l\u00f3, amelyhez a FIPS 140-3 konfigur\u00e1l\u00e1sa sz\u00fcks\u00e9ges. Ha ez az \u00e9rt\u00e9k nem \u00e9s nincs \u00fcgyf\u00e9l megadva, akkor a FIPS 140-3 van konfigur\u00e1lva minden \u00fcgyf\u00e9l, kiszolg\u00e1l\u00f3 \u00e9s parancs eset\u00e9ben.

configureFIPS.option-key.2.client=\ \ \ \ --client =n\u00e9v

configureFIPS.option-desc.2.client=\t\u00dcgyf\u00e9l, amelyhez a FIPS 140-3 szabv\u00e1nyt konfigur\u00e1lni kell. Ha ez az \u00e9rt\u00e9k nem \u00e9s nincs megadva kiszolg\u00e1l\u00f3, akkor a FIPS 140-3 van konfigur\u00e1lva minden \u00fcgyf\u00e9l, kiszolg\u00e1l\u00f3 \u00e9s parancs eset\u00e9ben.

configureFIPS.option-key.3.customProfileFile=\ \ \ \ --customProfileFile=name

configureFIPS.option-desc.3.customProfileFile=\tA f\u00e1jl, amelybe a IBM Semeru Runtimes FIPS 140-3 egy\u00e9ni profilj\u00e1t \u00edrja.\n\tHa ez az \u00e9rt\u00e9k nincs megadva, akkor a f\u00e1jl a k\u00f6vetkez\u0151 n\u00e9vvel j\u00f6n l\u00e9tre a FIPS140-3-Liberty-Application.properties k\u00f6nyvt\u00e1rban az etc k\u00f6nyvt\u00e1rban tal\u00e1lhat\u00f3 k\u00f6nyvt\u00e1r\u00e1ban tal\u00e1lhat\u00f3. Ha a kiszolg\u00e1l\u00f3 vagy az \u00fcgyf\u00e9l opci\u00f3t haszn\u00e1ltuk, akkor a f\u00e1jl a security/resources k\u00f6nyvt\u00e1rban j\u00f6n l\u00e9tre a megadott kiszolg\u00e1l\u00f3hoz vagy \u00fcgyf\u00e9lhez.\n\n\tA f\u00e1jl neve, a kiterjeszt\u00e9s n\u00e9lk\u00fcl, a f\u00e1jlkiterjeszt\u00e9s l\u00e9trehoz\u00e1s\u00e1hoz haszn\u00e1lt egy\u00e9ni profil neve; ez b\u0151v\u00edti a Liberty FIPS140-3-Liberty profilt.\n\tA f\u00e1jln\u00e9v csak alfanumerikus karaktereket \u00e9s k\u00f6t\u0151jeleket (-) tartalmazhat, al\u00e1h\u00faz\u00e1sokat (_) \u00e9s \
    pontokat (.). A f\u00e1jl alapneve nem lehet FIPS140-3-Liberty.\n\n\tT\u00f6bb f\u00e1jl is megadhat\u00f3 ezzel az opci\u00f3val a \u00fatvonal elv\u00e1laszt\u00f3jelek haszn\u00e1lat\u00e1val. A Windows eset\u00e9ben az \u00fatvonal elv\u00e1laszt\u00f3 jel egy pontosvessz\u0151 (;). Unix-alap\u00fa rendszerek eset\u00e9n az \u00fatvonal elv\u00e1laszt\u00f3 jel a kett\u0151spont (:). Minden egy\u00e9ni profil a megadott sorrendben b\u0151v\u00edti egym\u00e1st.

configureFIPS.option-key.4.disable=\ \ \ \ --disable

configureFIPS.option-desc.4.disable=\tA FIPS 140-3 letilt\u00e1sa a ENABLE_FIPS140_3 k\u00f6rnyezet be\u00e1ll\u00edt\u00e1s\u00e1val v\u00e1ltoz\u00f3t false \u00e9rt\u00e9kre \u00e1ll\u00edtsuk. Ez az opci\u00f3 az \u00fcgyf\u00e9l \u00e9s a kiszolg\u00e1l\u00f3 eset\u00e9n haszn\u00e1lhat\u00f3 opci\u00f3kkal adhat\u00f3 meg a FIPS 140-3 letiltand\u00f3 \u00fcgyf\u00e9l vagy kiszolg\u00e1l\u00f3.\n\tEllenkez\u0151 esetben letiltja a FIPS 140-3 szabv\u00e1nyt az \u00f6sszes \u00fcgyf\u00e9l, kiszolg\u00e1l\u00f3 \u00e9s parancsok, kiv\u00e9ve azokat az \u00fcgyfeleket \u00e9s kiszolg\u00e1l\u00f3kat, amelyek egyedileg enged\u00e9lyezve vannak.
