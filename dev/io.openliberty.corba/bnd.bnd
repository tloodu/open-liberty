-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0

Bundle-Name: CORBA and RMI APIs
Bundle-Description: OMG CORBA and Java RMI APIs used by the Java ORB
Bundle-SymbolicName: io.openliberty.corba.2.4

Import-Package: \
  javax.rmi, \
  javax.rmi.CORBA, \
  org.omg.*

Export-Package: \
  javax.rmi, \
  javax.rmi.CORBA, \
  org.omg.*


publish.wlp.jar.suffix: dev/api/spec

instrument.disabled: true

-buildpath: \
  io.openliberty.yoko.rmi.spec;version=latest, \
  io.openliberty.yoko.spec.corba;version=latest  
