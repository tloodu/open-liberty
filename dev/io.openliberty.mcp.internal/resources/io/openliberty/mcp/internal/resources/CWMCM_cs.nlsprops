# Used for server logging
# {0} = Method
# {1} = RequestURI
# {2} = RequestQuery
# {3} = ExceptionMessage
CWMCM0015E.unexpected.server.error.exception=CWMCM0015E: Neo\u010dek\u00e1van\u00e1 chyba serveru. Metoda= {0} RequestURI={1 } RequestQuery={2 }, V\u00fdjimka: {3}
CWMCM0015E.unexpected.server.error.exception.explanation=P\u0159i zpracov\u00e1n\u00ed po\u017eadavku do\u0161lo k neo\u010dek\u00e1van\u00e9 chyb\u011b serveru. Po\u017eadavek nelze dokon\u010dit.
CWMCM0015E.unexpected.server.error.exception.useraction=Zkontrolujte protokol zpr\u00e1v message.log a identifikujte probl\u00e9m.

# Used for server logging
# {0} = ExceptionMessage
CWMCM0016E.error.sending.response.exception=CWMCM0016E: Neo\u010dek\u00e1van\u00e1 chyba serveru. V\u00fdjimka: {0}
CWMCM0016E.error.sending.response.exception.explanation=P\u0159i pokusu o odesl\u00e1n\u00ed odpov\u011bdi do\u0161lo k chyb\u011b.
CWMCM0016E.error.sending.response.exception.useraction=Nen\u00ed pot\u0159eba \u017e\u00e1dn\u00e1 akce.

# Used as part of a response to a client
# do not translate jsonrpc
# {0} = jsonrpc value
jsonrpc.exception.validation.invalid.version=Pole jsonrpc mus\u00ed b\u00fdt p\u0159\u00edtomno. V sou\u010dasn\u00e9 dob\u011b je podporov\u00e1n 2.0 pouze JSONRPC.

# Used as part of a response to a client
jsonrpc.validation.empty.method=Pole metody je pr\u00e1zdn\u00e9.

# Used as part of a response to a client
# {0} = id value
jsonrpc.exception.validation.empty.string.id=Pole id je neplatn\u00e9. ID nesm\u00ed b\u00fdt pr\u00e1zdn\u00e9, pokud je zad\u00e1n \u0159et\u011bzec.

# Used as part of a response to a client
jsonrpc.exception.validation.invalid.id.type=Typ id nen\u00ed p\u0159ijateln\u00fd typ. ID mus\u00ed b\u00fdt \u0159et\u011bzec nebo cel\u00e9 \u010d\u00edslo.

# Used for server logging
# do not translate MCP
# {0} = The  qualified name of the tool
# {1} = corresponding argument name
# {2} = corresponding argument type
CWMCM0017E.missing.toolarg.defaultvalue.converter=CWMCM0017E: Argument \u201e {1} \u201c metody n\u00e1stroje MCP \u201e {0} \u201c nem\u00e1 p\u0159evad\u011b\u010d, kter\u00fd by zm\u011bnil jeho v\u00fdchoz\u00ed hodnotu na objekt typu \u201e {2} \u201c.
CWMCM0017E.missing.toolarg.defaultvalue.converter.explanation=Jeden nebo v\u00edce argument\u016f m\u00e1 v\u00fdchoz\u00ed hodnoty bez odpov\u00eddaj\u00edc\u00edho p\u0159evad\u011b\u010de, kter\u00fd by p\u0159evedl v\u00fdchoz\u00ed hodnotu na typ argumentu.
CWMCM0017E.missing.toolarg.defaultvalue.converter.useraction=Vytvo\u0159te vlastn\u00ed implementaci p\u0159evad\u011b\u010de pro typ argumentu n\u00e1stroje.

# Used for server logging
# do not translate MCP
# {0} = The qualified name of the tool
# {1} = Parameter name
CWMCM0018E.generic.arguments=CWMCM0018E: Argument \u201e {1} \u201c metody n\u00e1stroje MCP \u201e {0} \u201c obsahuje nepodporovan\u00e9 komponenty, jako jsou \u201e TypeVariable, Wildcard\u201c a \u201e GenericArrayType \u201c.
CWMCM0018E.generic.arguments.explanation=Byly poskytnuty argumenty n\u00e1stroje MCP, ale nejsou podporov\u00e1ny. 
CWMCM0018E.generic.arguments.useraction=Poskytn\u011bte argumenty, kter\u00e9 neobsahuj\u00ed obecn\u00e9 komponenty.

# Used for encoder logging
# {0} = The encoder class name
# {1} = The tool name
# {2} = The exception
CWMCM0019E.error.encoding.element=CWMCM0019E: Kod\u00e9r {0} vyhodil v\u00fdjimku p\u0159i k\u00f3dov\u00e1n\u00ed v\u00fdsledku n\u00e1stroje {1}. V\u00fdjimka: {2}
CWMCM0019E.error.encoding.element.explanation=Kod\u00e9r vyhodil v\u00fdjimku p\u0159i k\u00f3dov\u00e1n\u00ed v\u00fdsledku n\u00e1stroje. V\u00fdjimka m\u016f\u017ee b\u00fdt zp\u016fsobena probl\u00e9mem s kod\u00e9rem nebo t\u00edm, \u017ee n\u00e1stroj vr\u00e1til neo\u010dek\u00e1van\u00fd v\u00fdsledek.
CWMCM0019E.error.encoding.element.useraction=Zkontrolujte protokol zpr\u00e1v message.log a identifikujte probl\u00e9m.

# Used for server logging
# do not translate MCP
# {0} = The qualified name of the tool method, or the tool name
# {1} = corresponding argument name
# {2} = corresponding argument type
# {3} = corresponding default value
# {4} = ExceptionMessage
CWMCM0020E.defaultvalue.conversion.error=CWMCM0020E: V\u00fdchoz\u00ed hodnota argumentu \u201e {1} \u201c n\u00e1stroje MCP \u201e {0} \u201c nelze p\u0159ev\u00e9st na typ \u201e {2} \u201c. Hodnota je {3}. Chyba je \u201e {4} \u201c (Chyba p\u0159i na\u010d\u00edt\u00e1n\u00ed souboru: Chyba p\u0159i na\u010d\u00edt\u00e1n\u00ed souboru: Chyba p\u0159i na\u010d\u00edt\u00e1n\u00ed souboru:
CWMCM0020E.defaultvalue.conversion.error.explanation=Argument m\u00e1 v\u00fdchoz\u00ed hodnotu, kterou nelze p\u0159ev\u00e9st na typ argumentu. Tento probl\u00e9m m\u016f\u017ee nastat, pokud je v\u00fdchoz\u00ed hodnota nulov\u00e1, m\u00e1 neplatn\u00fd form\u00e1t nebo je mimo rozsah pro c\u00edlov\u00fd typ.
CWMCM0020E.defaultvalue.conversion.error.useraction=Zajist\u011bte, aby v\u00fdchoz\u00ed hodnota byla platn\u00e1 pro typ argumentu. Zajist\u011bte, aby v\u00fdchoz\u00ed hodnota nebyla nulov\u00e1. Pro typy znak\u016f zadejte p\u0159esn\u011b jeden znak. U \u010d\u00edseln\u00fdch typ\u016f zadejte platn\u00e9 \u010d\u00edslo v rozsahu dan\u00e9ho typu.

# Used for server logging
# do not translate MCP
# {0} = The default value string
CWMCM0021E.defaultvalue.character.invalid.length=CWMCM0021E: V\u00fdchoz\u00ed hodnota znaku mus\u00ed b\u00fdt p\u0159esn\u011b jeden znak, ale byla {0}
CWMCM0021E.defaultvalue.character.invalid.length.explanation=Byla zad\u00e1na v\u00fdchoz\u00ed hodnota pro argument typu Character, ale neobsahuje p\u0159esn\u011b jeden znak. Argumenty typu znak mus\u00ed m\u00edt jeden znakov\u00fd \u0159et\u011bzec.
CWMCM0021E.defaultvalue.character.invalid.length.useraction=Zajist\u011bte, aby v\u00fdchoz\u00ed hodnota argumentu typu Character byla \u0159et\u011bzec s p\u0159esn\u011b jedn\u00edm znakem.

# Used for server logging
# do not translate MCP
# {0} = The cursor value string
CWMCM0022E.invalid.cursor.value=CWMCM0022E: Hodnota kurzoru "{0}" je neplatn\u00e1.
CWMCM0022E.invalid.cursor.value.explanation=Hodnota kurzoru byla zad\u00e1na jako parametr p\u0159\u00edkazu tool/list, ale tato hodnota je neplatn\u00e1.
CWMCM0022E.invalid.cursor.value.useraction=Ujist\u011bte se, \u017ee hodnota kurzoru je zad\u00e1na p\u0159esn\u011b tak, jak byla vr\u00e1cena z p\u0159edchoz\u00edho vol\u00e1n\u00ed n\u00e1stroje/seznamu.

# Used for server logging
# do not translate MCP
# {0} = The name of the tool 
# {1} = The qualified name of the tool
CWMCM0023E.invalid.length.tool.name=CWMCM0023E: N\u00e1zev n\u00e1stroje {0} pro metodu n\u00e1stroje MCP {1} nen\u00ed platn\u00fd. N\u00e1zvy n\u00e1stroj\u016f mus\u00ed m\u00edt d\u00e9lku od 1 do 128 znak\u016f v\u010detn\u011b.
CWMCM0023E.invalid.length.tool.name.explanation=N\u00e1zev n\u00e1stroje nen\u00ed v souladu se specifikac\u00ed MCP pro n\u00e1zvy. N\u00e1zvy mus\u00ed m\u00edt d\u00e9lku od 1 do 128 znak\u016f v\u010detn\u011b.
CWMCM0023E.invalid.length.tool.name.useraction=Ujist\u011bte se, \u017ee n\u00e1zvy n\u00e1stroj\u016f maj\u00ed d\u00e9lku od 1 do 128 znak\u016f v\u010detn\u011b.

# Used for server logging
# do not translate MCP
# {0} = The name of the tool
# {1} = The qualified name of the tool
CWMCM0024E.invalid.character.tool.name=CWMCM0024E: N\u00e1zev n\u00e1stroje {0} pro metodu n\u00e1stroje MCP {1} nen\u00ed platn\u00fd. N\u00e1zvy n\u00e1stroj\u016f mohou obsahovat pouze znaky ASCII, \u010d\u00edslice, podtr\u017e\u00edtka nebo poml\u010dky.
CWMCM0024E.invalid.character.tool.name.explanation=N\u00e1zev n\u00e1stroje nen\u00ed v souladu se specifikac\u00ed MCP pro n\u00e1zvy. N\u00e1zvy mohou obsahovat pouze znaky ASCII, \u010d\u00edslice, podtr\u017e\u00edtka, poml\u010dky a \u017e\u00e1dn\u00e9 jin\u00e9 speci\u00e1ln\u00ed znaky.
CWMCM0024E.invalid.character.tool.name.useraction=Ujist\u011bte se, \u017ee n\u00e1zvy n\u00e1stroj\u016f obsahuj\u00ed pouze znaky ASCII, \u010d\u00edslice, podtr\u017e\u00edtka nebo poml\u010dky.

