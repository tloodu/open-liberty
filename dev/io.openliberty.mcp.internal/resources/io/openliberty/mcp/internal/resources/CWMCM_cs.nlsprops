# Used as exception message
# Do not translate MCP
# {0} = The name of the tool
CWMCM0029E.invalid.length.tool.name=CWMCM0029E: {0} N\u00e1zev n\u00e1stroje MCP nen\u00ed platn\u00fd. N\u00e1zvy n\u00e1stroj\u016f mus\u00ed m\u00edt d\u00e9lku od 1 do 128 znak\u016f v\u010detn\u011b.
CWMCM0029E.invalid.length.tool.name.explanation=N\u00e1zev n\u00e1stroje nen\u00ed v souladu se specifikac\u00ed MCP pro n\u00e1zvy. N\u00e1zvy mus\u00ed m\u00edt d\u00e9lku od 1 do 128 znak\u016f v\u010detn\u011b.
CWMCM0029E.invalid.length.tool.name.useraction=Ujist\u011bte se, \u017ee n\u00e1zvy n\u00e1stroj\u016f maj\u00ed d\u00e9lku od 1 do 128 znak\u016f v\u010detn\u011b.

# Used as exception message
# Do not translate MCP
# {0} = The name of the tool
CWMCM0030E.blank.arguments=CWMCM0030E: Nelze p\u0159idat argument s pr\u00e1zdn\u00fdm n\u00e1zvem do n\u00e1stroje MCP ( {0} ).
CWMCM0030E.blank.arguments.explanation=Ka\u017ed\u00fd argument n\u00e1stroje MCP mus\u00ed m\u00edt nenulov\u00fd n\u00e1zev. 
CWMCM0030E.blank.arguments.useraction=Zadejte nepr\u00e1zdn\u00e9 n\u00e1zvy pro v\u0161echny argumenty n\u00e1stroje.

# Used as exception message
# Do not translate MCP
# {0} = The name of the tool
# {1} = The name of the argument
# {2} = The type of the argument
CWMCM0031E.missing.toolarg.defaultvalue.converter=CWMCM0031E: Argument \u201e {1} \u201c n\u00e1stroje MCP \u201e {0} \u201c nem\u00e1 p\u0159evodn\u00edk, kter\u00fd by zm\u011bnil jeho v\u00fdchoz\u00ed hodnotu na objekt typu \u201e {2} \u201c.
CWMCM0031E.missing.toolarg.defaultvalue.converter.explanation=Jeden nebo v\u00edce argument\u016f m\u00e1 v\u00fdchoz\u00ed hodnoty bez odpov\u00eddaj\u00edc\u00edho p\u0159evad\u011b\u010de, kter\u00fd by p\u0159evedl v\u00fdchoz\u00ed hodnotu na typ argumentu.
CWMCM0031E.missing.toolarg.defaultvalue.converter.useraction=Vytvo\u0159te vlastn\u00ed implementaci p\u0159evad\u011b\u010de pro typ argumentu n\u00e1stroje.

# Used as exception message
# Do not translate MCP
# {0} = The name of the tool
# {1} = The name of the argument
CWMCM0032E.duplicate.argument.name=CWMCM0032E: Nelze p\u0159idat druh\u00fd argument s n\u00e1zvem \u201e {1} \u201c do n\u00e1stroje MCP \u201e {0} \u201c.
CWMCM0032E.duplicate.argument.name.explanation=Ka\u017ed\u00fd argument n\u00e1stroje MCP mus\u00ed m\u00edt jin\u00e9 jm\u00e9no.
CWMCM0032E.duplicate.argument.name.useraction=Ka\u017ed\u00e9mu argumentu n\u00e1stroje p\u0159i\u0159a\u010fte jin\u00e9 jm\u00e9no.

# Used for server logging
# {0} = Method
# {1} = RequestURI
# {2} = RequestQuery
# {3} = ExceptionMessage
CWMCM0033A.forbidden.error=CWMCM0033A: Zak\u00e1zan\u00fd po\u017eadavek. Metoda= {0} RequestURI={1 } RequestQuery={2 }, V\u00fdjimka: {3}
CWMCM0033A.forbidden.error.explanation=Byla pod\u00e1na \u017e\u00e1dost, ale u\u017eivatel nem\u00e1 opr\u00e1vn\u011bn\u00ed ji podat.
CWMCM0033A.forbidden.error.useraction=Ujist\u011bte se, \u017ee po\u017eadavek vol\u00e1 opr\u00e1vn\u011bn\u00fd u\u017eivatel.
