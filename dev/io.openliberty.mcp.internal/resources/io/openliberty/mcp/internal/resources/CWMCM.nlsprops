#CMVCPATHNAME N/A
#COMPONENTPREFIX CWMCM
#COMPONENTNAMEFOR CWMCM MCP Server
#NLS_ENCODING=UNICODE
#NLS_MESSAGEFORMAT_NONE
#ISMESSAGEFILE true

# Used for server logging
# do not translate MCP
# {0} = The qualified name of the tool
CWMCM0001E.blank.arguments=CWMCM0001E: The {0} MCP tool method has one or more arguments with blank names.
CWMCM0001E.blank.arguments.explanation=MCP Tool arguments were provided but they had missing names. Each argument to a tool method must have a name.
CWMCM0001E.blank.arguments.useraction=Provide non-empty values for all required arguments.

# Used for server logging
# do not translate MCP
# {0} = The  qualified name of the tool
# {1} = corresponding argument name
CWMCM0002E.duplicate.arguments=CWMCM0002E: The {0} MCP tool method has more than one argument named {1}.
CWMCM0002E.duplicate.arguments.explanation=One or more arguments have the same name. Each argument of an MCP tool method must have a different name.
CWMCM0002E.duplicate.arguments.useraction=Give each tool argument a different name.

# Used for server logging
# do not translate MCP
# {0} = The qualified name of the tool
CWMCM0003E.missing.tool.argument.name=CWMCM0003E: The {0} MCP tool method has one or more arguments without a name specified.
CWMCM0003E.missing.tool.argument.name.explanation=One or more Tool argument names were not provided for MCP Tools.
CWMCM0003E.missing.tool.argument.name.useraction=Either add a name to the @ToolArg annotation, or to add the -parameters compiler option to use the parameter name.

# Used for server logging
# do not translate MCP
# {0} = The list of qualified names of the tool
# {1} = The list of duplicate methods
CWMCM0004E.duplicate.tools=CWMCM0004E: There are multiple MCP tool methods named {0}. The methods are {1}.
CWMCM0004E.duplicate.tools.explanation=One or more MCP Tool names occurred multiple times. The server expects one name per tool for uniqueness.
CWMCM0004E.duplicate.tools.useraction=Only provide a unique name for each MCP Tool.

# Used for server logging
# do not translate MCP
CWMCM0005E.validation.error=CWMCM0005E: There are one or more MCP validation errors. Check logs for more details.
CWMCM0005E.validation.error.explanation=The application cannot be started because there are MCP validation errors.
CWMCM0005E.validation.error.useraction=Check logs for more details.

# Used for server logging
# do not translate MCP
# {0} = The fully qualified method name
# {1} = The parameter type simple name
CWMCM0006E.duplicate.special.arguments=CWMCM0006E: The {0} MCP Tool has more than one parameter with the {1} type. Use only one {1} parameter in each Tool method.
CWMCM0006E.duplicate.special.arguments.explanation=One or more special arguments occurred multiple times, only one is expected.
CWMCM0006E.duplicate.special.arguments.useraction=Remove the extra instances.

# Used for server logging
# {0} = The fully qualified method name
# {1} = The parameter type simple name
CWMCM0007E.invalid.arguments=CWMCM0007E: The {0} MCP Tool has a parameter of type {1} which is not a recognized special argument type and does not have a `@ToolArg` annotation.
CWMCM0007E.invalid.arguments.explanation=One or more parameters were not annotated as tool arguments and are not recognized special argument types.
CWMCM0007E.invalid.arguments.useraction=Check whether you have the correct class imported for your argument, or you meant to include @ToolArg.

# Used as part of a response to a client
# {0} = Request id
invalid.request.params=A request with the {0} ID is in progress.

# Used as part of a response to a client
# do not translate GET
get.disallowed=GET requests are not supported.

# Used for server logging
# {0} = tool name
# {1} = exception details
CWMCM0010E.internal.server.error.detailed=CWMCM0010E: The {0} tool method threw an unexpected exception. The exception is {1}
CWMCM0010E.internal.server.error.detailed.explanation=The tool method threw an unexpected exception.
CWMCM0010E.internal.server.error.detailed.useraction=Review the server message.log and FFDC logs to identify the problem.

# Used as part of a response to a client
internal.server.error=An internal server error occurred while running the tool.

# Used for server logging
# do not translate bean
# {0} = bean error details
# {1} = tool name
CWMCM0012E.bean.release.fail=CWMCM0012E: An error occurred when releasing the CDI bean after calling the {1} tool. The error is: {0}
CWMCM0012E.bean.release.fail.explanation=When calling a tool method, an instance of the CDI bean that declares the method is acquired before calling the method and released afterwards. An error occurred when releasing the bean instance.
CWMCM0012E.bean.release.fail.useraction=Review the server message.log and FFDC logs to identify the problem.

# Used for client response
# do not translate MCP-Protocol-Version, MCP
# {0} = List of supported MCP-Protocol-Version values
unsupported.mcp.http.version=An unsupported MCP-Protocol-Version header was provided. Supported values: {0}

# Used as part of a response to a client
# {0} = Method
# {1} = RequestURI
# {2} = RequestQuery
unexpected.server.error=Unexpected Server Error. Method={0} RequestURI={1} RequestQuery={2}

# Used for server logging
# {0} = Method
# {1} = RequestURI
# {2} = RequestQuery
# {3} = ExceptionMessage
CWMCM0015E.unexpected.server.error.exception=CWMCM0015E: Unexpected Server Error. Method={0} RequestURI={1} RequestQuery={2}, Exception: {3}
CWMCM0015E.unexpected.server.error.exception.explanation=An unexpected server error occurred while processing the request. The request cannot be completed.
CWMCM0015E.unexpected.server.error.exception.useraction=Review the server message.log and FFDC logs to identify the problem.

# Used for server logging
# {0} = ExceptionMessage
CWMCM0016E.error.sending.response.exception=CWMCM0016E: Unexpected Server Error. Exception: {0}
CWMCM0016E.error.sending.response.exception.explanation=An error occurred while trying to send the response.
CWMCM0016E.error.sending.response.exception.useraction=No action is required.

# Used as part of a response to a client
# do not translate jsonrpc
# {0} = jsonrpc value
jsonrpc.exception.validation.invalid.version=The jsonrpc field must be present. Only JSONRPC 2.0 is currently supported.

# Used as part of a response to a client
jsonrpc.validation.empty.method=The method field is empty.

# Used as part of a response to a client
# {0} = id value
jsonrpc.exception.validation.empty.string.id=The id field is invalid. The id must not be blank if a string is provided.

# Used as part of a response to a client
jsonrpc.exception.validation.invalid.id.type=The id type is not an acceptable type. The id must be a string or integer.

# Used for server logging
# do not translate MCP
# {0} = The  qualified name of the tool
# {1} = corresponding argument name
# {2} = corresponding argument type
CWMCM0017E.missing.toolarg.defaultvalue.converter=CWMCM0017E: The {1} argument of the {0} MCP tool method does not have a converter to change its default value into an object of type {2}.
CWMCM0017E.missing.toolarg.defaultvalue.converter.explanation=One or more arguments have default values without a matching converter to convert the default value to the argument's type.
CWMCM0017E.missing.toolarg.defaultvalue.converter.useraction=Create a custom converter implementation for the tool argument's type.

# Used for server logging
# do not translate MCP
# {0} = The qualified name of the tool
# {1} = Parameter name
CWMCM0018E.generic.arguments=CWMCM0018E: The {1} argument of the {0} MCP tool method contains unsupported components such as TypeVariable, Wildcard, GenericArrayType.
CWMCM0018E.generic.arguments.explanation=MCP Tool arguments were provided but they are not supported. 
CWMCM0018E.generic.arguments.useraction=Provide arguments that do not have generic components.

# Used for encoder logging
# {0} = The encoder class name
# {1} = The tool name
# {2} = The exception
CWMCM0019E.error.encoding.element=CWMCM0019E: The {0} encoder threw an exception while encoding the result of the {1} tool. The exception is {2}
CWMCM0019E.error.encoding.element.explanation=The encoder threw an exception while encoding the result of the tool. The exception might be due to a problem with the encoder, or because the tool returned an unexpected result.
CWMCM0019E.error.encoding.element.useraction=Review the server message.log and FFDC logs to identify the problem.

# Used for server logging
# do not translate MCP
# {0} = The qualified name of the tool method, or the tool name
# {1} = corresponding argument name
# {2} = corresponding argument type
# {3} = corresponding default value
# {4} = ExceptionMessage
CWMCM0020E.defaultvalue.conversion.error=CWMCM0020E: The default value of the {1} argument of the {0} MCP tool cannot be converted to the {2} type. The value is {3}. The error is {4}.
CWMCM0020E.defaultvalue.conversion.error.explanation=An argument has a default value that cannot be converted to the argument's type. This problem might occur if the default value is null, has an invalid format, or is out of range for the target type.
CWMCM0020E.defaultvalue.conversion.error.useraction=Ensure that the default value is valid for the argument's type. Ensure the default value is not null. For character types, provide exactly one character. For numeric types, provide a valid number within the type's range.

# Used for server logging
# do not translate MCP
# {0} = The default value string
CWMCM0021E.defaultvalue.character.invalid.length=CWMCM0021E: A character default value must be exactly one character, but was {0}
CWMCM0021E.defaultvalue.character.invalid.length.explanation=A default value for a Character type argument was provided, but it does not contain exactly one character. Character arguments must have a single character string.
CWMCM0021E.defaultvalue.character.invalid.length.useraction=Ensure that the default value for an argument with a Character type is a string with exactly one character.

# Used for server logging
# do not translate MCP
# {0} = The cursor value string
CWMCM0022E.invalid.cursor.value=CWMCM0022E: The "{0}" cursor value is invalid.
CWMCM0022E.invalid.cursor.value.explanation=A cursor value was provided as a parameter to the tool/list command, but the value is invalid.
CWMCM0022E.invalid.cursor.value.useraction=Make sure that the cursor value is provided exactly as it was returned from the previous tool/list call.

# Used for server logging
# do not translate MCP
# {0} = The name of the tool 
# {1} = The qualified name of the tool
CWMCM0023E.invalid.length.tool.name=CWMCM0023E: The {0} tool name for the {1} MCP tool method is not valid. Tool names must be between 1 and 128 characters in length, inclusive.
CWMCM0023E.invalid.length.tool.name.explanation=The tool name does not follow the MCP specification for names. Names must be between 1 and 128 characters in length, inclusive.
CWMCM0023E.invalid.length.tool.name.useraction=Make sure that tool names are between 1 and 128 characters, inclusive.

# Used for server logging
# do not translate MCP
# {0} = The name of the tool
# {1} = The qualified name of the tool
CWMCM0024E.invalid.character.tool.name=CWMCM0024E: The {0} tool name for the {1} MCP tool method is not valid. Tool names must contain only ASCII letters, digits, underscores, or hyphens.
CWMCM0024E.invalid.character.tool.name.explanation=The tool name doesn't follow the MCP specification for names. Names can contain only ASCII letters, digits, underscores, hyphens, and not any other special character.
CWMCM0024E.invalid.character.tool.name.useraction=Make sure that tool names contain only ASCII letters, digits, underscores, or hyphens.

#Used as part of a response to a client
# do not translate MCP
argument.conversion.failed=The {0} argument cannot be converted to the {1} type.
extra.arguments=The following arguments were passed but were not found in the method: {0}.
missing.arguments=The method expected the following arguments but did not receive them: {0}.
unauthorized.cancellation=The tool cannot be cancelled as the calling user is not authorized.

# Used for server logging
# {0} = Parameter name
# {1} = The qualified name of the tool
CWMCM0025E.unsupported.output=CWMCM0025E: The {0} return type of the {1} MCP tool method must be an object.
CWMCM0025E.unsupported.output.explanation=The provided MCP tool return type is not supported. Because the structured content is set to true, the output schema type must be an object.
CWMCM0025E.unsupported.output.useraction=Provide a return type that is an object.

# Used as exception message
# {0} = The name of the tool
CWMCM0026E.duplicate.tool.name=CWMCM0026E: An MCP tool with the name {0} already exists.
CWMCM0026E.duplicate.tool.name.explanation=Each tool must have a unique name. You cannot register a new tool that has the same name as an existing tool.
CWMCM0026E.duplicate.tool.name.useraction=Provide a unique name for each MCP tool.

# Used as exception message
# Do not translate handler, setHandler, asyncHandler, setAsyncHandler, ToolManager, or ToolDefinition
# {0} = The name of the tool
CWMCM0027E.provide.one.handler=CWMCM0027E: Either the setHandler method or the setAsyncHandler method must be called for the {0} MCP tool.
CWMCM0027E.provide.one.handler.explanation=When you register a new tool by using ToolManager, you must provide either a synchronous handler by calling the setHandler method, or an asynchronous handler by calling the setAsyncHandler method. Do not provide both.
CWMCM0027E.provide.one.handler.useraction=Call either the ToolDefinition.setHandler method or the ToolDefinition.setAsyncHandler method when you register a tool by using ToolManager.

# Used as exception message
# Do not translate MCP
# {0} = The name of the tool
CWMCM0028E.invalid.character.tool.name=CWMCM0028E: The {0} MCP tool name is not valid. Tool names must contain only ASCII letters, digits, underscores, or hyphens.
CWMCM0028E.invalid.character.tool.name.explanation=The tool name doesn't follow the MCP specification for names. Names can contain only ASCII letters, digits, underscores, hyphens, and not any other special character.
CWMCM0028E.invalid.character.tool.name.useraction=Make sure that tool names contain only ASCII letters, digits, underscores, or hyphens.

# Used as exception message
# Do not translate MCP
# {0} = The name of the tool
CWMCM0029E.invalid.length.tool.name=CWMCM0029E: The {0} MCP tool name is not valid. Tool names must be between 1 and 128 characters in length, inclusive.
CWMCM0029E.invalid.length.tool.name.explanation=The tool name doesn't follow the MCP specification for names. Names must be between 1 and 128 characters in length, inclusive.
CWMCM0029E.invalid.length.tool.name.useraction=Make sure that tool names are between 1 and 128 characters, inclusive.

# Used as exception message
# Do not translate MCP
# {0} = The name of the tool
CWMCM0030E.blank.arguments=CWMCM0030E: Cannot add an argument with a blank name to the {0} MCP tool.
CWMCM0030E.blank.arguments.explanation=Every MCP tool argument must have a non-blank name. 
CWMCM0030E.blank.arguments.useraction=Provide non-empty names for all tool arguments.

# Used as exception message
# Do not translate MCP
# {0} = The name of the tool
# {1} = The name of the argument
# {2} = The type of the argument
CWMCM0031E.missing.toolarg.defaultvalue.converter=CWMCM0031E: The {1} argument of the {0} MCP tool does not have a converter to change its default value into an object of type {2}.
CWMCM0031E.missing.toolarg.defaultvalue.converter.explanation=One or more arguments have default values without a matching converter to convert the default value to the argument's type.
CWMCM0031E.missing.toolarg.defaultvalue.converter.useraction=Create a custom converter implementation for the tool argument's type.

# Used as exception message
# Do not translate MCP
# {0} = The name of the tool
# {1} = The name of the argument
CWMCM0032E.duplicate.argument.name=CWMCM0032E: Cannot add a second argument with the {1} name to the {0} MCP tool.
CWMCM0032E.duplicate.argument.name.explanation=Each argument of an MCP tool must have a different name.
CWMCM0032E.duplicate.argument.name.useraction=Give each tool argument a different name.

# Used for server logging
# {0} = Method
# {1} = RequestURI
# {2} = RequestQuery
# {3} = ExceptionMessage
CWMCM0033A.forbidden.error=CWMCM0033A: Forbidden request. Method={0} RequestURI={1} RequestQuery={2}, Exception: {3}
CWMCM0033A.forbidden.error.explanation=A request was made but the user is not authorized to make it.
CWMCM0033A.forbidden.error.useraction=Make sure that an authorized user is calling the request.
