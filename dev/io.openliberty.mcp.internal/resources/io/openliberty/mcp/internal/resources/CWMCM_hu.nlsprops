#ISMESSAGEFILE true

# Used for server logging
# do not translate MCP
# {0} = The qualified name of the tool
CWMCM0001E.blank.arguments=CWMCM0001E: Az {0} MCP eszk\u00f6z m\u00f3dszer\u00e9nek egy vagy t\u00f6bb \u00fcres nev\u0171 argumentuma van.
CWMCM0001E.blank.arguments.explanation=Az MCP eszk\u00f6z argumentumai megadva voltak, de hi\u00e1nyoztak a nevek. A szersz\u00e1m m\u00f3dszer minden argumentum\u00e1nak nevet kell adni.
CWMCM0001E.blank.arguments.useraction=Adjon meg nem \u00fcres \u00e9rt\u00e9keket az \u00f6sszes k\u00f6telez\u0151 argumentumhoz.

# Used for server logging
# do not translate MCP
# {0} = The  qualified name of the tool
# {1} = corresponding argument name
CWMCM0002E.duplicate.arguments=CWMCM0002E: Az {0} MCP eszk\u00f6z m\u00f3dszernek t\u00f6bb, nev\u0171 {1} argumentuma van.
CWMCM0002E.duplicate.arguments.explanation=Egy vagy t\u00f6bb argumentumnak ugyanaz a neve. Az MCP eszk\u00f6z m\u00f3dszer\u00e9nek minden argumentum\u00e1nak k\u00fcl\u00f6nb\u00f6z\u0151 n\u00e9vvel kell rendelkeznie.
CWMCM0002E.duplicate.arguments.useraction=Adjon minden eszk\u00f6zargumentumnak k\u00fcl\u00f6nb\u00f6z\u0151 nevet.

# Used for server logging
# do not translate MCP
# {0} = The qualified name of the tool
CWMCM0003E.missing.tool.argument.name=CWMCM0003E: Az {0} MCP eszk\u00f6z m\u00f3dszer\u00e9nek egy vagy t\u00f6bb argumentuma van, amelyeknek nincs megadva a neve.
CWMCM0003E.missing.tool.argument.name.explanation=Egy vagy t\u00f6bb eszk\u00f6zargumentum neve nem ker\u00fclt megad\u00e1sra az MCP eszk\u00f6z\u00f6kh\u00f6z.
CWMCM0003E.missing.tool.argument.name.useraction=Adjon hozz\u00e1 egy nevet a @ToolArg megjegyz\u00e9shez, vagy adja hozz\u00e1 a -parameters ford\u00edt\u00f3opci\u00f3t a param\u00e9tern\u00e9v haszn\u00e1lat\u00e1hoz.

# Used for server logging
# do not translate MCP
# {0} = The list of qualified names of the tool
# {1} = The list of duplicate methods
CWMCM0004E.duplicate.tools=CWMCM0004E: T\u00f6bb MCP eszk\u00f6z m\u00f3dszer l\u00e9tezik, amelyek neve {0}. A m\u00f3dszerek a k\u00f6vetkez\u0151k {1}.
CWMCM0004E.duplicate.tools.explanation=Egy vagy t\u00f6bb MCP eszk\u00f6z neve t\u00f6bbsz\u00f6r is el\u0151fordult. A szerver az egyedis\u00e9g \u00e9rdek\u00e9ben egy nevet v\u00e1r el minden eszk\u00f6zh\u00f6z.
CWMCM0004E.duplicate.tools.useraction=Minden MCP eszk\u00f6znek csak egyedi nevet adjon meg.

# Used for server logging
# do not translate MCP
CWMCM0005E.validation.error=CWMCM0005E: Egy vagy t\u00f6bb MCP-\u00e9rv\u00e9nyes\u00edt\u00e9si hiba t\u00f6rt\u00e9nt. Tov\u00e1bbi r\u00e9szletek\u00e9rt n\u00e9zze meg a napl\u00f3kat.
CWMCM0005E.validation.error.explanation=Az alkalmaz\u00e1s nem ind\u00edthat\u00f3 el, mert MCP-\u00e9rv\u00e9nyes\u00edt\u00e9si hib\u00e1k vannak.
CWMCM0005E.validation.error.useraction=Tov\u00e1bbi r\u00e9szletek\u00e9rt n\u00e9zze meg a napl\u00f3kat.

# Used for server logging
# do not translate MCP
# {0} = The fully qualified method name
# {1} = The parameter type simple name
CWMCM0006E.duplicate.special.arguments=CWMCM0006E: Az {0} MCP eszk\u00f6z t\u00f6bb mint egy param\u00e9terrel rendelkezik a {1} t\u00edpus\u00fa. Minden eszk\u00f6zm\u00f3dszerben csak egy {1} param\u00e9tert haszn\u00e1ljon.
CWMCM0006E.duplicate.special.arguments.explanation=Egy vagy t\u00f6bb speci\u00e1lis argumentum t\u00f6bbsz\u00f6r is el\u0151fordult, pedig csak egy v\u00e1rhat\u00f3.
CWMCM0006E.duplicate.special.arguments.useraction=T\u00e1vol\u00edtsa el a felesleges p\u00e9ld\u00e1nyokat.

# Used for server logging
# {0} = The fully qualified method name
# {1} = The parameter type simple name
CWMCM0007E.invalid.arguments=CWMCM0007E: Az {0} MCP eszk\u00f6znek van egy t\u00edpus\u00fa {1} param\u00e9tere, amely nem felismert speci\u00e1lis argumentumt\u00edpus, \u00e9s nincs `@ToolArg` annot\u00e1ci\u00f3ja.
CWMCM0007E.invalid.arguments.explanation=Egy vagy t\u00f6bb param\u00e9ter nem lett eszk\u00f6zargumentumk\u00e9nt megjel\u00f6lve, \u00e9s nem ismerik fel \u0151ket speci\u00e1lis argumentumt\u00edpusk\u00e9nt.
CWMCM0007E.invalid.arguments.useraction=Ellen\u0151rizze, hogy az argumentumhoz a megfelel\u0151 oszt\u00e1lyt import\u00e1lta-e, vagy azt akarta-e beilleszteni @ToolArg.

