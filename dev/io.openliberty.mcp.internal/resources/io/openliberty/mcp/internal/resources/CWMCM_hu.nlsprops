#CMVCPATHNAME N/A
#COMPONENTPREFIX CWMCM
#COMPONENTNAMEFOR CWMCM MCP Server
#NLS_ENCODING=UNICODE
#NLS_MESSAGEFORMAT_NONE
#ISMESSAGEFILE true

# Used for server logging
# do not translate MCP
# {0} = The qualified name of the tool
CWMCM0001E.blank.arguments=CWMCM0001E: Az {0} MCP eszk\u00f6z m\u00f3dszer\u00e9nek egy vagy t\u00f6bb \u00fcres nev\u0171 argumentuma van.
CWMCM0001E.blank.arguments.explanation=Az MCP eszk\u00f6z argumentumai megadva voltak, de hi\u00e1nyoztak a nevek. A szersz\u00e1m m\u00f3dszer minden argumentum\u00e1nak nevet kell adni.
CWMCM0001E.blank.arguments.useraction=Adjon meg nem \u00fcres \u00e9rt\u00e9keket az \u00f6sszes k\u00f6telez\u0151 argumentumhoz.

# Used for server logging
# do not translate MCP
# {0} = The  qualified name of the tool
# {1} = corresponding argument name
CWMCM0002E.duplicate.arguments=CWMCM0002E: Az {0} MCP eszk\u00f6z m\u00f3dszernek t\u00f6bb, nev\u0171 {1} argumentuma van.
CWMCM0002E.duplicate.arguments.explanation=Egy vagy t\u00f6bb argumentumnak ugyanaz a neve. Az MCP eszk\u00f6z m\u00f3dszer\u00e9nek minden argumentum\u00e1nak k\u00fcl\u00f6nb\u00f6z\u0151 n\u00e9vvel kell rendelkeznie.
CWMCM0002E.duplicate.arguments.useraction=Adjon minden eszk\u00f6zargumentumnak k\u00fcl\u00f6nb\u00f6z\u0151 nevet.

# Used for server logging
# do not translate MCP
# {0} = The qualified name of the tool
CWMCM0003E.missing.tool.argument.name=CWMCM0003E: Az {0} MCP eszk\u00f6z m\u00f3dszer\u00e9nek egy vagy t\u00f6bb argumentuma van, amelyeknek nincs megadva a neve.
CWMCM0003E.missing.tool.argument.name.explanation=Egy vagy t\u00f6bb eszk\u00f6zargumentum neve nem ker\u00fclt megad\u00e1sra az MCP eszk\u00f6z\u00f6kh\u00f6z.
CWMCM0003E.missing.tool.argument.name.useraction=Adjon hozz\u00e1 egy nevet a @ToolArg megjegyz\u00e9shez, vagy adja hozz\u00e1 a -parameters ford\u00edt\u00f3opci\u00f3t a param\u00e9tern\u00e9v haszn\u00e1lat\u00e1hoz.

# Used for server logging
# do not translate MCP
# {0} = The list of qualified names of the tool
CWMCM0004E.duplicate.tools=CWMCM0004E: T\u00f6bb MCP eszk\u00f6z m\u00f3dszer l\u00e9tezik, amelyek neve {0}. A m\u00f3dszerek a k\u00f6vetkez\u0151k {1}.
CWMCM0004E.duplicate.tools.explanation=Egy vagy t\u00f6bb MCP eszk\u00f6z neve t\u00f6bbsz\u00f6r is el\u0151fordult. A szerver az egyedis\u00e9g \u00e9rdek\u00e9ben egy nevet v\u00e1r el minden eszk\u00f6zh\u00f6z.
CWMCM0004E.duplicate.tools.useraction=Minden MCP eszk\u00f6znek csak egyedi nevet adjon meg.

# Used for server logging
# do not translate MCP
CWMCM0005E.validation.error=CWMCM0005E: Egy vagy t\u00f6bb MCP-\u00e9rv\u00e9nyes\u00edt\u00e9si hiba t\u00f6rt\u00e9nt. Tov\u00e1bbi r\u00e9szletek\u00e9rt n\u00e9zze meg a napl\u00f3kat.
CWMCM0005E.validation.error.explanation=Az alkalmaz\u00e1s nem ind\u00edthat\u00f3 el, mert MCP-\u00e9rv\u00e9nyes\u00edt\u00e9si hib\u00e1k vannak.
CWMCM0005E.validation.error.useraction=Tov\u00e1bbi r\u00e9szletek\u00e9rt n\u00e9zze meg a napl\u00f3kat.

# Used for server logging
# do not translate MCP
# {0} = The fully qualified method name
# {1} = The parameter type simple name
CWMCM0006E.duplicate.special.arguments=CWMCM0006E: Az {0} MCP eszk\u00f6z t\u00f6bb mint egy param\u00e9terrel rendelkezik a {1} t\u00edpus\u00fa. Minden eszk\u00f6zm\u00f3dszerben csak egy {1} param\u00e9tert haszn\u00e1ljon.
CWMCM0006E.duplicate.special.arguments.explanation=Egy vagy t\u00f6bb speci\u00e1lis argumentum t\u00f6bbsz\u00f6r is el\u0151fordult, pedig csak egy v\u00e1rhat\u00f3.
CWMCM0006E.duplicate.special.arguments.useraction=T\u00e1vol\u00edtsa el a felesleges p\u00e9ld\u00e1nyokat.

# Used for server logging
# {0} = The fully qualified method name
# {1} = The parameter type simple name
CWMCM0007E.invalid.arguments=CWMCM0007E: Az {0} MCP eszk\u00f6znek van egy t\u00edpus\u00fa {1} param\u00e9tere, amely nem felismert speci\u00e1lis argumentumt\u00edpus, \u00e9s nincs `@ToolArg` annot\u00e1ci\u00f3ja.
CWMCM0007E.invalid.arguments.explanation=Egy vagy t\u00f6bb param\u00e9ter nem lett eszk\u00f6zargumentumk\u00e9nt megjel\u00f6lve, \u00e9s nem ismerik fel \u0151ket speci\u00e1lis argumentumt\u00edpusk\u00e9nt.
CWMCM0007E.invalid.arguments.useraction=Ellen\u0151rizze, hogy az argumentumhoz a megfelel\u0151 oszt\u00e1lyt import\u00e1lta-e, vagy azt akarta-e beilleszteni @ToolArg.

# Used as part of a response to a client
# {0} = Request id
CWMCM0008E.invalid.request.params=CWMCM0008E: Az {0} azonos\u00edt\u00f3val rendelkez\u0151 k\u00e9relem feldolgoz\u00e1s alatt \u00e1ll.
CWMCM0008E.invalid.request.params.explanation=Ugyanazon azonos\u00edt\u00f3val rendelkez\u0151 k\u00e9relem feldolgoz\u00e1s alatt \u00e1ll. Az ugyanazon \u00fcgyf\u00e9lt\u0151l \u00e9rkez\u0151 k\u00e9r\u00e9seknek egyedi azonos\u00edt\u00f3val kell rendelkezni\u00fck.
CWMCM0008E.invalid.request.params.useraction=Minden k\u00e9r\u00e9shez egyedi azonos\u00edt\u00f3t haszn\u00e1ljon.

# Used as part of a response to a client
# do not translate GET, POST
CWMCM0009I.get.disallowed=CWMCM0009I: A GET k\u00e9r\u00e9sek nem t\u00e1mogatottak.
CWMCM0009I.get.disallowed.explanation=GET k\u00e9r\u00e9s ker\u00fclt elk\u00fcld\u00e9sre, de ez a funkci\u00f3 nem t\u00e1mogatott.
CWMCM0009I.get.disallowed.useraction=Nincs teend\u0151.

# Used for server logging
# {0} = tool name
# {1} = exception details
CWMCM0010E.internal.server.error.detailed=CWMCM0010E: Az {0} eszk\u00f6z m\u00f3dszer v\u00e1ratlan kiv\u00e9telt dobott. A kiv\u00e9tel: {1}
CWMCM0010E.internal.server.error.detailed.explanation=Az eszk\u00f6z m\u00f3dszer v\u00e1ratlan kiv\u00e9telt dobott.
CWMCM0010E.internal.server.error.detailed.useraction=A kiszolg\u00e1l\u00f3 message.log f\u00e1jlj\u00e1t \u00e9s FFDC napl\u00f3it \u00e1ttekintve azonos\u00edtsa be a probl\u00e9m\u00e1t.

# Used as part of a response to a client
CWMCM0011E.internal.server.error=CWMCM0011E: Az eszk\u00f6z futtat\u00e1sa k\u00f6zben bels\u0151 szerverhiba t\u00f6rt\u00e9nt.
CWMCM0011E.internal.server.error.explanation=A szerver nem tudta teljes\u00edteni az eszk\u00f6zh\u00edv\u00e1s k\u00e9r\u00e9s\u00e9t.
CWMCM0011E.internal.server.error.useraction=Ellen\u0151rizze, hogy a k\u00e9r\u00e9s helyes-e. Tov\u00e1bbi inform\u00e1ci\u00f3k a hib\u00e1r\u00f3l a szerveren messages.log tal\u00e1lhat\u00f3k.

# Used for server logging
# do not translate bean
# {0} = bean error details
# {1} = tool name
CWMCM0012E.bean.release.fail=CWMCM0012E: Hiba t\u00f6rt\u00e9nt a CDI bean felszabad\u00edt\u00e1sakor a {1} tool h\u00edv\u00e1sa ut\u00e1n. A hiba a k\u00f6vetkez\u0151: {0}
CWMCM0012E.bean.release.fail.explanation=Egy eszk\u00f6zm\u00f3dszer megh\u00edv\u00e1sakor a m\u00f3dszert deklar\u00e1l\u00f3 CDI bean p\u00e9ld\u00e1nya a m\u00f3dszer megh\u00edv\u00e1sa el\u0151tt ker\u00fcl lek\u00e9r\u00e9sre, majd a m\u00f3dszer megh\u00edv\u00e1sa ut\u00e1n felszabad\u00edt\u00e1sra ker\u00fcl. Hiba t\u00f6rt\u00e9nt a bean p\u00e9ld\u00e1ny felszabad\u00edt\u00e1sakor.
CWMCM0012E.bean.release.fail.useraction=A kiszolg\u00e1l\u00f3 message.log f\u00e1jlj\u00e1t \u00e9s FFDC napl\u00f3it \u00e1ttekintve azonos\u00edtsa be a probl\u00e9m\u00e1t.

# Used for server logging and client response
# do not translate MCP-Protocol-Version, MCP
# {0} = List of supported MCP-Protocol-Version values
CWMCM0013E.unsupported.mcp.http.version=CWMCM0013E: Nem t\u00e1mogatott MCP-Protocol-Version fejl\u00e9cet adtak meg. T\u00e1mogatott \u00e9rt\u00e9kek: {0}
CWMCM0013E.unsupported.mcp.http.version.explanation=A szerver nem t\u00e1mogatja az MCP-Protocol-Version fejl\u00e9cben szerepl\u0151 protokollverzi\u00f3t.
CWMCM0013E.unsupported.mcp.http.version.useraction=Haszn\u00e1ljon t\u00e1mogatott protokoll verzi\u00f3t.

# Used as part of a response to a client
# {0} = Method
# {1} = RequestURI
# {2} = RequestQuery
CWMCM0014E.unexpected.server.error=CWMCM0014E: V\u00e1ratlan szerverhiba. M\u00f3dszer= {0} RequestURI={1 } RequestQuery={2 }
CWMCM0014E.unexpected.server.error.explanation=A k\u00e9r\u00e9s feldolgoz\u00e1sa k\u00f6zben v\u00e1ratlan szerverhiba t\u00f6rt\u00e9nt. A k\u00e9r\u00e9s nem teljes\u00edthet\u0151.
CWMCM0014E.unexpected.server.error.useraction=Nincs teend\u0151.

# Used for server logging
# {0} = Method
# {1} = RequestURI
# {2} = RequestQuery
# {3} = ExceptionMessage
CWMCM0015E.unexpected.server.error.exception=CWMCM0015E: V\u00e1ratlan szerverhiba. M\u00f3dszer= {0} RequestURI={1 } RequestQuery={2 }, Kiv\u00e9tel: {3}
CWMCM0015E.unexpected.server.error.exception.explanation=A k\u00e9r\u00e9s feldolgoz\u00e1sa k\u00f6zben v\u00e1ratlan szerverhiba t\u00f6rt\u00e9nt. A k\u00e9r\u00e9s nem teljes\u00edthet\u0151.
CWMCM0015E.unexpected.server.error.exception.useraction=A kiszolg\u00e1l\u00f3 message.log f\u00e1jlj\u00e1t \u00e9s FFDC napl\u00f3it \u00e1ttekintve azonos\u00edtsa be a probl\u00e9m\u00e1t.

# Used for server logging
# {0} = ExceptionMessage
CWMCM0016E.error.sending.response.exception=CWMCM0016E: V\u00e1ratlan szerverhiba. Kiv\u00e9tel: {0}
CWMCM0016E.error.sending.response.exception.explanation=Hiba t\u00f6rt\u00e9nt a v\u00e1lasz elk\u00fcld\u00e9se k\u00f6zben.
CWMCM0016E.error.sending.response.exception.useraction=Nincs teend\u0151.

# Used as part of a response to a client
# do not translate jsonrpc
# {0} = jsonrpc value
jsonrpc.exception.validation.invalid.version=A jsonrpc mez\u0151nek jelen kell lennie. Jelenleg csak a JSONRPC 2.0 t\u00e1mogatott.

# Used as part of a response to a client
jsonrpc.validation.empty.method=A m\u00f3dszer mez\u0151 \u00fcres.

# Used as part of a response to a client
# {0} = id value
jsonrpc.exception.validation.empty.string.id=Az id mez\u0151 \u00e9rv\u00e9nytelen. Az azonos\u00edt\u00f3 nem lehet \u00fcres, ha karakterl\u00e1nc van megadva.

# Used as part of a response to a client
jsonrpc.exception.validation.invalid.id.type=Az id t\u00edpus nem elfogadhat\u00f3 t\u00edpus. Az azonos\u00edt\u00f3nak karakterl\u00e1ncnak vagy eg\u00e9sz sz\u00e1mnak kell lennie.

# Used as part of a response to a client
jsonrpc.missing.params=A k\u00e9r\u00e9snek nincsenek param\u00e9terekben megadott argumentumai.

# Used as part of a response to a client
# {0} = list of arguments
jsonrpc.extra.arguments=A k\u00f6vetkez\u0151 argumentumok ker\u00fcltek \u00e1tad\u00e1sra, de nem tal\u00e1lt\u00e1k meg \u0151ket a m\u00f3dszerben: {0}.

# Used as part of a response to a client
# {0} = list of arguments
jsonrpc.missing.arguments=A m\u00f3dszer a k\u00f6vetkez\u0151 argumentumokat v\u00e1rta, de azok nem ker\u00fcltek megad\u00e1sra: {0}.
