<server description="Server for testing Telemetry10">

	<include location="../fatTestPorts.xml" />

	<featureManager>
		<feature>servlet-6.0</feature>
		<feature>mpTelemetry-1.0</feature>
		<feature>componentTest-2.0</feature>
	</featureManager>
	 
	<variable name="otel.service.name" value="overrideDone"/>
	<variable name="otel.sdk.disabled" value="false"/>
	<variable name="otel.logs.exporter" value="none"/>
	<variable name="otel.metrics.exporter" value="none"/>
	<variable name="otel.traces.exporter" value="none"/>

	<application id="TelemetryApp" name="TelemetryApp" type="war" location="TelemetryApp.war">
    	<classloader apiTypeVisibility="+third-party"/>
	</application>

</server>