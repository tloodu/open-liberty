-include=~../cnf/resources/bnd/bundle.props

-sub: *.bnd

bVersion=1.0
cxfVersion=3.5.5.1

WS-TraceGroup: WSSECURITY

Bundle-ActivationPolicy: lazy

Export-Package: \
  org.apache.cxf.rt.security.saml.*;version=3.5.5

Import-Package:  \
  com.ibm.websphere.ras, \
  com.ibm.websphere.ras.annotation, \
  com.ibm.ws.ffdc, \
  *

-includeresource: \
  @${repo;io.openliberty.org.apache.cxf:cxf-rt-security-saml;${cxfVersion};EXACT}!/!META-INF/maven/*|META-INF/MANIFEST.MF|META-INF/cxf/*

globalize: false
instrument.ffdc: true

-buildpath: \
 io.openliberty.org.apache.cxf:cxf-rt-security-saml;strategy=exact;version=${cxfVersion}, \
  com.ibm.ws.org.joda.time.2.9.9;version=latest
