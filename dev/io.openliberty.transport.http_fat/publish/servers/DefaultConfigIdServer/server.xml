<server description="Test Default Config IDs">

    <include location="../fatTestCommon.xml"/>

    <featureManager>
        <feature>servlet-3.1</feature>
    </featureManager>

    <!-- Note: Only httpEndpoint & tcpOptions will be picked up regardless of ID   -->

    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="${bvt.prop.HTTP_default}"
                  httpsPort="${bvt.prop.HTTP_default.secure}"
                  tcpOptionsRef="defaultTCPOptions"
                  httpOptionsRef="defaultHttpOptions"
                  accessLoggingRef="defaultAccessLogging"
                  headersRef="defaultHeaders"
                  compressionRef="defaultCompression"
                  remoteIpRef="defaultRemoteIp"
                  samesiteRef="defaultSameSite">
    </httpEndpoint>
    
    <tcpOptions id="defaultTCPOptions"
                maxOpenConnections="10" />

    <httpOptions id="defaultHttpOptions"
                 readTimeout="150s"
                 writeTimeout="150s" />

    <httpAccessLogging id="defaultAccessLogging"
                       logFormat='%h %u "%r" %s %b' />

    <headers id="defaultHeaders">
        <add>Custom-Header:Test-Custom</add>
        <setIfMissing>Test-Missing:TestMissingValue</setIfMissing>
    </headers>

    <compression id="defaultCompression"
                 types="+text/html, +text/plain, +text/xml" />

    <remoteIp id="defaultRemoteIp"
              proxies=".*"
              useRemoteIpInAccessLog="true" />

    <samesite id="defaultSameSite"
              lax="*"/>
    
    <!-- Note: defaultSSLOptions is not tested -->
</server>
