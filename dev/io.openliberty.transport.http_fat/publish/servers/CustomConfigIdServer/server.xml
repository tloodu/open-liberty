<server description="Test Custom (Non-Default) Config IDs">

    <include location="../fatTestCommon.xml"/>

    <featureManager>
        <feature>servlet-3.1</feature>
    </featureManager>

    <!-- Note: httpEndpoint is picked up regardless of ID -->
    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="${bvt.prop.HTTP_default}"
                  httpsPort="${bvt.prop.HTTP_default.secure}"
                  tcpOptionsRef="testTCPOptions"
                  httpOptionsRef="testHttpOptions"
                  accessLoggingRef="testAccessLogging"
                  headersRef="testHeaders"
                  compressionRef="testCompression"
                  remoteIpRef="testRemoteIp"
                  samesiteRef="testSameSite">
    </httpEndpoint>
    
    <tcpOptions id="testTCPOptions"
                maxOpenConnections="100" />

    <httpOptions id="testHttpOptions"
                 readTimeout="200s"
                 writeTimeout="200s" />

    <httpAccessLogging id="testAccessLogging"
                       logFormat='%h %u "%r" %s %b' />

    <headers id="testHeaders">
        <add>Custom-Header:Test-Custom</add>
        <setIfMissing>Test-Missing:TestMissingValue</setIfMissing>
    </headers>

    <compression id="testCompression"
                 types="+text/html, +text/plain, +text/xml" />

    <remoteIp id="testRemoteIp"
              proxies=".*"
              useRemoteIpInAccessLog="true" />

    <samesite id="testSameSite"
              lax="*" />

    <!-- Note: defaultSSLOptions is not tested -->

</server>
