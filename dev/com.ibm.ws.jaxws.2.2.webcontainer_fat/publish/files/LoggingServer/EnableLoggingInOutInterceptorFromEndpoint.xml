<server>
    <featureManager>
        <feature>jsp-2.2</feature>        
        <feature>jaxws-2.2</feature>
        <feature>servlet-3.1</feature>
        <feature>componenttest-1.0</feature>
    </featureManager>

    <include location="../fatTestPorts.xml"/>

    <javaPermission className="java.util.PropertyPermission" name="*" actions="read"/>
    <javaPermission className="javax.security.auth.AuthPermission" name="*" actions="getSubject" />
    <javaPermission className="java.lang.RuntimePermission" name="getClassLoader"/>
    <javaPermission className="java.lang.RuntimePermission" name="createClassLoader"/>
    <javaPermission className="java.lang.RuntimePermission" name="accessDeclaredMembers"/>
    <javaPermission className="java.io.FilePermission" name="ALL FILES" actions="read"/>
  	
	<!-- using enableLoggingInOutInterceptor to enable feature logging -->
	<webApplication name="helloApp" location="helloApp.war"
		context-root="helloApp">
		<webservices-bnd>
			<webservice-endpoint-properties enableLoggingInOutInterceptor="true"/>  
		</webservices-bnd>
	</webApplication>
</server>