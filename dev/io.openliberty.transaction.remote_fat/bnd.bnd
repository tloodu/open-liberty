-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0

src: \
	fat/src,\
	test-applications/remoteEJB/src

fat.project: true

# Define additional tested features that are NOT present in any XML files in this bucket.
# In this case, servlet-4.0 is added programmatically at runtime by the RepeatTests rule.
tested.features:\
 servlet-4.0,\
 servlet-5.0,\
 servlet-6.0,\
 servlet-6.1,\
 enterprisebeansremote-4.0,\
 enterprisebeanslite-4.0

# To define a global minimum java level for the FAT, use the following property.
# If unspecified, the default value is ${javac.source}
# fat.minimum.java.level: 11

# Dependencies may be local bundles (e.g. com.ibm.websphere.javaee.servlet.3.1)
#      or binaries from Artifactory (e.g. commons-logging:commons-logging)
# For all project names that match the pattern "*_fat*", dependencies for junit,
# fattest.simplicity, and componenttest-1.0 will be automatically added to the buildpath
-buildpath: \
	com.ibm.tx.jta,\
	com.ibm.tx.util,\
	com.ibm.websphere.javaee.annotation.1.2,\
	com.ibm.websphere.javaee.ejb.3.2,\
	com.ibm.websphere.javaee.servlet.3.1,\
	com.ibm.websphere.javaee.transaction.1.2,\
	com.ibm.websphere.org.osgi.core,\
	com.ibm.websphere.org.osgi.service.component,\
	com.ibm.ws.kernel.service,\
	com.ibm.ws.logging,\
	io.openliberty.yoko.rmi.spec,\
	com.ibm.ws.org.osgi.annotation.versioning,\
	com.ibm.ws.transaction.fat.util,\
	com.ibm.ws.transaction.test.util,\
	com.ibm.ws.tx.embeddable,\
	com.ibm.wsspi.org.osgi.service.component.annotations,\
	io.openliberty.org.apache.commons.logging
