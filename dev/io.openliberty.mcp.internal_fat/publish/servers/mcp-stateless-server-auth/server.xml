<server description="Sample Liberty server">

  <featureManager>
    <feature>servlet-6.0</feature>
    <feature>cdi-4.0</feature>
    <feature>mcpServer-1.0</feature>
    <feature>appSecurity-5.0</feature>
  </featureManager>
  <mcpServer stateless="true"/>

  <include location="../fatTestPorts.xml" />
  
	<basicRegistry id="basic" realm="BasicRealm">
	
	     <user name="testuser" password="testpassword"/>
	     <user name="BobTheAdmin" password="testpassword"/>
		 <user name="noRoleUser" password="testpassword"/>

	     <group name="Admins">
	         <member name="BobTheAdmin"/>
	     </group>
	     
	     <group name="TestUsers">
	         <member name="testuser"/>
	     </group>
	     
	     <group name="AllUsers">
	         <member name="testuser"/>
	         <member name="BobTheAdmin"/>
	     </group>
	     
	</basicRegistry>
  
</server>
