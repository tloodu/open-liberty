#CMVCPATHNAME io.openliberty.security.jakartasec.4.0.internal.cdi/resources/io/openliberty/security/jakartasec/cdi/internal/resources/JakartaSecurity40Messages.nlsprops
#COMPONENTPREFIX CWWKS
#COMPONENTNAMEFOR WebSphere Application Server Jakarta Security 4.0
#ISMESSAGEFILE TRUE
#NLS_MESSAGEFORMAT_VAR
#NLS_ENCODING=UNICODE
# -------------------------------------------------------------------------------------------------

# Message prefix block: 2610-2620

JAKARTA_SECURITY_CDI_ERROR_CUSTOM_QUALIFIERS_NO_HAM_HANDLER=CWWKS2610E: Lipse\u0219te un handler personalizat care utilizeaz\u0103 HttpAuthenticationMechanisms calificat.
JAKARTA_SECURITY_CDI_ERROR_CUSTOM_QUALIFIERS_NO_HAM_HANDLER.explanation=Dac\u0103 sunt specificate HttpAuthenticationMechanisms calificate, atunci HttpAuthenticationMechanismHandler implicit nu poate determina ce HAM s\u0103 utilizeze, prin urmare trebuie furnizat\u0103 o implementare personalizat\u0103 a HttpAuthenticationMechanismHandler.
JAKARTA_SECURITY_CDI_ERROR_CUSTOM_QUALIFIERS_NO_HAM_HANDLER.useraction=Implementa\u021bi un serviciu de autentificare ( HttpAuthenticationMechanismHandler ) care utilizeaz\u0103 o logic\u0103 personalizat\u0103 pentru a selecta un ID unic de utilizator ( HttpAuthenticationMechanism ).

JAKARTASEC_CDI_ERROR_PROCESSING_HAM_LIST=CWWKS2611E: Procesarea adnot\u0103rilor pentru defini\u021bia \u201e {0} \u201d dintr-o list\u0103 a e\u0219uat.
JAKARTASEC_CDI_ERROR_PROCESSING_HAM_LIST.explanation=\u00cen timpul proces\u0103rii unei liste de defini\u021bii HttpAuthenticationMechanism, a ap\u0103rut o eroare la extragerea valorilor adnot\u0103rilor.
JAKARTASEC_CDI_ERROR_PROCESSING_HAM_LIST.useraction=Investiga\u0163i cauza excep\u0163iei \u015fi corecta\u0163i configura\u0163ia aplica\u0163iei.

JAKARTASEC_CDI_ERROR_EXTRACTING_HAM_PROPERTIES=CWWKS2612E: Propriet\u0103\u021bile de procesare de tipul \u201e {0} \u201d au e\u0219uat.
JAKARTASEC_CDI_ERROR_EXTRACTING_HAM_PROPERTIES.explanation=\u00cen timpul proces\u0103rii unei anumite adnot\u0103ri HttpAuthenticationMechanism, a ap\u0103rut o eroare la extragerea valorilor propriet\u0103\u021bilor.
JAKARTASEC_CDI_ERROR_EXTRACTING_HAM_PROPERTIES.useraction=Investiga\u0163i cauza excep\u0163iei \u015fi corecta\u0163i configura\u0163ia aplica\u0163iei.

JAKARTASEC_CDI_ERROR_CREATING_QUALIFIERS=CWWKS2613E: Nu se poate crea adnotarea calificatorului personalizat \u201e {0} \u201d pentru clasa calificatorului \u201e {1} \u201d.
JAKARTASEC_CDI_ERROR_CREATING_QUALIFIERS.explanation=\u00cen timpul cre\u0103rii unui calificativ HttpAuthenticationMechanism, a ap\u0103rut o eroare la crearea unei adnot\u0103ri de calificativ personalizat.
JAKARTASEC_CDI_ERROR_CREATING_QUALIFIERS.useraction=Investiga\u0163i cauza excep\u0163iei \u015fi corecta\u0163i configura\u0163ia aplica\u0163iei.
