#CMVCPATHNAME io.openliberty.security.jakartasec.4.0.internal.cdi/resources/io/openliberty/security/jakartasec/cdi/internal/resources/JakartaSecurity40Messages.nlsprops
#COMPONENTPREFIX CWWKS
#COMPONENTNAMEFOR WebSphere Application Server Jakarta Security 4.0
#ISMESSAGEFILE TRUE
#NLS_MESSAGEFORMAT_VAR
#NLS_ENCODING=UNICODE
# -------------------------------------------------------------------------------------------------

# Message prefix block: 2610-2620

JAKARTA_SECURITY_CDI_ERROR_CUSTOM_QUALIFIERS_NO_HAM_HANDLER=CWWKS2610E: Falta un controlador personalizado que utilice HttpAuthenticationMechanisms cualificado.
JAKARTA_SECURITY_CDI_ERROR_CUSTOM_QUALIFIERS_NO_HAM_HANDLER.explanation=Si se especifican HttpAuthenticationMechanisms cualificados, entonces el HttpAuthenticationMechanismHandler predeterminado no puede determinar qu\u00e9 HAM utilizar, por lo que se debe proporcionar una implementaci\u00f3n personalizada del HttpAuthenticationMechanismHandler.
JAKARTA_SECURITY_CDI_ERROR_CUSTOM_QUALIFIERS_NO_HAM_HANDLER.useraction=Implementar un control de acceso de nivel de sesi\u00f3n ( HttpAuthenticationMechanismHandler ) que utilice una l\u00f3gica personalizada para seleccionar un identificador de sesi\u00f3n de nivel de aplicaci\u00f3n ( HttpAuthenticationMechanism ) \u00fanico.

JAKARTASEC_CDI_ERROR_PROCESSING_HAM_LIST=CWWKS2611E: Se ha producido un error al procesar las anotaciones para la definici\u00f3n \u00ab {0} \u00bb dentro de una lista.
JAKARTASEC_CDI_ERROR_PROCESSING_HAM_LIST.explanation=Al procesar una lista de definiciones de HttpAuthenticationMechanism, se produjo un error al extraer los valores de las anotaciones.
JAKARTASEC_CDI_ERROR_PROCESSING_HAM_LIST.useraction=Investigue la causa de la excepci\u00f3n y corrija la configuraci\u00f3n de la aplicaci\u00f3n.

JAKARTASEC_CDI_ERROR_EXTRACTING_HAM_PROPERTIES=CWWKS2612E: Se ha producido un error al procesar las propiedades del tipo {0}.
JAKARTASEC_CDI_ERROR_EXTRACTING_HAM_PROPERTIES.explanation=Al procesar una anotaci\u00f3n espec\u00edfica HttpAuthenticationMechanism, se produjo un error al extraer los valores de las propiedades.
JAKARTASEC_CDI_ERROR_EXTRACTING_HAM_PROPERTIES.useraction=Investigue la causa de la excepci\u00f3n y corrija la configuraci\u00f3n de la aplicaci\u00f3n.

JAKARTASEC_CDI_ERROR_CREATING_QUALIFIERS=CWWKS2613E: No se puede crear la anotaci\u00f3n de calificador personalizada \u00ab {0} \u00bb para la clase de calificador \u00ab {1} \u00bb.
JAKARTASEC_CDI_ERROR_CREATING_QUALIFIERS.explanation=Al crear un calificador HttpAuthenticationMechanism, se produjo un error al crear una anotaci\u00f3n de calificador personalizada.
JAKARTASEC_CDI_ERROR_CREATING_QUALIFIERS.useraction=Investigue la causa de la excepci\u00f3n y corrija la configuraci\u00f3n de la aplicaci\u00f3n.
