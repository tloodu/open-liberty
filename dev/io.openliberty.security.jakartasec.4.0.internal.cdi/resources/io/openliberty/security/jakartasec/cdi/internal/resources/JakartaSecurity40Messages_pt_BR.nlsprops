#CMVCPATHNAME io.openliberty.security.jakartasec.4.0.internal.cdi/resources/io/openliberty/security/jakartasec/cdi/internal/resources/JakartaSecurity40Messages.nlsprops
#COMPONENTPREFIX CWWKS
#COMPONENTNAMEFOR WebSphere Application Server Jakarta Security 4.0
#ISMESSAGEFILE TRUE
#NLS_MESSAGEFORMAT_VAR
#NLS_ENCODING=UNICODE
# -------------------------------------------------------------------------------------------------

# Message prefix block: 2610-2620

JAKARTA_SECURITY_CDI_ERROR_CUSTOM_QUALIFIERS_NO_HAM_HANDLER=CWWKS2610E: Falta um manipulador personalizado que usa HttpAuthenticationMechanisms qualificado.
JAKARTA_SECURITY_CDI_ERROR_CUSTOM_QUALIFIERS_NO_HAM_HANDLER.explanation=Se forem especificados HttpAuthenticationMechanisms qualificados, o HttpAuthenticationMechanismHandler padr\u00e3o n\u00e3o poder\u00e1 determinar qual HAM usar, portanto, uma implementa\u00e7\u00e3o personalizada do HttpAuthenticationMechanismHandler deve ser fornecida.
JAKARTA_SECURITY_CDI_ERROR_CUSTOM_QUALIFIERS_NO_HAM_HANDLER.useraction=Implemente um HttpAuthenticationMechanismHandler que utilize l\u00f3gica personalizada para selecionar um HttpAuthenticationMechanism \u00fanico.

JAKARTASEC_CDI_ERROR_PROCESSING_HAM_LIST=CWWKS2611E: Falha ao processar anota\u00e7\u00f5es para a defini\u00e7\u00e3o {0} em uma lista.
JAKARTASEC_CDI_ERROR_PROCESSING_HAM_LIST.explanation=Ao processar uma lista de defini\u00e7\u00f5es de HttpAuthenticationMechanism, ocorreu um erro ao extrair os valores das anota\u00e7\u00f5es.
JAKARTASEC_CDI_ERROR_PROCESSING_HAM_LIST.useraction=Investigue a causa da exce\u00e7\u00e3o e corrija a configura\u00e7\u00e3o do aplicativo.

JAKARTASEC_CDI_ERROR_EXTRACTING_HAM_PROPERTIES=CWWKS2612E: Falha ao processar as propriedades do tipo {0}.
JAKARTASEC_CDI_ERROR_EXTRACTING_HAM_PROPERTIES.explanation=Ao processar uma anota\u00e7\u00e3o espec\u00edfica HttpAuthenticationMechanism, ocorreu um erro ao extrair os valores das propriedades.
JAKARTASEC_CDI_ERROR_EXTRACTING_HAM_PROPERTIES.useraction=Investigue a causa da exce\u00e7\u00e3o e corrija a configura\u00e7\u00e3o do aplicativo.

JAKARTASEC_CDI_ERROR_CREATING_QUALIFIERS=CWWKS2613E: N\u00e3o \u00e9 poss\u00edvel criar a anota\u00e7\u00e3o de qualificador personalizado {0} para a classe de qualificador {1}.
JAKARTASEC_CDI_ERROR_CREATING_QUALIFIERS.explanation=Ao criar um qualificador HttpAuthenticationMechanism,, ocorreu um erro ao criar uma anota\u00e7\u00e3o de qualificador personalizada.
JAKARTASEC_CDI_ERROR_CREATING_QUALIFIERS.useraction=Investigue a causa da exce\u00e7\u00e3o e corrija a configura\u00e7\u00e3o do aplicativo.
