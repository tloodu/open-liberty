<server>

	<include location="../fatTestPorts.xml" />
	
	<featureManager>
		<feature>appSecurity-2.0</feature>
		<feature>ejbRemote-3.2</feature>
		<feature>servlet-3.1</feature>
		<feature>transportSecurity-1.0</feature>
	</featureManager>

	<!-- Use the same keystore as the myTestClientCipher so the client already trusts the server cert -->
	<keyStore id="defaultKeyStore"
		password="{xor}EzY9Oi0rJg==" type="PKCS12" />

	<sslDefault sslRef="supportedClientAuthenticationSSLConfig" />

	<basicRegistry id="basic" realm="BasicRealm">
		<user name="user0" password="user0pwd" />
		<user name="user1" password="user1pwd" />
		<group name="group1">
			<member name="user0" />
			<member name="user1" />
		</group>
		<user name="user2" password="user2pwd" />
		<group name="group2">
			<member name="user2" />
			<member name="user6" />
		</group>
		<user name="user3" password="user3pwd" />
		<group name="group3">
			<member name="user3" />
		</group>
		<user name="user4" password="user4pwd" />
		<group name="group4">
			<member name="user4" />
		</group>
		<user name="user5" password="user5pwd " />
		<group name="group5">
			<member name="user5" />
		</group>
		<user name="user6" password="user6pwd" />
	</basicRegistry>

	<application type="ear" id="basicCalc" name="BasicCalculator" location="${server.config.dir}/apps/BasicCalculator.ear" />

	<iiopEndpoint id="myIiopEndpoint" iiopPort="${bvt.prop.IIOP}">
		<iiopsOptions iiopsPort="${bvt.prop.IIOP.secure}" sslRef="supportedClientAuthenticationSSLConfig" />
	</iiopEndpoint>

	<orb id="defaultOrb" iiopEndpointRef="myIiopEndpoint" orbSSLInitTimeout="60">
		<serverPolicy.csiv2>
			<layers>
				<transportLayer sslRef="supportedClientAuthenticationSSLConfig" />
			</layers>
		</serverPolicy.csiv2>
	</orb>

	<logging traceSpecification="*=info:SSLChannel=all:com.ibm.ws.ssl.*=all:com.ibm.websphere.ssl=all:com.ibm.wsspi.ssl.*=all" 
        traceFileName="ssl_trace.log" 
        maxFileSize="10000" 
        maxFiles="10" />

</server>
