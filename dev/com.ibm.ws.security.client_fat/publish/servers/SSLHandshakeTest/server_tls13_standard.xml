<server>
	<include location="../fatTestPorts.xml" />
	<include location="server_base.xml" />

	<!-- Server is configured with standard TLS 1.3 without PQC.
	     Tests with standard TLS 1.3 clients should succeed.
	     Tests with PQC-only clients (no fallback) should fail. -->
	<ssl id="supportedClientAuthenticationSSLConfig"
		clientAuthenticationSupported="true" 
		keyStoreRef="defaultKeyStore"
		sslProtocol="TLSv1.3" />

</server>

