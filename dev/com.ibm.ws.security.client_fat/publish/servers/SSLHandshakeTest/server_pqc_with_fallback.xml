<server>
	<include location="../fatTestPorts.xml" />
	<include location="server_base.xml" />

	<!-- Server is configured with TLS 1.3 and PQC enabled with fallback to non-PQC.
	     Requires JVM arg: -Djdk.tls.namedGroups=X25519MLKEM768,X25519
	     Tests with both PQC and non-PQC clients should succeed. -->
	<ssl id="supportedClientAuthenticationSSLConfig"
		clientAuthenticationSupported="true" 
		keyStoreRef="defaultKeyStore"
		sslProtocol="TLSv1.3" />

</server>

