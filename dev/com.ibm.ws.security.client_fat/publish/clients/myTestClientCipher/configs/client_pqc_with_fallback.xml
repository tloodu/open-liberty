<client description="SSL handshake test client - PQC with fallback to non-PQC">
	<include location="client_base.xml" />

	<!-- PQC-enabled SSL configuration with fallback to non-PQC algorithms
	     Requires JVM arg: -Djdk.tls.namedGroups=X25519MLKEM768,X25519 -->
	<ssl id="supportedClientAuthenticationSSLConfig"
		clientAuthenticationSupported="true" 
		keyStoreRef="defaultKeyStore"
		sslProtocol="TLSv1.3" />

</client>

