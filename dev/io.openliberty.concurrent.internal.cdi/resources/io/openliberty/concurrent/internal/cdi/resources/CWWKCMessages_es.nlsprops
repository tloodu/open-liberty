#CMVCPATHNAME io.openliberty.concurrent.internal.cdi/resources/io/openliberty/concurrent/internal/cdi/resources/CWWKCMessages.nlsprops
#ISMESSAGEFILE TRUE
#NLS_ENCODING=UNICODE
#
#COMPONENTPREFIX CWWKC
#COMPONENTNAMEFOR CWWKC Jakarta EE Concurrency
#
# NLS_MESSAGEFORMAT_VAR
#
#   Strings in this file which contain replacement variables are processed by the MessageFormat 
#   class (single quote must be coded as 2 consecutive single quotes ''). Strings in this file 
#   which do NOT contain replacement variables are NOT processed by the MessageFormat class 
#   (single quote must be coded as one single quote '). 

# All messages must use the range CWWKC1410 to CWWKC1499

CWWKC1410.schedule.lacks.seconds=CWWKC1410E: La anotaci\u00f3n Schedule, {0}, especifica una lista vac\u00eda para los segundos en los que se ejecuta la tarea. Especifique una lista no vac\u00eda para el campo segundos u omita el campo segundos de la anotaci\u00f3n Programaci\u00f3n. Si se omite el campo de segundos, la tarea se programar\u00e1 para ejecutarse al inicio del minuto.
CWWKC1410.schedule.lacks.seconds.explanation=La lista vac\u00eda indica que el campo de segundos debe ignorarse al calcular las horas programadas. Si se omite el campo de segundos, la tarea se programar\u00e1 para ejecutarse al inicio del minuto.
CWWKC1410.schedule.lacks.seconds.useraction=Modifique el campo segundos de la anotaci\u00f3n Schedule para especificar una lista que no est\u00e9 vac\u00eda u omita el campo segundos de la anotaci\u00f3n Schedule.

CWWKC1411.qualified.res.err=CWWKC1411E: El servidor no ha creado un bean {0} para la anotaci\u00f3n {1} o el elemento descriptor de despliegue {2}. El elemento de anotaci\u00f3n o descriptor de despliegue tiene el {3} nombre y {4} calificadores y se define en el {5} artefacto de aplicaci\u00f3n. El error es {6}
CWWKC1411.qualified.res.err.explanation=El c\u00f3digo no ha creado el recurso o no lo ha registrado como bean.
CWWKC1411.qualified.res.err.useraction=Aseg\u00farese de que el recurso est\u00e1 configurado correctamente.

CWWKC1412.qualifier.conflict=CWWKC1412E: El artefacto de aplicaci\u00f3n {0} incluye m\u00faltiples definiciones de recursos {1} que tienen los calificadores {2}. Los nombres de las definiciones de recursos {1} en conflicto son {3}.
CWWKC1412.qualifier.conflict.explanation=Cada definici\u00f3n de recurso del mismo tipo que tenga un calificador debe tener un calificador diferente.
CWWKC1412.qualifier.conflict.useraction=Aseg\u00farese de que cada definici\u00f3n de recurso del mismo tipo tiene un calificador diferente o no tiene ning\u00fan calificador.
