-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0

src:\
    fat/src,\
    test-applications/web/src,\
    test-libraries/cdiextension/src,\
    test-resourceadapters/adminobject/src,\
    test-resourceadapters/connectionfactory/src,\
    test-resourceadapters/jmsconnectionfactory/src,\
    test-resourceadapters/jmsdestination/src

fat.project: true

tested.features:\
    cdi-4.0,\
    cdi-4.1,\
    connectors-2.1,\
    messaging-3.1,\
    servlet-6.0,\
    servlet-6.1

-buildpath:\
    com.ibm.websphere.javaee.servlet.4.0;version=latest,\
    com.ibm.ws.componenttest.2.0;version=latest,\
    io.openliberty.jakarta.annotation.2.1;version=latest,\
    io.openliberty.jakarta.cdi.3.0;version=latest,\
    io.openliberty.jakarta.connectors.2.1;version=latest,\
    io.openliberty.jakarta.messaging.3.1;version=latest,\
    io.openliberty.jakarta.servlet.5.0;version=latest

