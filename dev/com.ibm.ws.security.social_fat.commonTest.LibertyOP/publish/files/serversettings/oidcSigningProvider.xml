<server>

	<openidConnectProvider
		id="OidcConfigSigning"
		scope="myScopeSample"
		jwkEnabled="false"
		signatureAlgorithm="RS256"
		keyStoreRef="key_allSigAlg"
		keyAliasName="rs256"
		oauthProviderRef="OAuthConfigSigning" />

	<oauthProvider
		id="OAuthConfigSigning"
		filter="request-url%=SimpleServlet;request-url!=snooping"
		httpsRequired="false"
		autoAuthorize="true"
		jwtAccessToken="true"
	>

		<autoAuthorizeClient>client01</autoAuthorizeClient>

        
		<localStore>
			<client
				name="client01"
				secret="{xor}LDo8LTorbm1saw=="
				displayname="client01"
				redirect="https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/hs256,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/hs384,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/hs512,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/rs256,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/rs256Implicit,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/rs384,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/rs512,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/es256,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/es384,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/es512,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderHS256,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderHS384,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderHS512,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderRS256,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderRS384,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderRS512,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderES256,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderES384,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderES512,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderHSSigAlg,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderRSSigAlg,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderESSigAlg,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeaderHS256RS384ES512,
					https://localhost:${bvt.prop.security_2_HTTP_default.secure}/ibm/api/social-login/redirect/FromHeader,
